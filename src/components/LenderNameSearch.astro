---
// LenderNameSearch — typeahead input for finding a lender review by company name.
// - Index (~1.3 MB raw, ~260 KB gzipped) is lazy-loaded on FIRST focus, not on page load.
// - Fuse.js for typo tolerance, also lazy-loaded from jsdelivr on first focus.
// - Can be placed multiple times on a page; each instance shares the same cached fetch.
//
// Props:
//   variant?: 'hero' | 'inline'   — styling preset. Defaults to 'inline'.
//   placeholder?: string          — input placeholder override.
export interface Props {
  variant?: 'hero' | 'inline';
  placeholder?: string;
}
const { variant = 'inline', placeholder = 'Search by company name (e.g. "EZ Credit", "WalletHub")' } = Astro.props;

// Unique id so multiple instances on the same page don't collide
const uid = `lns_${Math.random().toString(36).slice(2, 10)}`;

const wrapperClass = variant === 'hero'
  ? 'w-full max-w-2xl mx-auto'
  : 'w-full max-w-3xl mx-auto';

const inputClass = variant === 'hero'
  ? 'w-full pl-12 pr-4 py-4 text-base rounded-xl border-2 border-border bg-white text-text shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-all'
  : 'w-full pl-11 pr-4 py-3 text-sm rounded-lg border border-border bg-white text-text focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-all';
---

<div class={`lns-root ${wrapperClass}`} data-uid={uid}>
  <div class="relative">
    <svg xmlns="http://www.w3.org/2000/svg" class:list={['absolute top-1/2 -translate-y-1/2 pointer-events-none text-muted', variant === 'hero' ? 'left-4 h-5 w-5' : 'left-3.5 h-4 w-4']} viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd"/>
    </svg>
    <input
      type="text"
      id={`${uid}-input`}
      class={inputClass}
      placeholder={placeholder}
      autocomplete="off"
      spellcheck="false"
      aria-label="Search lenders by name"
      aria-autocomplete="list"
      aria-controls={`${uid}-dropdown`}
    />
    <!-- Loading spinner overlay (only while index is being fetched) -->
    <div id={`${uid}-spinner`} class:list={['absolute top-1/2 -translate-y-1/2 hidden', variant === 'hero' ? 'right-4' : 'right-3.5']}>
      <svg class="animate-spin h-4 w-4 text-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/>
      </svg>
    </div>
  </div>

  <div
    id={`${uid}-dropdown`}
    role="listbox"
    class="relative z-30 mt-2 hidden rounded-lg border border-border bg-white shadow-lg overflow-hidden"
  ></div>
</div>

<script>
  // Module-level cache shared across all instances on the page
  type LenderHit = { s: string; n: string; c: string; st: string; p?: number };
  // @ts-ignore — attach to window for instance-to-instance sharing
  const G = (window.__creditdocLenderSearch ||= {
    index: null as LenderHit[] | null,
    fuse: null as any,
    loading: null as Promise<void> | null,
  });

  // Rank hits: Founder Approved first → name starts with query → shortest name.
  // Without this, Fuse's default sort promotes short noise like "Bank of America ATM"
  // above the canonical "Bank of America" entry.
  function rankHits(hits: LenderHit[], query: string): LenderHit[] {
    const q = query.trim().toLowerCase();
    return hits.slice().sort((a, b) => {
      const ap = a.p ? 1 : 0;
      const bp = b.p ? 1 : 0;
      if (ap !== bp) return bp - ap;
      const as = a.n.toLowerCase().startsWith(q) ? 1 : 0;
      const bs = b.n.toLowerCase().startsWith(q) ? 1 : 0;
      if (as !== bs) return bs - as;
      return a.n.length - b.n.length;
    });
  }

  async function ensureIndex(): Promise<void> {
    if (G.index && G.fuse) return;
    if (G.loading) return G.loading;
    G.loading = (async () => {
      // Lazy-load Fuse.js from jsdelivr (CDN cache hit across sites)
      const [fuseMod, resp] = await Promise.all([
        import(/* @vite-ignore */ 'https://cdn.jsdelivr.net/npm/fuse.js@7.0.0/dist/fuse.mjs'),
        fetch('/search/lender-name-index.json', { cache: 'force-cache' }),
      ]);
      if (!resp.ok) throw new Error(`index fetch ${resp.status}`);
      G.index = await resp.json();
      const Fuse = (fuseMod as any).default ?? (fuseMod as any);
      G.fuse = new Fuse(G.index, {
        keys: ['n'],
        threshold: 0.3,           // typo tolerance — lower = stricter, higher = fuzzier
        ignoreLocation: true,
        minMatchCharLength: 2,
        shouldSort: true,
        includeScore: false,
      });
    })();
    return G.loading;
  }

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, c => (
      { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' } as Record<string, string>
    )[c]);
  }

  function initInstance(root: HTMLElement) {
    const uid = root.dataset.uid!;
    const input = document.getElementById(`${uid}-input`) as HTMLInputElement;
    const dropdown = document.getElementById(`${uid}-dropdown`) as HTMLElement;
    const spinner = document.getElementById(`${uid}-spinner`) as HTMLElement;
    let activeIndex = -1;
    let currentResults: LenderHit[] = [];
    let currentQuery = '';
    let currentTotal = 0;

    function hide() {
      dropdown.classList.add('hidden');
      dropdown.innerHTML = '';
      activeIndex = -1;
    }

    function render(results: typeof currentResults, query: string, totalMatches: number) {
      if (!results.length) {
        dropdown.innerHTML = `
          <div class="px-4 py-3 text-sm text-muted">
            No company matches <span class="font-semibold text-text">"${escapeHtml(query)}"</span>.
            <a href="/categories/" class="ml-1 text-primary hover:underline">Browse categories</a>
            or
            <a href="/search/?q=${encodeURIComponent(query)}" class="text-primary hover:underline">open full search</a>.
          </div>`;
        dropdown.classList.remove('hidden');
        return;
      }
      const itemsHtml = results.map((r, i) => {
        const loc = [r.c, r.st].filter(Boolean).join(', ');
        const badge = r.p ? '<span class="inline-flex items-center rounded-full bg-primary/10 text-primary px-2 py-0.5 text-[10px] font-semibold mr-2 shrink-0">FA</span>' : '';
        return `<a href="/review/${encodeURIComponent(r.s)}/" role="option" data-idx="${i}" class="lns-item flex items-center justify-between gap-3 px-4 py-3 text-sm hover:bg-bg-alt border-b border-border last:border-b-0">
          <span class="flex items-center min-w-0 flex-1">${badge}<span class="font-medium text-text truncate">${escapeHtml(r.n)}</span></span>
          ${loc ? `<span class="text-xs text-muted shrink-0">${escapeHtml(loc)}</span>` : ''}
        </a>`;
      }).join('');
      const moreCount = totalMatches - results.length;
      const footer = `<a href="/search/?q=${encodeURIComponent(query)}" class="flex items-center justify-center gap-1.5 px-4 py-3 text-sm font-semibold text-primary hover:bg-primary-light border-t border-border bg-bg-alt/50">
          ${moreCount > 0 ? `See all ${totalMatches} matches for "${escapeHtml(query)}"` : `Open full search for "${escapeHtml(query)}"`}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/></svg>
        </a>`;
      dropdown.innerHTML = itemsHtml + footer;
      dropdown.classList.remove('hidden');
    }

    function updateActive() {
      dropdown.querySelectorAll<HTMLElement>('.lns-item').forEach((el, i) => {
        if (i === activeIndex) {
          el.classList.add('bg-bg-alt');
          el.scrollIntoView({ block: 'nearest' });
        } else {
          el.classList.remove('bg-bg-alt');
        }
      });
    }

    let debounce: number | undefined;
    async function onInput() {
      const q = input.value.trim();
      if (q.length < 2) {
        hide();
        return;
      }
      await loadAndMaybeSpin();
      if (!G.fuse) return;
      // Pull a wider slice so the FA/startsWith re-rank has room to work,
      // then keep the top 8 for the dropdown.
      const allHits: LenderHit[] = G.fuse.search(q, { limit: 50 }).map((h: any) => h.item);
      const ranked = rankHits(allHits, q);
      const shown = ranked.slice(0, 8);
      currentResults = shown;
      currentQuery = q;
      currentTotal = allHits.length;
      activeIndex = -1;
      render(shown, q, allHits.length);
    }

    async function loadAndMaybeSpin() {
      if (G.index && G.fuse) return;
      spinner.classList.remove('hidden');
      try {
        await ensureIndex();
      } catch (e) {
        dropdown.innerHTML = `<div class="px-4 py-3 text-sm text-red-600">Search unavailable right now. <a href="/search/" class="underline">Use full search</a>.</div>`;
        dropdown.classList.remove('hidden');
      } finally {
        spinner.classList.add('hidden');
      }
    }

    input.addEventListener('focus', () => { loadAndMaybeSpin(); });
    input.addEventListener('input', () => {
      clearTimeout(debounce);
      debounce = window.setTimeout(onInput, 100);
    });
    input.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (!currentResults.length) return;
        activeIndex = (activeIndex + 1) % currentResults.length;
        updateActive();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (!currentResults.length) return;
        activeIndex = activeIndex <= 0 ? currentResults.length - 1 : activeIndex - 1;
        updateActive();
      } else if (e.key === 'Enter') {
        e.preventDefault();
        const q = input.value.trim();
        // Arrow-selected item → open that review.
        // Otherwise → send to the full results page (don't auto-pick the top Fuse hit;
        // that's how "Bank of America ATM" was winning over canonical Bank of America).
        if (activeIndex >= 0 && currentResults[activeIndex]) {
          location.href = `/review/${encodeURIComponent(currentResults[activeIndex].s)}/`;
        } else if (q) {
          location.href = `/search/?q=${encodeURIComponent(q)}`;
        }
      } else if (e.key === 'Escape') {
        hide();
        input.blur();
      }
    });

    document.addEventListener('click', (e) => {
      if (!root.contains(e.target as Node)) hide();
    });
  }

  document.querySelectorAll<HTMLElement>('.lns-root').forEach(initInstance);
</script>
