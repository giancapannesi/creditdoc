---
const categories = [
  { value: 'credit-repair', label: 'Credit Repair' },
  { value: 'personal-loans', label: 'Personal Loans' },
  { value: 'debt-relief', label: 'Debt Relief' },
  { value: 'credit-cards', label: 'Credit Cards' },
];

const budgets = [
  { value: 'under-50', label: 'Under $50/mo' },
  { value: '50-100', label: '$50-$100/mo' },
  { value: '100-150', label: '$100-$150/mo' },
  { value: '150-plus', label: '$150+/mo' },
];

const bbbRatings = [
  { value: 'a-plus', label: 'A+ Only' },
  { value: 'a-or-higher', label: 'A or Higher' },
  { value: 'b-or-higher', label: 'B or Higher' },
  { value: 'any', label: 'Any Rating' },
];
---

<div class="glass-card p-6 sm:p-8">
  <div class="text-center mb-6">
    <h2 class="text-lg sm:text-xl font-bold text-text">Find the Right Service for You</h2>
    <p class="text-sm text-muted mt-1">Answer three quick questions to see your best matches</p>
  </div>

  <form id="filter-form" class="flex flex-col gap-4 sm:flex-row sm:items-end sm:gap-3">
    <!-- Category -->
    <div class="flex-1 min-w-0">
      <label for="filter-need" class="block text-xs font-semibold text-text uppercase tracking-wider mb-1.5">
        I need help with
      </label>
      <select
        id="filter-need"
        name="category"
        class="w-full rounded-lg border border-border bg-white px-3 py-3 text-sm text-text focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors min-h-[44px]"
      >
        <option value="">Select a category...</option>
        {categories.map(cat => (
          <option value={cat.value}>{cat.label}</option>
        ))}
      </select>
    </div>

    <!-- Budget -->
    <div class="flex-1 min-w-0">
      <label for="filter-budget" class="block text-xs font-semibold text-text uppercase tracking-wider mb-1.5">
        My budget
      </label>
      <select
        id="filter-budget"
        name="budget"
        class="w-full rounded-lg border border-border bg-white px-3 py-3 text-sm text-text focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors min-h-[44px]"
      >
        <option value="">Any budget...</option>
        {budgets.map(b => (
          <option value={b.value}>{b.label}</option>
        ))}
      </select>
    </div>

    <!-- BBB Rating -->
    <div class="flex-1 min-w-0">
      <label for="filter-bbb" class="block text-xs font-semibold text-text uppercase tracking-wider mb-1.5">
        BBB Rating
      </label>
      <select
        id="filter-bbb"
        name="bbb"
        class="w-full rounded-lg border border-border bg-white px-3 py-3 text-sm text-text focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors min-h-[44px]"
      >
        <option value="">Any rating...</option>
        {bbbRatings.map(r => (
          <option value={r.value}>{r.label}</option>
        ))}
      </select>
    </div>

    <!-- CTA -->
    <div class="sm:shrink-0">
      <button
        type="submit"
        class="w-full sm:w-auto flex items-center justify-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-white hover:bg-primary-hover transition-colors min-h-[44px] shadow-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd"/>
        </svg>
        See Matches
      </button>
    </div>
  </form>
</div>

<script>
  const form = document.getElementById('filter-form') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const category = (document.getElementById('filter-need') as HTMLSelectElement)?.value;
    const budget = (document.getElementById('filter-budget') as HTMLSelectElement)?.value;
    const bbb = (document.getElementById('filter-bbb') as HTMLSelectElement)?.value;

    // Route to category page if selected, otherwise to search
    if (category) {
      const params = new URLSearchParams();
      if (budget) params.set('budget', budget);
      if (bbb) params.set('bbb', bbb);
      const qs = params.toString();
      window.location.href = `/categories/${category}/${qs ? '?' + qs : ''}`;
    } else {
      const params = new URLSearchParams();
      if (budget) params.set('budget', budget);
      if (bbb) params.set('bbb', bbb);
      const qs = params.toString();
      window.location.href = `/search/${qs ? '?' + qs : ''}`;
    }
  });
</script>
