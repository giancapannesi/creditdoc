---
import type { Lender } from '../utils/data';
import RatingStars from './RatingStars.astro';
import { formatPrice, getBbbClass } from '../utils/data';

interface Props {
  lenders: Lender[];
}

const { lenders } = Astro.props;
const sorted = [...lenders].sort((a, b) => b.rating - a.rating);
---

<div class="overflow-x-auto -mx-4 sm:mx-0 rounded-xl border border-border">
  <table class="w-full min-w-[700px] text-sm">
    <thead>
      <tr class="bg-bg-alt border-b-2 border-border">
        <th class="text-left py-3.5 px-4 font-semibold text-text w-10">#</th>
        <th class="text-left py-3.5 px-4 font-semibold text-text">Provider</th>
        <th class="text-left py-3.5 px-4 font-semibold text-text">Price</th>
        <th class="text-center py-3.5 px-4 font-semibold text-text">BBB</th>
        <th class="text-center py-3.5 px-4 font-semibold text-text">Guarantee</th>
        <th class="text-left py-3.5 px-4 font-semibold text-text">Best For</th>
        <th class="text-center py-3.5 px-4 font-semibold text-text">Action</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-border">
      {sorted.map((lender, i) => {
        const bbbClass = getBbbClass(lender.company_info.bbb_rating);
        return (
          <tr class="hover:bg-bg-alt/50 transition-colors bg-white">
            <!-- Rank -->
            <td class="py-4 px-4">
              <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-primary-light text-primary text-xs font-bold">
                {i + 1}
              </span>
            </td>

            <!-- Provider (logo + name + description) -->
            <td class="py-4 px-4">
              <div class="flex items-center gap-3">
                <div class="shrink-0 w-10 h-10 rounded-lg bg-bg-alt border border-border flex items-center justify-center overflow-hidden">
                  {lender.logo_url ? (
                    <img src={lender.logo_url} alt={lender.name} class="w-7 h-7 object-contain" loading="lazy" />
                  ) : (
                    <span class="text-xs font-bold text-primary">{lender.name.charAt(0)}</span>
                  )}
                </div>
                <div class="min-w-0">
                  <a href={`/review/${lender.slug}/`} class="font-semibold text-text hover:text-primary transition-colors block truncate">
                    {lender.name}
                  </a>
                  <div class="mt-0.5">
                    <RatingStars rating={lender.rating} size="sm" />
                  </div>
                </div>
              </div>
            </td>

            <!-- Price -->
            <td class="py-4 px-4">
              <span class="font-semibold text-text">
                {formatPrice(lender.pricing.monthly_price)}
              </span>
              {lender.pricing.monthly_price > 0 && (
                <span class="text-muted text-xs">/mo</span>
              )}
              {lender.pricing.setup_fee > 0 && (
                <p class="text-xs text-muted mt-0.5">
                  + {formatPrice(lender.pricing.setup_fee)} setup
                </p>
              )}
            </td>

            <!-- BBB -->
            <td class="py-4 px-4 text-center">
              <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold ${bbbClass}`}>
                {lender.company_info.bbb_rating}
              </span>
            </td>

            <!-- Guarantee -->
            <td class="py-4 px-4 text-center">
              {lender.pricing.money_back_guarantee ? (
                <span class="inline-flex items-center gap-1 text-positive">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-xs font-medium">Yes</span>
                </span>
              ) : (
                <span class="text-xs text-muted">No</span>
              )}
            </td>

            <!-- Best For -->
            <td class="py-4 px-4">
              <span class="text-xs text-muted line-clamp-2 max-w-[180px]">
                {lender.best_for.slice(0, 2).join(', ')}
              </span>
            </td>

            <!-- Action -->
            <td class="py-4 px-4 text-center">
              <a
                href={`/review/${lender.slug}/`}
                class="inline-flex items-center gap-1 rounded-lg bg-primary px-4 py-2.5 text-xs font-semibold text-white hover:bg-primary-hover transition-colors min-h-[44px] whitespace-nowrap"
              >
                View Details
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
                </svg>
              </a>
            </td>
          </tr>
        );
      })}
    </tbody>
  </table>
</div>
