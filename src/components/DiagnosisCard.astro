---
interface Props {
  diagnosis: string;
  lenderName: string;
}

const { diagnosis, lenderName } = Astro.props;
---

<div class="rounded-xl border border-primary/20 bg-primary-light/30 p-5 sm:p-6 border-l-4 border-l-primary">
  <div class="flex items-start gap-3">
    <!-- Stethoscope Icon -->
    <div class="shrink-0 w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6 6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/>
        <path d="M8 15v1a6 6 0 0 0 6 6 6 6 0 0 0 6-6v-4"/>
        <circle cx="20" cy="10" r="2"/>
      </svg>
    </div>

    <div class="flex-1 min-w-0">
      <!-- CreditDoc Diagnosis branding -->
      <p class="text-xs font-semibold uppercase tracking-wider text-primary mb-1">CreditDoc Diagnosis</p>

      <!-- Doctor's Verdict heading -->
      <h4 class="text-base font-bold text-text mb-2">
        Doctor's Verdict on {lenderName}
      </h4>

      <!-- Diagnosis text -->
      <p class="text-sm text-text leading-relaxed">
        {diagnosis}
      </p>
    </div>
  </div>
</div>
