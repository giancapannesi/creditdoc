---
interface Props {
  type: 'verified' | 'bbb-a-plus' | 'money-back' | 'updated' | string;
  text?: string;
}

const { type, text } = Astro.props;

const badgeConfig: Record<string, { bg: string; textColor: string; icon: string; defaultText: string }> = {
  'verified': {
    bg: 'bg-accent/10',
    textColor: 'text-accent',
    icon: 'check-circle',
    defaultText: 'Verified',
  },
  'bbb-a-plus': {
    bg: 'bg-positive-light',
    textColor: 'text-positive',
    icon: 'shield-check',
    defaultText: 'BBB A+',
  },
  'money-back': {
    bg: 'bg-positive-light',
    textColor: 'text-positive',
    icon: 'shield',
    defaultText: 'Money-Back',
  },
  'updated': {
    bg: 'bg-bg-alt',
    textColor: 'text-muted',
    icon: 'clock',
    defaultText: 'Updated',
  },
};

const config = badgeConfig[type] || badgeConfig['verified'];
const displayText = text || config.defaultText;
---

<span class={`inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-medium ${config.bg} ${config.textColor}`}>
  {config.icon === 'check-circle' && (
    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/>
    </svg>
  )}
  {config.icon === 'shield-check' && (
    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M9.661 2.237a.531.531 0 01.678 0 11.947 11.947 0 007.078 2.749.5.5 0 01.479.425c.069.52.104 1.05.104 1.59 0 5.162-3.26 9.563-7.834 11.256a.48.48 0 01-.332 0C5.26 16.564 2 12.163 2 7c0-.538.035-1.069.104-1.589a.5.5 0 01.48-.425 11.947 11.947 0 007.077-2.75zm4.196 5.954a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/>
    </svg>
  )}
  {config.icon === 'shield' && (
    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M9.661 2.237a.531.531 0 01.678 0 11.947 11.947 0 007.078 2.749.5.5 0 01.479.425c.069.52.104 1.05.104 1.59 0 5.162-3.26 9.563-7.834 11.256a.48.48 0 01-.332 0C5.26 16.564 2 12.163 2 7c0-.538.035-1.069.104-1.589a.5.5 0 01.48-.425 11.947 11.947 0 007.077-2.75z" clip-rule="evenodd"/>
    </svg>
  )}
  {config.icon === 'clock' && (
    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-13a.75.75 0 00-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 000-1.5h-3.25V5z" clip-rule="evenodd"/>
    </svg>
  )}
  {displayText}
</span>
