---
import type { Lender } from '../utils/data';
import { getBbbClass, formatPrice } from '../utils/data';
import RatingStars from './RatingStars.astro';
import TrustBadge from './TrustBadge.astro';

interface Props {
  lender: Lender;
}

const { lender } = Astro.props;

const bbbClass = getBbbClass(lender.company_info.bbb_rating);
const monthlyPrice = formatPrice(lender.pricing.monthly_price);
---

<article class="glass-card p-5 sm:p-6 flex flex-col h-full">
  <!-- Top: Logo + Name -->
  <div class="flex items-start gap-4">
    <div class="shrink-0 w-14 h-14 rounded-xl bg-bg-alt border border-border flex items-center justify-center overflow-hidden">
      {lender.logo_url ? (
        <img
          src={lender.logo_url}
          alt={`${lender.name} logo`}
          class="w-10 h-10 object-contain"
          loading="lazy"
        />
      ) : (
        <span class="text-lg font-bold text-primary">
          {lender.name.charAt(0)}
        </span>
      )}
    </div>
    <div class="flex-1 min-w-0">
      <h3 class="text-lg font-semibold text-text truncate">{lender.name}</h3>
      <p class="text-sm text-muted mt-0.5 line-clamp-2">{lender.description_short}</p>
    </div>
  </div>

  <!-- Rating -->
  <div class="mt-4">
    <RatingStars rating={lender.rating} size="sm" />
  </div>

  <!-- Badges Row -->
  <div class="mt-3 flex flex-wrap items-center gap-2">
    <!-- Price badge -->
    <span class="inline-flex items-center rounded-full bg-bg-alt px-3 py-1 text-xs font-semibold text-text border border-border">
      {monthlyPrice === 'Free' ? 'Free' : `${monthlyPrice}/mo`}
    </span>

    <!-- BBB Rating pill -->
    <span class={`inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold ${bbbClass}`}>
      BBB: {lender.company_info.bbb_rating}
    </span>

    <!-- Money-Back Guarantee -->
    {lender.pricing.money_back_guarantee && (
      <TrustBadge type="money-back" />
    )}
  </div>

  <!-- Best For -->
  {lender.best_for.length > 0 && (
    <div class="mt-3">
      <p class="text-xs text-muted">
        <span class="font-medium">Best for:</span> {lender.best_for.slice(0, 2).join(', ')}
      </p>
    </div>
  )}

  <!-- Spacer -->
  <div class="flex-1"></div>

  <!-- CTA -->
  <div class="mt-5">
    <a
      href={`/review/${lender.slug}/`}
      class="flex items-center justify-center w-full rounded-lg bg-primary px-4 py-3 text-sm font-semibold text-white hover:bg-primary-hover transition-colors min-h-[44px]"
    >
      View Details
      <svg xmlns="http://www.w3.org/2000/svg" class="ml-1.5 h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
      </svg>
    </a>
  </div>
</article>
