---
import { US_STATES, TOP_CITIES } from '../utils/data';

const topCitiesJson = JSON.stringify(TOP_CITIES.map(c => `${c.city}, ${c.state}`));
---

<div class="glass-card p-6 sm:p-8" style="transform: none;">
  <h2 class="text-lg sm:text-xl font-bold text-text text-center mb-2">Find Credit Services Near You</h2>
  <p class="text-sm text-muted text-center mb-6">Search by keyword, state, or city to find services in your area</p>

  <form id="search-form-services" action="/search/" method="get" class="space-y-5">
    <input type="hidden" name="mode" value="services" />

    <!-- Row 1: Keyword + State + City -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      <!-- Keyword -->
      <div>
        <label for="svc-keyword" class="block text-xs font-semibold text-text uppercase tracking-wider mb-1.5">
          Keyword
        </label>
        <div class="relative">
          <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd"/>
          </svg>
          <input
            type="text"
            id="svc-keyword"
            name="q"
            placeholder="e.g. credit repair, debt..."
            class="w-full rounded-lg border border-border bg-white py-3 pl-9 pr-3 text-sm text-text placeholder:text-muted/60 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors min-h-[44px]"
          />
        </div>
      </div>

      <!-- State -->
      <div>
        <label for="svc-state" class="block text-xs font-semibold text-text uppercase tracking-wider mb-1.5">
          State
        </label>
        <select
          id="svc-state"
          name="state"
          class="w-full rounded-lg border border-border bg-white px-3 py-3 text-sm text-text focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors min-h-[44px]"
        >
          <option value="">All states...</option>
          {US_STATES.map(state => (
            <option value={state}>{state}</option>
          ))}
        </select>
      </div>

      <!-- City -->
      <div class="relative">
        <label for="svc-city" class="block text-xs font-semibold text-text uppercase tracking-wider mb-1.5">
          City
        </label>
        <input
          type="text"
          id="svc-city"
          name="city"
          placeholder="Start typing a city..."
          autocomplete="off"
          class="w-full rounded-lg border border-border bg-white px-3 py-3 text-sm text-text placeholder:text-muted/60 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors min-h-[44px]"
        />
        <ul
          id="svc-city-autocomplete"
          class="hidden absolute z-20 left-0 right-0 top-full mt-1 max-h-48 overflow-y-auto rounded-lg border border-border bg-white shadow-lg"
        ></ul>
      </div>
    </div>

    <!-- Row 2: Filter checkboxes -->
    <div class="flex flex-wrap gap-x-6 gap-y-3">
      <label class="inline-flex items-center gap-2 cursor-pointer group">
        <input
          type="checkbox"
          name="guarantee"
          value="1"
          class="h-4 w-4 rounded border-border text-primary focus:ring-primary/30 cursor-pointer accent-primary"
        />
        <span class="text-sm text-text group-hover:text-primary transition-colors">Money-back guarantee</span>
      </label>

      <label class="inline-flex items-center gap-2 cursor-pointer group">
        <input
          type="checkbox"
          name="bbb_a_plus"
          value="1"
          class="h-4 w-4 rounded border-border text-primary focus:ring-primary/30 cursor-pointer accent-primary"
        />
        <span class="text-sm text-text group-hover:text-primary transition-colors">BBB A+ only</span>
      </label>

      <label class="inline-flex items-center gap-2 cursor-pointer group">
        <input
          type="checkbox"
          name="free_consult"
          value="1"
          class="h-4 w-4 rounded border-border text-primary focus:ring-primary/30 cursor-pointer accent-primary"
        />
        <span class="text-sm text-text group-hover:text-primary transition-colors">Free consultation</span>
      </label>

      <label class="inline-flex items-center gap-2 cursor-pointer group">
        <input
          type="checkbox"
          name="all_bureaus"
          value="1"
          class="h-4 w-4 rounded border-border text-primary focus:ring-primary/30 cursor-pointer accent-primary"
        />
        <span class="text-sm text-text group-hover:text-primary transition-colors">All 3 bureaus</span>
      </label>
    </div>

    <!-- Row 3: Search button + browse link -->
    <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4">
      <button
        type="submit"
        class="flex items-center justify-center gap-2 rounded-lg bg-primary px-8 py-3 text-sm font-semibold text-white hover:bg-primary-hover transition-colors min-h-[44px] shadow-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd"/>
        </svg>
        Search
      </button>

      <div class="flex-1 text-center sm:text-right">
        <span class="text-xs text-muted">
          or browse by <a href="/categories/credit-repair/" class="text-primary hover:underline">category</a>
        </span>
      </div>
    </div>
  </form>

  <!-- Browse by State hint -->
  <div class="mt-6 rounded-xl border border-border bg-bg-alt p-4 text-center">
    <p class="text-sm text-muted">Use the dropdowns above to search by location, or <a href="/search/#browse-by-state" class="text-primary hover:underline font-medium">browse all 50 states</a></p>
  </div>
</div>

<script define:vars={{ topCitiesJson }}>
  const cities = JSON.parse(topCitiesJson);

  // ===== Pre-fill services form from URL params =====
  var urlParams = new URLSearchParams(window.location.search);
  var svcKeyword = document.getElementById('svc-keyword');
  var svcState = document.getElementById('svc-state');
  var svcCity = document.getElementById('svc-city');

  if (svcKeyword && urlParams.get('q')) svcKeyword.value = urlParams.get('q');
  if (svcState && urlParams.get('state')) svcState.value = urlParams.get('state');
  if (svcCity && urlParams.get('city')) svcCity.value = urlParams.get('city');

  // Pre-fill checkboxes
  var svcForm = document.getElementById('search-form-services');
  if (svcForm) {
    ['guarantee', 'bbb_a_plus', 'free_consult', 'all_bureaus'].forEach(function(name) {
      var cb = svcForm.querySelector('input[name="' + name + '"]');
      if (cb && urlParams.get(name) === '1') cb.checked = true;
    });
  }

  // ===== City Autocomplete =====
  function setupCityAutocomplete(inputId, listId) {
    var cityInput = document.getElementById(inputId);
    var autocompleteList = document.getElementById(listId);

    if (!cityInput || !autocompleteList) return;

    cityInput.addEventListener('input', function () {
      var val = this.value.toLowerCase().trim();
      autocompleteList.innerHTML = '';

      if (val.length < 2) {
        autocompleteList.classList.add('hidden');
        return;
      }

      var matches = cities.filter(function(c) {
        return c.toLowerCase().indexOf(val) !== -1;
      }).slice(0, 8);

      if (matches.length === 0) {
        autocompleteList.classList.add('hidden');
        return;
      }

      matches.forEach(function(city) {
        var li = document.createElement('li');
        li.textContent = city;
        li.className = 'px-3 py-2.5 text-sm text-text hover:bg-primary-light hover:text-primary cursor-pointer transition-colors';
        li.style.minHeight = '44px';
        li.style.display = 'flex';
        li.style.alignItems = 'center';
        li.addEventListener('click', function() {
          cityInput.value = city;
          autocompleteList.classList.add('hidden');
        });
        autocompleteList.appendChild(li);
      });

      autocompleteList.classList.remove('hidden');
    });

    // Close on click outside
    document.addEventListener('click', function(e) {
      if (!cityInput.contains(e.target) && !autocompleteList.contains(e.target)) {
        autocompleteList.classList.add('hidden');
      }
    });

    // Close on Escape
    cityInput.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        autocompleteList.classList.add('hidden');
      }
    });
  }

  setupCityAutocomplete('svc-city', 'svc-city-autocomplete');

  // ===== Form Submission =====
  if (svcForm) {
    svcForm.addEventListener('submit', function(e) {
      e.preventDefault();
      var formData = new FormData(svcForm);
      var params = new URLSearchParams();
      for (var pair of formData.entries()) {
        if (pair[1]) params.set(pair[0], String(pair[1]));
      }
      // Checkboxes
      var checkboxes = svcForm.querySelectorAll('input[type="checkbox"]');
      checkboxes.forEach(function(cb) {
        if (cb.checked) params.set(cb.name, cb.value);
      });
      window.history.pushState({}, '', '/search/?' + params.toString());
      // Dispatch a custom event so the search page can re-filter
      window.dispatchEvent(new CustomEvent('searchbar:submit'));
    });
  }
</script>
