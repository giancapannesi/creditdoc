---
import { US_STATES, TOP_CITIES } from '../utils/data';

const topCitiesJson = JSON.stringify(TOP_CITIES.map(c => `${c.city}, ${c.state}`));
---

<div class="glass-card p-6 sm:p-8">
  <h2 class="text-lg sm:text-xl font-bold text-text text-center mb-2">Find Credit Services Near You</h2>
  <p class="text-sm text-muted text-center mb-6">Search by keyword, state, or city to find services in your area</p>

  <form id="search-form" action="/search/" method="get" class="space-y-5">
    <!-- Row 1: Keyword + State + City -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      <!-- Keyword -->
      <div>
        <label for="search-keyword" class="block text-xs font-semibold text-text uppercase tracking-wider mb-1.5">
          Keyword
        </label>
        <div class="relative">
          <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd"/>
          </svg>
          <input
            type="text"
            id="search-keyword"
            name="q"
            placeholder="e.g. credit repair, debt..."
            class="w-full rounded-lg border border-border bg-white py-3 pl-9 pr-3 text-sm text-text placeholder:text-muted/60 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors min-h-[44px]"
          />
        </div>
      </div>

      <!-- State -->
      <div>
        <label for="search-state" class="block text-xs font-semibold text-text uppercase tracking-wider mb-1.5">
          State
        </label>
        <select
          id="search-state"
          name="state"
          class="w-full rounded-lg border border-border bg-white px-3 py-3 text-sm text-text focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors min-h-[44px]"
        >
          <option value="">All states...</option>
          {US_STATES.map(state => (
            <option value={state}>{state}</option>
          ))}
        </select>
      </div>

      <!-- City -->
      <div class="relative">
        <label for="search-city" class="block text-xs font-semibold text-text uppercase tracking-wider mb-1.5">
          City
        </label>
        <input
          type="text"
          id="search-city"
          name="city"
          placeholder="Start typing a city..."
          autocomplete="off"
          class="w-full rounded-lg border border-border bg-white px-3 py-3 text-sm text-text placeholder:text-muted/60 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors min-h-[44px]"
        />
        <ul
          id="city-autocomplete"
          class="hidden absolute z-20 left-0 right-0 top-full mt-1 max-h-48 overflow-y-auto rounded-lg border border-border bg-white shadow-lg"
        ></ul>
      </div>
    </div>

    <!-- Row 2: Filter checkboxes -->
    <div class="flex flex-wrap gap-x-6 gap-y-3">
      <label class="inline-flex items-center gap-2 cursor-pointer group">
        <input
          type="checkbox"
          name="guarantee"
          value="1"
          class="h-4 w-4 rounded border-border text-primary focus:ring-primary/30 cursor-pointer"
        />
        <span class="text-sm text-text group-hover:text-primary transition-colors">Money-back guarantee</span>
      </label>

      <label class="inline-flex items-center gap-2 cursor-pointer group">
        <input
          type="checkbox"
          name="bbb_a_plus"
          value="1"
          class="h-4 w-4 rounded border-border text-primary focus:ring-primary/30 cursor-pointer"
        />
        <span class="text-sm text-text group-hover:text-primary transition-colors">BBB A+ only</span>
      </label>

      <label class="inline-flex items-center gap-2 cursor-pointer group">
        <input
          type="checkbox"
          name="free_consult"
          value="1"
          class="h-4 w-4 rounded border-border text-primary focus:ring-primary/30 cursor-pointer"
        />
        <span class="text-sm text-text group-hover:text-primary transition-colors">Free consultation</span>
      </label>

      <label class="inline-flex items-center gap-2 cursor-pointer group">
        <input
          type="checkbox"
          name="under_100"
          value="1"
          class="h-4 w-4 rounded border-border text-primary focus:ring-primary/30 cursor-pointer"
        />
        <span class="text-sm text-text group-hover:text-primary transition-colors">Under $100/mo</span>
      </label>
    </div>

    <!-- Row 3: Search button + Map placeholder -->
    <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4">
      <button
        type="submit"
        class="flex items-center justify-center gap-2 rounded-lg bg-primary px-8 py-3 text-sm font-semibold text-white hover:bg-primary-hover transition-colors min-h-[44px] shadow-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd"/>
        </svg>
        Search
      </button>

      <div class="flex-1 text-center sm:text-right">
        <span class="text-xs text-muted">
          or browse by <a href="/categories/credit-repair/" class="text-primary hover:underline">category</a>
        </span>
      </div>
    </div>
  </form>

  <!-- Map Placeholder -->
  <div
    id="map"
    class="mt-6 rounded-xl border border-border bg-bg-alt flex items-center justify-center p-8"
    style="min-height: 200px;"
  >
    <div class="text-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-muted mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z"/>
      </svg>
      <p class="text-sm text-muted font-medium">Map search coming soon</p>
      <p class="text-xs text-muted mt-1">Use the dropdowns above to search by location</p>
    </div>
  </div>
</div>

<script define:vars={{ topCitiesJson }}>
  const cities = JSON.parse(topCitiesJson);
  const cityInput = document.getElementById('search-city');
  const autocompleteList = document.getElementById('city-autocomplete');

  if (cityInput && autocompleteList) {
    cityInput.addEventListener('input', function () {
      const val = this.value.toLowerCase().trim();
      autocompleteList.innerHTML = '';

      if (val.length < 2) {
        autocompleteList.classList.add('hidden');
        return;
      }

      const matches = cities.filter(c => c.toLowerCase().includes(val)).slice(0, 8);

      if (matches.length === 0) {
        autocompleteList.classList.add('hidden');
        return;
      }

      matches.forEach(city => {
        const li = document.createElement('li');
        li.textContent = city;
        li.className = 'px-3 py-2.5 text-sm text-text hover:bg-primary-light hover:text-primary cursor-pointer transition-colors';
        li.style.minHeight = '44px';
        li.style.display = 'flex';
        li.style.alignItems = 'center';
        li.addEventListener('click', () => {
          cityInput.value = city;
          autocompleteList.classList.add('hidden');
        });
        autocompleteList.appendChild(li);
      });

      autocompleteList.classList.remove('hidden');
    });

    // Close on click outside
    document.addEventListener('click', (e) => {
      if (!cityInput.contains(e.target) && !autocompleteList.contains(e.target)) {
        autocompleteList.classList.add('hidden');
      }
    });

    // Close on Escape
    cityInput.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        autocompleteList.classList.add('hidden');
      }
    });
  }
</script>
