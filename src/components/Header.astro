---
import { getCategories } from '../utils/data';

const categories = getCategories();
const currentPath = Astro.url.pathname;

/* Group categories by section for the dropdown */
const creditRepair = categories.filter(c =>
  ['fix-my-credit', 'build-credit', 'credit-monitoring', 'credit-cards'].includes(c.slug)
);
const loansCash = categories.filter(c =>
  ['personal-loans', 'emergency-cash', 'payday-alternatives', 'business-loans', 'mortgages'].includes(c.slug)
);
const debtHelp = categories.filter(c =>
  ['debt-relief', 'free-help', 'bankruptcy'].includes(c.slug)
);
const services = categories.filter(c =>
  ['banking', 'check-cashing', 'insurance', 'pawn-shops', 'atm'].includes(c.slug)
);
---

<header class="sticky top-0 z-50 border-b border-border bg-white/80 backdrop-blur-lg">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 text-primary font-bold text-xl hover:opacity-90 transition-opacity">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6 6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/>
        <path d="M8 15v1a6 6 0 0 0 6 6 6 6 0 0 0 6-6v-4"/>
        <circle cx="20" cy="10" r="2"/>
      </svg>
      <span>CreditDoc</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-6">
      <!-- Categories Dropdown -->
      <div class="relative group">
        <button class="flex items-center gap-1 text-sm font-medium text-text hover:text-primary transition-colors py-2">
          Categories
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:rotate-180" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/>
          </svg>
        </button>
        <div class="invisible opacity-0 group-hover:visible group-hover:opacity-100 absolute left-0 top-full pt-2 transition-all duration-200">
          <div class="glass-card w-64 p-3 shadow-lg">
            <!-- Credit & Repair -->
            <p class="px-3 pt-1 pb-1.5 text-[11px] font-semibold uppercase tracking-wider text-muted">Credit & Repair</p>
            {creditRepair.map(cat => (
              <a
                href={`/categories/${cat.slug}/`}
                class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-text hover:bg-primary-light hover:text-primary transition-colors"
              >
                {cat.name}
              </a>
            ))}

            <!-- Separator -->
            <div class="my-2 border-t border-border"></div>

            <!-- Loans & Cash -->
            <p class="px-3 pt-1 pb-1.5 text-[11px] font-semibold uppercase tracking-wider text-muted">Loans & Cash</p>
            {loansCash.map(cat => (
              <a
                href={`/categories/${cat.slug}/`}
                class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-text hover:bg-primary-light hover:text-primary transition-colors"
              >
                {cat.name}
              </a>
            ))}

            <!-- Separator -->
            <div class="my-2 border-t border-border"></div>

            <!-- Debt & Help -->
            <p class="px-3 pt-1 pb-1.5 text-[11px] font-semibold uppercase tracking-wider text-muted">Debt & Help</p>
            {debtHelp.map(cat => (
              <a
                href={`/categories/${cat.slug}/`}
                class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-text hover:bg-primary-light hover:text-primary transition-colors"
              >
                {cat.name}
              </a>
            ))}

            <!-- Separator -->
            <div class="my-2 border-t border-border"></div>

            <!-- Services -->
            <p class="px-3 pt-1 pb-1.5 text-[11px] font-semibold uppercase tracking-wider text-muted">Services</p>
            {services.map(cat => (
              <a
                href={`/categories/${cat.slug}/`}
                class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-text hover:bg-primary-light hover:text-primary transition-colors"
              >
                {cat.name}
              </a>
            ))}
          </div>
        </div>
      </div>

      <a
        href="/deals/"
        class:list={[
          "text-sm font-medium transition-colors py-2",
          currentPath.startsWith('/deals') ? 'text-primary' : 'text-text hover:text-primary'
        ]}
      >
        Deals
      </a>

      <a
        href="/state/"
        class:list={[
          "text-sm font-medium transition-colors py-2",
          currentPath.startsWith('/state') ? 'text-primary' : 'text-text hover:text-primary'
        ]}
      >
        States
      </a>

      <a
        href="/tools/"
        class:list={[
          "text-sm font-medium transition-colors py-2",
          currentPath.startsWith('/tools') ? 'text-primary' : 'text-text hover:text-primary'
        ]}
      >
        Tools
      </a>

      <a
        href="/blog/"
        class:list={[
          "text-sm font-medium transition-colors py-2",
          currentPath.startsWith('/blog') ? 'text-primary' : 'text-text hover:text-primary'
        ]}
      >
        Blog
      </a>

      <a
        href="/financial-wellness/"
        class:list={[
          "text-sm font-medium transition-colors py-2",
          currentPath.startsWith('/financial-wellness') ? 'text-primary' : 'text-text hover:text-primary'
        ]}
      >
        Wellness
      </a>

      <a
        href="/learn/"
        class:list={[
          "text-sm font-medium transition-colors py-2",
          currentPath.startsWith('/learn') ? 'text-primary' : 'text-text hover:text-primary'
        ]}
      >
        Learn
      </a>

      <a
        href="/search/"
        class:list={[
          "text-sm font-medium transition-colors py-2",
          currentPath.startsWith('/search') ? 'text-primary' : 'text-text hover:text-primary'
        ]}
      >
        Search
      </a>

      <a
        href="/about/"
        class:list={[
          "text-sm font-medium transition-colors py-2",
          currentPath.startsWith('/about') ? 'text-primary' : 'text-text hover:text-primary'
        ]}
      >
        About
      </a>

    </div>

    <!-- Mobile Hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex items-center justify-center w-10 h-10 rounded-lg text-text hover:bg-bg-alt transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
      </svg>
      <svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-white/95 backdrop-blur-lg">
    <div class="px-4 py-4 space-y-1">
      <!-- Categories accordion -->
      <button
        id="mobile-categories-btn"
        class="flex w-full items-center justify-between rounded-lg px-3 py-3 text-sm font-medium text-text hover:bg-bg-alt transition-colors"
      >
        Categories
        <svg id="mobile-cat-arrow" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/>
        </svg>
      </button>
      <div id="mobile-categories-list" class="hidden pl-4 space-y-0.5">
        <!-- Credit & Repair -->
        <p class="px-3 pt-2 pb-1 text-[11px] font-semibold uppercase tracking-wider text-muted">Credit & Repair</p>
        {creditRepair.map(cat => (
          <a
            href={`/categories/${cat.slug}/`}
            class="block rounded-lg px-3 py-2.5 text-sm text-muted hover:bg-primary-light hover:text-primary transition-colors"
          >
            {cat.name}
          </a>
        ))}

        <!-- Separator -->
        <div class="mx-3 my-1.5 border-t border-border"></div>

        <!-- Loans & Cash -->
        <p class="px-3 pt-1 pb-1 text-[11px] font-semibold uppercase tracking-wider text-muted">Loans & Cash</p>
        {loansCash.map(cat => (
          <a
            href={`/categories/${cat.slug}/`}
            class="block rounded-lg px-3 py-2.5 text-sm text-muted hover:bg-primary-light hover:text-primary transition-colors"
          >
            {cat.name}
          </a>
        ))}

        <!-- Separator -->
        <div class="mx-3 my-1.5 border-t border-border"></div>

        <!-- Debt & Help -->
        <p class="px-3 pt-1 pb-1 text-[11px] font-semibold uppercase tracking-wider text-muted">Debt & Help</p>
        {debtHelp.map(cat => (
          <a
            href={`/categories/${cat.slug}/`}
            class="block rounded-lg px-3 py-2.5 text-sm text-muted hover:bg-primary-light hover:text-primary transition-colors"
          >
            {cat.name}
          </a>
        ))}
      </div>

      <a href="/deals/" class="block rounded-lg px-3 py-3 text-sm font-medium text-text hover:bg-bg-alt transition-colors">
        Deals
      </a>
      <a href="/state/" class="block rounded-lg px-3 py-3 text-sm font-medium text-text hover:bg-bg-alt transition-colors">
        States
      </a>
      <a href="/tools/" class="block rounded-lg px-3 py-3 text-sm font-medium text-text hover:bg-bg-alt transition-colors">
        Tools
      </a>
      <a href="/blog/" class="block rounded-lg px-3 py-3 text-sm font-medium text-text hover:bg-bg-alt transition-colors">
        Blog
      </a>
      <a href="/financial-wellness/" class="block rounded-lg px-3 py-3 text-sm font-medium text-text hover:bg-bg-alt transition-colors">
        Wellness
      </a>
      <a href="/learn/" class="block rounded-lg px-3 py-3 text-sm font-medium text-text hover:bg-bg-alt transition-colors">
        Learn
      </a>
      <a href="/search/" class="block rounded-lg px-3 py-3 text-sm font-medium text-text hover:bg-bg-alt transition-colors">
        Search
      </a>
      <a href="/about/" class="block rounded-lg px-3 py-3 text-sm font-medium text-text hover:bg-bg-alt transition-colors">
        About
      </a>

    </div>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  const catBtn = document.getElementById('mobile-categories-btn');
  const catList = document.getElementById('mobile-categories-list');
  const catArrow = document.getElementById('mobile-cat-arrow');

  menuBtn?.addEventListener('click', () => {
    const expanded = menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    menuBtn.setAttribute('aria-expanded', expanded === false ? 'true' : 'false');
  });

  catBtn?.addEventListener('click', () => {
    catList?.classList.toggle('hidden');
    catArrow?.classList.toggle('rotate-180');
  });
</script>
