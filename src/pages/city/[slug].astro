---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LenderCard from '../../components/LenderCard.astro';
import { getCitiesWithLenders, getLendersByCityState, getCategories } from '../../utils/data';
import type { CityInfo, Lender } from '../../utils/data';

export function getStaticPaths() {
  const cities = getCitiesWithLenders(5);
  return cities.map(city => ({
    params: { slug: city.slug },
    props: { cityInfo: city },
  }));
}

const { cityInfo } = Astro.props as { cityInfo: CityInfo };
const lenders = getLendersByCityState(cityInfo.city, cityInfo.stateAbbr);
const categories = getCategories();

// Group lenders by category
const categoryGroups = new Map<string, Lender[]>();
for (const l of lenders) {
  const cat = l.category;
  if (!categoryGroups.has(cat)) categoryGroups.set(cat, []);
  categoryGroups.get(cat)!.push(l);
}

// Sort groups by count
const sortedGroups = Array.from(categoryGroups.entries())
  .sort((a, b) => b[1].length - a[1].length);

// Get category display names
const catNames: Record<string, string> = {};
for (const cat of categories) {
  catNames[cat.slug] = cat.name;
}

// Top-rated lenders for featured section
const topLenders = [...lenders].sort((a, b) => b.rating - a.rating).slice(0, 6);

// Map center (use city name for Google Maps embed)
const mapQuery = `${cityInfo.city}, ${cityInfo.stateAbbr}`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `Credit Repair & Financial Services in ${cityInfo.city}, ${cityInfo.state}`,
    "description": `Find ${lenders.length} credit repair companies, personal lenders, and financial services in ${cityInfo.city}, ${cityInfo.stateAbbr}. Compare ratings, pricing, and BBB ratings.`,
    "url": `https://creditdoc.co/city/${cityInfo.slug}/`,
    "about": {
      "@type": "City",
      "name": cityInfo.city,
      "containedInPlace": {
        "@type": "State",
        "name": cityInfo.state,
      }
    }
  },
  ...(topLenders.length > 0 ? [{
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": `Top-Rated Financial Services in ${cityInfo.city}, ${cityInfo.stateAbbr}`,
    "itemListOrder": "https://schema.org/ItemListOrderDescending",
    "numberOfItems": topLenders.length,
    "itemListElement": topLenders.map((l: any, i: number) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": l.name,
      "url": `https://creditdoc.co/review/${l.slug}/`,
    })),
  }] : []),
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://creditdoc.co/" },
      { "@type": "ListItem", "position": 2, "name": "Cities", "item": "https://creditdoc.co/city/" },
      { "@type": "ListItem", "position": 3, "name": `${cityInfo.city}, ${cityInfo.stateAbbr}`, "item": `https://creditdoc.co/city/${cityInfo.slug}/` }
    ]
  }
];
---

<BaseLayout
  title={`Credit Repair & Financial Services in ${cityInfo.city}, ${cityInfo.stateAbbr} (2026) | CreditDoc`}
  description={`Compare ${lenders.length} credit repair companies, personal lenders, and financial services in ${cityInfo.city}, ${cityInfo.state}. Honest reviews, BBB ratings, and pricing.`}
  jsonLd={jsonLd}
>
  <!-- Breadcrumbs -->
  <div class="border-b border-border bg-white">
    <div class="mx-auto max-w-7xl px-4 py-3 sm:px-6 lg:px-8">
      <nav class="flex items-center text-sm text-muted" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" class="mx-2 h-4 w-4 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"/>
        </svg>
        <a href="/city/" class="hover:text-primary transition-colors">Cities</a>
        <svg xmlns="http://www.w3.org/2000/svg" class="mx-2 h-4 w-4 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"/>
        </svg>
        <span class="text-text font-medium">{cityInfo.city}, {cityInfo.stateAbbr}</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-white border-b border-border">
    <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
        <div>
          <span class="inline-block rounded-full bg-primary-light px-4 py-1.5 text-xs font-semibold text-primary uppercase tracking-wider mb-4">
            {cityInfo.city}, {cityInfo.stateAbbr}
          </span>
          <h1 class="text-3xl font-bold text-text sm:text-4xl leading-tight">
            Credit Repair & Financial Services in {cityInfo.city}
          </h1>
          <p class="mt-4 text-lg text-muted leading-relaxed">
            Compare {lenders.length} credit repair companies, personal lenders, and financial services in {cityInfo.city}, {cityInfo.state}. All independently reviewed with BBB ratings and pricing.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            {sortedGroups.slice(0, 4).map(([cat, items]) => (
              <a
                href={`#${cat}`}
                class="inline-flex items-center gap-1.5 rounded-full border border-border px-3.5 py-1.5 text-sm text-text hover:border-primary/30 hover:bg-primary-light/20 transition-colors"
              >
                <span class="font-medium">{catNames[cat] || cat}</span>
                <span class="text-xs text-muted">({items.length})</span>
              </a>
            ))}
          </div>
        </div>
        <div class="rounded-xl overflow-hidden border border-border shadow-sm">
          <iframe
            src={`https://www.google.com/maps?q=${encodeURIComponent(mapQuery + ' credit repair financial services')}&output=embed`}
            width="100%"
            height="280"
            style="border:0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title={`Map of financial services in ${cityInfo.city}`}
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- Top Rated -->
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-text">Top Rated in {cityInfo.city}</h2>
      <span class="text-sm text-muted">{lenders.length} companies</span>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {topLenders.map(lender => (
        <LenderCard lender={lender} />
      ))}
    </div>
  </section>

  <!-- By Category -->
  {sortedGroups.map(([cat, items]) => (
    <section id={cat} class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-bold text-text">
          {catNames[cat] || cat} in {cityInfo.city}
        </h2>
        <a
          href={`/categories/${cat}/`}
          class="text-sm font-medium text-primary hover:text-primary-hover transition-colors"
        >
          View all &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {items.sort((a: any, b: any) => b.rating - a.rating).slice(0, 6).map((lender: any) => (
          <LenderCard lender={lender} />
        ))}
      </div>
      {items.length > 6 && (
        <div class="mt-4 text-center">
          <a
            href={`/search/?city=${encodeURIComponent(cityInfo.city)}`}
            class="text-sm font-medium text-primary hover:text-primary-hover transition-colors"
          >
            View all {items.length} {catNames[cat] || cat} providers in {cityInfo.city} &rarr;
          </a>
        </div>
      )}
    </section>
  ))}

  <!-- Know Your Rights -->
  <section class="bg-white border-t border-b border-border">
    <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">
      <h2 class="text-xl font-bold text-text mb-4">Your Rights in {cityInfo.state}</h2>
      <div class="glass-card p-6 space-y-4 text-sm text-muted leading-relaxed">
        <p>
          <strong class="text-text">Fair Credit Reporting Act (FCRA):</strong> You have the right to dispute inaccurate information on your credit report directly with the credit bureaus, free of charge. Credit repair companies cannot charge you before performing services (Credit Repair Organizations Act).
        </p>
        <p>
          <strong class="text-text">State protections:</strong> {cityInfo.state} may have additional consumer protection laws regarding credit repair services and lending practices. Check with the {cityInfo.state} Attorney General's office or Department of Financial Services for state-specific regulations.
        </p>
        <p>
          <strong class="text-text">Free resources:</strong> You can get a free credit report from each bureau annually at <a href="https://www.annualcreditreport.com" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">AnnualCreditReport.com</a>. HUD-approved housing counselors in {cityInfo.city} offer free financial guidance — search at <a href="https://www.consumerfinance.gov/housing/" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">consumerfinance.gov</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- Other Cities -->
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <h2 class="text-xl font-bold text-text mb-6">Browse Other Cities</h2>
    <div class="flex flex-wrap gap-2">
      {getCitiesWithLenders(30).filter(c => c.slug !== cityInfo.slug).slice(0, 24).map(city => (
        <a
          href={`/city/${city.slug}/`}
          class="inline-flex items-center gap-1 rounded-full border border-border px-3 py-1.5 text-sm text-text hover:border-primary/30 hover:bg-primary-light/20 transition-colors"
        >
          {city.city}, {city.stateAbbr}
          <span class="text-xs text-muted">({city.count})</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Disclaimer -->
  <section class="mx-auto max-w-7xl px-4 pb-12 sm:px-6 lg:px-8">
    <div class="rounded-lg bg-bg-alt border border-border p-4">
      <p class="text-xs text-muted leading-relaxed">
        <strong class="text-text">Affiliate Disclosure:</strong> CreditDoc may earn a commission when you click links to products and services featured on this page. Our editorial team independently reviews all services. <a href="/disclosure/" class="text-primary hover:underline">Learn more</a>.
      </p>
    </div>
  </section>
</BaseLayout>
