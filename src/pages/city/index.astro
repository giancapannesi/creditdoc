---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCitiesWithLenders } from '../../utils/data';

const cities = await getCitiesWithLenders(5);
const totalLenders = cities.reduce((sum, c) => sum + c.count, 0);

// Group by state
const stateGroups = new Map<string, typeof cities>();
for (const city of cities) {
  const state = city.state;
  if (!stateGroups.has(state)) stateGroups.set(state, []);
  stateGroups.get(state)!.push(city);
}
const sortedStates = Array.from(stateGroups.entries()).sort((a, b) => a[0].localeCompare(b[0]));

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Browse Credit Repair & Financial Services by City",
  "description": `Find credit repair companies and financial services in ${cities.length} cities across the United States.`,
  "url": "https://www.creditdoc.co/city/"
};
---

<BaseLayout
  title="Browse by City | Credit Repair & Financial Services Nationwide | CreditDoc"
  description={`Find credit repair companies, personal lenders, and financial services in ${cities.length} cities across the US. Local providers with BBB ratings and honest reviews.`}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-white border-b border-border">
    <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8 text-center">
      <span class="inline-block rounded-full bg-primary-light px-4 py-1.5 text-xs font-semibold text-primary uppercase tracking-wider mb-6">Browse by City</span>
      <h1 class="text-4xl font-bold text-text sm:text-5xl">Find Local Financial Services</h1>
      <p class="mt-6 text-lg text-muted leading-relaxed max-w-2xl mx-auto">
        Browse {totalLenders.toLocaleString()} credit repair companies, personal lenders, and financial services across {cities.length} cities in the United States.
      </p>
    </div>
  </section>

  <!-- Major Cities Grid -->
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-bold text-text mb-6">Major Cities</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {cities.slice(0, 24).map(city => (
        <a
          href={`/city/${city.slug}/`}
          class="glass-card p-5 flex items-center gap-4 hover:shadow-lg transition-shadow group"
        >
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-light text-primary flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="text-base font-semibold text-text group-hover:text-primary transition-colors">
              {city.city}, {city.stateAbbr}
            </h3>
            <p class="text-sm text-muted">{city.count} providers</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-muted group-hover:text-primary transition-colors flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"/>
          </svg>
        </a>
      ))}
    </div>
  </section>

  <!-- By State -->
  <section class="bg-white border-t border-b border-border">
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-text mb-8">Browse by State</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {sortedStates.map(([state, stateCities]) => (
          <div>
            <h3 class="text-base font-semibold text-text mb-3 border-b border-border pb-2">{state}</h3>
            <ul class="space-y-1.5">
              {stateCities.sort((a, b) => b.count - a.count).map(city => (
                <li>
                  <a
                    href={`/city/${city.slug}/`}
                    class="flex items-center justify-between text-sm text-muted hover:text-primary transition-colors py-0.5"
                  >
                    <span>{city.city}</span>
                    <span class="text-xs">{city.count}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
