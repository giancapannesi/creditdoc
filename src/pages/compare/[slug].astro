---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import DiagnosisCard from '../../components/DiagnosisCard.astro';
import RatingStars from '../../components/RatingStars.astro';
import { getComparisons, getLenderBySlug, formatPrice, getBbbClass } from '../../utils/data';
import type { Lender } from '../../utils/data';

export function getStaticPaths() {
  const comparisons = getComparisons();
  return comparisons
    .filter(comp => getLenderBySlug(comp.lender_a) && getLenderBySlug(comp.lender_b))
    .map(comp => ({
      params: { slug: comp.slug },
    }));
}

const { slug } = Astro.params;
const comparisons = getComparisons();
const comparison = comparisons.find(c => c.slug === slug)!;

const lenderA = getLenderBySlug(comparison.lender_a)!;
const lenderB = getLenderBySlug(comparison.lender_b)!;

const winnerLender = comparison.winner === comparison.lender_a ? lenderA : lenderB;

const faqs = [
  {
    question: `Which is cheaper, ${lenderA.name} or ${lenderB.name}?`,
    answer: lenderA.pricing.monthly_price < lenderB.pricing.monthly_price
      ? `${lenderA.name} is cheaper at ${formatPrice(lenderA.pricing.monthly_price)}/mo compared to ${lenderB.name} at ${formatPrice(lenderB.pricing.monthly_price)}/mo. However, ${lenderA.pricing.setup_fee > 0 ? `${lenderA.name} charges a ${formatPrice(lenderA.pricing.setup_fee)} setup fee` : `${lenderA.name} has no setup fee`}, while ${lenderB.pricing.setup_fee > 0 ? `${lenderB.name} charges a ${formatPrice(lenderB.pricing.setup_fee)} setup fee` : `${lenderB.name} has no setup fee`}.`
      : lenderA.pricing.monthly_price > lenderB.pricing.monthly_price
        ? `${lenderB.name} is cheaper at ${formatPrice(lenderB.pricing.monthly_price)}/mo compared to ${lenderA.name} at ${formatPrice(lenderA.pricing.monthly_price)}/mo. However, ${lenderB.pricing.setup_fee > 0 ? `${lenderB.name} charges a ${formatPrice(lenderB.pricing.setup_fee)} setup fee` : `${lenderB.name} has no setup fee`}, while ${lenderA.pricing.setup_fee > 0 ? `${lenderA.name} charges a ${formatPrice(lenderA.pricing.setup_fee)} setup fee` : `${lenderA.name} has no setup fee`}.`
        : `Both ${lenderA.name} and ${lenderB.name} charge the same monthly rate of ${formatPrice(lenderA.pricing.monthly_price)}/mo. The difference comes down to setup fees: ${lenderA.pricing.setup_fee > 0 ? `${lenderA.name} charges ${formatPrice(lenderA.pricing.setup_fee)}` : `${lenderA.name} charges nothing`} vs ${lenderB.pricing.setup_fee > 0 ? `${formatPrice(lenderB.pricing.setup_fee)} for ${lenderB.name}` : `no setup fee for ${lenderB.name}`}.`,
  },
  {
    question: `Which has a better BBB rating, ${lenderA.name} or ${lenderB.name}?`,
    answer: `${lenderA.name} has a ${lenderA.company_info.bbb_rating} BBB rating${lenderA.company_info.bbb_accredited ? ' (accredited)' : ''}, while ${lenderB.name} has a ${lenderB.company_info.bbb_rating} BBB rating${lenderB.company_info.bbb_accredited ? ' (accredited)' : ''}. The BBB rating reflects how well a company responds to customer complaints and conducts business.`,
  },
  {
    question: `Do ${lenderA.name} and ${lenderB.name} offer money-back guarantees?`,
    answer: `${lenderA.pricing.money_back_guarantee ? `${lenderA.name} offers a money-back guarantee: ${lenderA.pricing.guarantee_details}` : `${lenderA.name} does not offer a money-back guarantee.`} ${lenderB.pricing.money_back_guarantee ? `${lenderB.name} offers a money-back guarantee: ${lenderB.pricing.guarantee_details}` : `${lenderB.name} does not offer a money-back guarantee.`}`,
  },
  {
    question: `Which company is better overall, ${lenderA.name} or ${lenderB.name}?`,
    answer: `Based on our analysis, ${winnerLender.name} is the better overall choice. ${comparison.winner_reason}`,
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: comparison.title,
    description: comparison.summary,
    url: `https://creditdoc.co/compare/${comparison.slug}/`,
    author: {
      '@type': 'Person',
      name: 'CreditDoc Editorial Team',
      jobTitle: 'Chief Executive',
      description: 'International consumer finance executive with experience across multiple continents. MBA from a globally ranked university. Over 15 years in payments, lending, and risk management.',
      url: 'https://creditdoc.co/about/',
    },
    publisher: {
      '@type': 'Organization',
      name: 'CreditDoc',
      url: 'https://creditdoc.co',
      logo: { '@type': 'ImageObject', url: 'https://creditdoc.co/favicon.svg' },
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://creditdoc.co/' },
      { '@type': 'ListItem', position: 2, name: 'Comparisons', item: 'https://creditdoc.co/' },
      { '@type': 'ListItem', position: 3, name: comparison.title, item: `https://creditdoc.co/compare/${comparison.slug}/` },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map(faq => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.answer,
      },
    })),
  },
];
---

<BaseLayout
  title={`${comparison.title} | CreditDoc`}
  description={comparison.summary}
  jsonLd={jsonLd}
>
  <!-- Breadcrumbs -->
  <nav class="mx-auto max-w-7xl px-4 pt-6 sm:px-6 lg:px-8" aria-label="Breadcrumb">
    <ol class="flex items-center gap-1.5 text-sm text-muted">
      <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
      <li><span class="mx-1">/</span></li>
      <li class="text-text font-medium">{comparison.title}</li>
    </ol>
  </nav>

  <!-- Two-Column Header -->
  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <h1 class="text-2xl sm:text-3xl font-bold text-text text-center mb-3">{comparison.title}</h1>
    <p class="text-sm text-muted text-center mb-8">
      Written by <a href="/about/" class="text-primary hover:underline font-medium">CreditDoc Editorial Team</a>
      <span class="mx-2 text-border">|</span>
      Reviewed by a consumer finance specialist with 15+ years experience
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {[lenderA, lenderB].map((lender) => {
        const isWinner = comparison.winner === lender.slug;
        const bbbCls = getBbbClass(lender.company_info.bbb_rating);
        return (
          <div class:list={[
            'glass-card p-6 text-center relative',
            isWinner ? 'ring-2 ring-primary' : ''
          ]}>
            {isWinner && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-primary text-white shadow-md">
                Our Pick
              </span>
            )}
            <div class="w-16 h-16 rounded-2xl bg-bg-alt border border-border flex items-center justify-center mx-auto overflow-hidden">
              {lender.logo_url ? (
                <img src={lender.logo_url} alt={`${lender.name} logo`} class="w-12 h-12 object-contain" loading="lazy" />
              ) : (
                <span class="text-xl font-bold text-primary">{lender.name.charAt(0)}</span>
              )}
            </div>
            <h2 class="mt-3 text-lg font-bold text-text">{lender.name}</h2>
            <div class="mt-2 flex items-center justify-center">
              <RatingStars rating={lender.rating} size="sm" showValue={true} />
            </div>
            <div class="mt-3 flex flex-wrap items-center justify-center gap-2">
              <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-primary-light text-primary">
                From {formatPrice(lender.pricing.tiers[0]?.price || lender.pricing.monthly_price)}/mo
              </span>
              <span class:list={['inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold', bbbCls]}>
                BBB: {lender.company_info.bbb_rating}
              </span>
            </div>
            <div class="mt-4 flex gap-2">
              <a
                href={`/review/${lender.slug}/`}
                class="flex-1 text-center px-4 py-2.5 text-sm font-medium rounded-lg border border-border text-text hover:bg-bg-alt transition-colors"
              >
                Full Review
              </a>
              <a
                href={lender.affiliate_url || lender.website_url}
                target="_blank"
                rel="noopener noreferrer nofollow"
                class="flex-1 text-center px-4 py-2.5 text-sm font-medium rounded-lg bg-primary text-white hover:bg-primary-hover transition-colors"
              >
                Visit Site
              </a>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Summary -->
  <section class="mx-auto max-w-7xl px-4 pb-4 sm:px-6 lg:px-8">
    <div class="glass-card p-6">
      <h2 class="text-lg font-bold text-text mb-3">Summary</h2>
      <p class="text-sm text-muted leading-relaxed">{comparison.summary}</p>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="glass-card p-4 sm:p-6">
      <h2 class="text-lg font-bold text-text mb-4">Side-by-Side Comparison</h2>
      <ComparisonTable lenderA={lenderA} lenderB={lenderB} />
    </div>
  </section>

  <!-- Diagnosis -->
  <section class="mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8">
    <h2 class="text-lg font-bold text-text mb-4">Which One Is Right for You?</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <DiagnosisCard
        diagnosis={`Choose ${lenderA.name} if you want: ${lenderA.best_for.slice(0, 2).join('. ')}. Top strength: ${lenderA.pros[0]}.`}
        lenderName={lenderA.name}
      />
      <DiagnosisCard
        diagnosis={`Choose ${lenderB.name} if you want: ${lenderB.best_for.slice(0, 2).join('. ')}. Top strength: ${lenderB.pros[0]}.`}
        lenderName={lenderB.name}
      />
    </div>
    <div class="mt-4">
      <DiagnosisCard
        diagnosis={`Our pick: ${winnerLender.name}. ${comparison.winner_reason}`}
        lenderName={winnerLender.name}
      />
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="glass-card p-6">
      <h2 class="text-xl font-bold text-text mb-4">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqs.map(faq => (
          <details class="group border-b border-border pb-4 last:border-0 last:pb-0">
            <summary class="flex items-center justify-between cursor-pointer text-sm font-semibold text-text hover:text-primary transition-colors py-1">
              {faq.question}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-muted group-open:rotate-180 transition-transform shrink-0 ml-2" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 011.06 0L10 11.94l3.72-3.72a.75.75 0 111.06 1.06l-4.25 4.25a.75.75 0 01-1.06 0L5.22 9.28a.75.75 0 010-1.06z" clip-rule="evenodd"/>
              </svg>
            </summary>
            <p class="mt-2 text-sm text-muted leading-relaxed">{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Affiliate Disclosure -->
  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="rounded-lg bg-bg-alt border border-border p-4">
      <p class="text-xs text-muted leading-relaxed">
        <strong class="text-text">Affiliate Disclosure:</strong> CreditDoc may earn a commission when you click links to the services featured on this page. Our editorial team independently evaluates all services. <a href="/disclosure/" class="text-primary hover:underline">Learn more</a>.
      </p>
    </div>
  </section>
</BaseLayout>
