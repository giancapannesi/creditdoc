---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateInline from '../../components/AffiliateInline.astro';
import AffiliateSidebar from '../../components/AffiliateSidebar.astro';
import { createLinker } from '../../utils/inline-linker';
import {
  getClusterAnswers,
  getClusterAnswerBySlug,
  getSiblingClusterAnswers,
  getGlossaryTermsForContext,
} from '../../utils/data-build';

export function getStaticPaths() {
  const answers = getClusterAnswers();
  return answers.map(a => ({
    params: { slug: a.slug },
  }));
}

const { slug } = Astro.params;
const answer = getClusterAnswerBySlug(slug!)!;
const siblings = getSiblingClusterAnswers(slug!, 4);

// Glossary context feeds the inline linker.
const glossaryTerms = getGlossaryTermsForContext([
  `cluster-${answer.cluster_pillar}`,
  `answer-${answer.cluster_id}`,
  'blog-credit-score',
  'blog-credit-repair',
  'blog-personal-loans',
]);

// Per-page linker: 8 money + 8 glossary caps persist across all sections.
const linker = createLinker(glossaryTerms, { moneyBudget: 8, glossaryBudget: 8 });
const linkedSections = answer.sections.map(section => ({
  heading: section.heading,
  content: linker(section.content).join('\n\n'),
}));

// Derive key takeaways from the first sentence of the first 4 sections (used in TL;DR card).
function firstSentence(md: string): string {
  const plain = md.replace(/[#*_`|]/g, '').replace(/\s+/g, ' ').trim();
  const m = plain.match(/^(.*?[.!?])(\s|$)/);
  return (m ? m[1] : plain.slice(0, 160)).trim();
}
const keyTakeaways = answer.sections.slice(0, 4).map(s => firstSentence(s.content)).filter(Boolean);

// Convert a minimal markdown subset to HTML (tables, headings, lists, bold, italic).
// Matches typography of existing site components (glass-card with dark text).
function mdToHtml(src: string): string {
  const lines = src.split('\n');
  const out: string[] = [];
  let tableRows: string[][] = [];
  let inTable = false;
  let inList = false;

  function inline(s: string): string {
    return s
      .replace(/\*\*([^*]+)\*\*/g, '<strong class="font-semibold text-text">$1</strong>')
      .replace(/(?<!\*)\*([^*]+)\*(?!\*)/g, '<em>$1</em>');
  }

  const flushTable = () => {
    if (!tableRows.length) return;
    const [header, _sep, ...body] = tableRows;
    out.push('<div class="my-6 overflow-x-auto rounded-lg border border-border">');
    out.push('<table class="w-full text-sm">');
    out.push('<thead class="bg-bg-alt"><tr>' + header.map(c => `<th class="px-4 py-2.5 text-left font-semibold text-text">${inline(c)}</th>`).join('') + '</tr></thead>');
    out.push('<tbody>');
    for (const row of body) {
      out.push('<tr class="border-t border-border">' + row.map(c => `<td class="px-4 py-2.5 text-text">${inline(c)}</td>`).join('') + '</tr>');
    }
    out.push('</tbody></table></div>');
    tableRows = [];
    inTable = false;
  };
  const flushList = () => {
    if (inList) { out.push('</ul>'); inList = false; }
  };

  for (const raw of lines) {
    const line = raw.trimEnd();
    if (line.startsWith('|') && line.endsWith('|')) {
      const cells = line.slice(1, -1).split('|').map(c => c.trim());
      tableRows.push(cells);
      inTable = true;
      continue;
    } else if (inTable) {
      flushTable();
    }
    if (line.startsWith('### ')) {
      flushList();
      out.push(`<h4 class="text-lg font-semibold text-text mt-6 mb-2">${inline(line.slice(4))}</h4>`);
    } else if (line.startsWith('## ')) {
      flushList();
      out.push(`<h4 class="text-lg font-semibold text-text mt-6 mb-2">${inline(line.slice(3))}</h4>`);
    } else if (line.startsWith('- ')) {
      if (!inList) { out.push('<ul class="list-disc pl-6 my-3 space-y-1.5 text-text">'); inList = true; }
      out.push(`<li class="leading-relaxed">${inline(line.slice(2))}</li>`);
    } else if (line === '') {
      flushList();
      out.push('');
    } else {
      flushList();
      out.push(`<p class="text-text leading-relaxed my-3">${inline(line)}</p>`);
    }
  }
  flushTable();
  flushList();
  return out.join('\n');
}

const canonicalUrl = `https://www.creditdoc.co/answers/${answer.slug}/`;
const siteName = 'CreditDoc';

// JSON-LD
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: answer.h1,
  description: answer.meta_description,
  author: {
    '@type': 'Person',
    name: 'Harvey Brooks',
    jobTitle: 'Senior Financial Editor',
    url: 'https://www.creditdoc.co/about/',
  },
  publisher: {
    '@type': 'Organization',
    name: siteName,
    url: 'https://www.creditdoc.co',
    logo: { '@type': 'ImageObject', url: 'https://www.creditdoc.co/favicon.svg' },
  },
  datePublished: answer.published_at || answer.last_updated,
  dateModified: answer.last_updated || answer.published_at,
  image: 'https://www.creditdoc.co/og-default.png',
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: (answer.faq_schema || []).map(f => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.creditdoc.co/' },
    { '@type': 'ListItem', position: 2, name: 'Answers', item: 'https://www.creditdoc.co/answers/' },
    { '@type': 'ListItem', position: 3, name: answer.h1, item: canonicalUrl },
  ],
};

const jsonLd = [articleSchema, faqSchema, breadcrumbSchema];
---

<BaseLayout
  title={answer.title}
  description={answer.meta_description}
  canonical={canonicalUrl}
  ogType="article"
  articlePublishedTime={answer.published_at || answer.last_updated}
  articleModifiedTime={answer.last_updated || answer.published_at}
  articleAuthor="Harvey Brooks"
  articleSection={answer.cluster_pillar}
  jsonLd={jsonLd}
>
  <!-- Breadcrumbs -->
  <nav class="mx-auto max-w-7xl px-4 pt-6 sm:px-6 lg:px-8" aria-label="Breadcrumb">
    <ol class="flex items-center gap-1.5 text-sm text-muted">
      <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
      <li><span class="mx-1">/</span></li>
      <li><a href="/answers/" class="hover:text-primary transition-colors">Answers</a></li>
      <li><span class="mx-1">/</span></li>
      <li class="text-text font-medium truncate">{answer.h1}</li>
    </ol>
  </nav>

  <!-- Header -->
  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <h1 class="text-2xl sm:text-3xl font-bold text-text">{answer.h1}</h1>
      <p class="mt-3 text-muted leading-relaxed">{answer.meta_description}</p>
      <p class="mt-3 text-sm text-muted">Written by <a href="/about/" class="text-primary hover:underline font-medium">Harvey Brooks</a>, Senior Financial Editor</p>
    </div>
  </section>

  <!-- TL;DR / Key Takeaways -->
  {keyTakeaways.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 pb-4 sm:px-6 lg:px-8">
      <div class="rounded-xl border-2 border-primary/30 bg-gradient-to-r from-primary/5 to-primary/10 p-6">
        <div class="flex items-center gap-2 mb-3">
          <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-primary text-white uppercase tracking-wide">Key Takeaways</span>
          <span class="text-xs text-muted">Quick answers to the core questions</span>
        </div>
        <ul class="space-y-1.5">
          {keyTakeaways.map((t) => (
            <li class="flex items-start gap-2 text-sm text-muted">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 text-primary shrink-0" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
              </svg>
              <span set:html={t} />
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- Affiliate offer — above the fold, after Key Takeaways -->
  <section class="mx-auto max-w-7xl px-4 pb-4 sm:px-6 lg:px-8">
    <AffiliateInline category={answer.banner_category} />
  </section>

  <!-- Main content (full-width, matching /best/ layout) -->
  <section class="mx-auto max-w-7xl px-4 pb-8 sm:px-6 lg:px-8">
    <div class="space-y-6">
        {linkedSections.map((section, idx) => (
          <article class="glass-card p-6">
            <h2 class="text-xl sm:text-2xl font-bold text-text mb-4">{section.heading}</h2>
            <div set:html={mdToHtml(section.content)} />
            {idx === 4 && <div class="mt-6"><AffiliateSidebar category={answer.banner_category} /></div>}
          </article>
        ))}

        {/* Money CTA */}
        <div class="rounded-xl border-2 border-primary/30 bg-gradient-to-r from-primary/5 to-primary/10 p-6">
          <h2 class="text-xl font-bold text-text mb-2">Ready to take action?</h2>
          <p class="text-muted mb-4">Compare our top-rated options for this topic and find the right fit for your situation.</p>
          <a
            href={answer.target_money_page}
            class="inline-flex items-center px-5 py-2.5 rounded-lg bg-primary text-white text-sm font-semibold hover:bg-primary-hover transition-colors"
          >
            See the full comparison
            <svg xmlns="http://www.w3.org/2000/svg" class="ml-1.5 h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd"/>
            </svg>
          </a>
        </div>

        {/* FAQ */}
        {answer.faq_schema && answer.faq_schema.length > 0 && (
          <section id="faq">
            <h2 class="text-2xl font-bold text-text mb-4">Frequently Asked Questions</h2>
            <div class="space-y-4">
              {answer.faq_schema.map(f => (
                <details class="glass-card p-5 group" open>
                  <summary class="flex items-center justify-between cursor-pointer list-none">
                    <h3 class="text-base font-semibold text-text pr-4">{f.question}</h3>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-muted shrink-0 transition-transform group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 011.06 0L10 11.94l3.72-3.72a.75.75 0 111.06 1.06l-4.25 4.25a.75.75 0 01-1.06 0L5.22 9.28a.75.75 0 010-1.06z" clip-rule="evenodd"/>
                    </svg>
                  </summary>
                  <p class="mt-3 text-sm text-muted leading-relaxed">{f.answer}</p>
                </details>
              ))}
            </div>
          </section>
        )}

        {/* Related answers */}
        {siblings.length > 0 && (
          <section>
            <h2 class="text-2xl font-bold text-text mb-4">Related Answers</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {siblings.map(s => (
                <a href={`/answers/${s.slug}/`} class="glass-card p-4 block hover:border-primary transition-colors">
                  <div class="text-xs text-primary font-semibold uppercase tracking-wide mb-1">{s.cluster_pillar.replace('-', ' ')}</div>
                  <div class="text-text font-semibold leading-snug">{s.h1}</div>
                </a>
              ))}
            </div>
          </section>
        )}

        {/* Sources */}
        {answer.primary_sources && answer.primary_sources.length > 0 && (
          <section class="rounded-lg border border-border bg-bg-alt p-5">
            <h2 class="text-base font-semibold text-text mb-3">Sources</h2>
            <ul class="list-disc pl-6 space-y-1.5 text-sm text-muted">
              {answer.primary_sources.map(src => (
                <li><a href={src.url} rel="nofollow noopener" class="hover:text-primary underline">{src.name}</a></li>
              ))}
            </ul>
          </section>
        )}
      </div>
    </div>
  </section>

  <!-- Author / E-E-A-T -->
  <section class="mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8">
    <div class="rounded-xl border border-border bg-white p-5 flex gap-4">
      <div class="flex-shrink-0">
        <div class="h-12 w-12 rounded-full bg-gradient-to-br from-primary to-primary-hover flex items-center justify-center text-white text-sm font-bold">HB</div>
      </div>
      <div>
        <p class="text-sm font-semibold text-text">Harvey Brooks</p>
        <p class="text-xs text-primary font-medium">Senior Financial Editor</p>
        <p class="mt-2 text-xs text-muted leading-relaxed">
          Harvey Brooks is a consumer finance writer specializing in credit repair, personal lending, and debt management. With over a decade covering the industry, he makes financial literacy accessible to everyday Americans. <a href="/about/" class="text-primary hover:underline">About our editorial team</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- Affiliate Disclosure -->
  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="rounded-lg bg-bg-alt border border-border p-4">
      <p class="text-xs text-muted leading-relaxed">
        <strong class="text-text">Affiliate Disclosure:</strong> CreditDoc may earn a commission when you click links to products and services mentioned on this page. These commissions help us maintain our free research. Our editorial team independently evaluates all services. Compensation does not influence our ratings or rankings. <a href="/disclosure/" class="text-primary hover:underline">Learn more</a>.
      </p>
    </div>
  </section>
</BaseLayout>
