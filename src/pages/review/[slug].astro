          <a
            href={lender.affiliate_url || lender.website_url}
            target="_blank"
            rel="noopener noreferrer nofollow"
            class="mt-5 flex items-center justify-center w-full rounded-lg bg-primary px-4 py-3 text-sm font-semibold text-white hover:bg-primary-hover transition-colors min-h-[44px]"
          >
            Visit {lender.name}
          </a>
          ) : (
          <p class="mt-5 text-center text-sm text-muted">No Website Currently Available</p>
          )}

          {/* Contact & Location */}
          {(lender.phone || lender.address) && (
            <div class="mt-4 pt-4 border-t border-border/50 space-y-2">
              {lender.phone && (
                <a href={`tel:${lender.phone}`} class="flex items-center gap-2 text-sm text-muted hover:text-primary transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M2 3.5A1.5 1.5 0 013.5 2h1.148a1.5 1.5 0 011.465 1.175l.716 3.223a1.5 1.5 0 01-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 006.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 011.767-1.052l3.223.716A1.5 1.5 0 0118 15.352V16.5a1.5 1.5 0 01-1.5 1.5H15c-1.149 0-2.263-.15-3.326-.43A13.022 13.022 0 012.43 8.326 13.019 13.019 0 012 5V3.5z" clip-rule="evenodd"/>
                  </svg>
                  {lender.phone}
                </a>
              )}
              {lender.address && (
                <a
                  href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(lender.address)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-start gap-2 text-sm text-muted hover:text-primary transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                  </svg>
                  <span>{lender.address}</span>
                </a>
              )}
            </div>
          )}

          {/* Embedded Map */}
          {lender.address && (
            <div class="mt-4 rounded-lg overflow-hidden border border-border/50">
              <iframe
                src={`https://www.google.com/maps?q=${encodeURIComponent(lender.address)}&output=embed`}
                width="100%"
                height="180"
                style="border:0"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title={`${lender.name} location map`}
              ></iframe>
            </div>
          )}
        </div>

        <!-- Diagnosis Card -->
        <DiagnosisCard diagnosis={diagnosis} lenderName={lender.name} />

        <!-- CFPB Transparency Report -->
        {lender.cfpb_data?.found_in_cfpb && (
          <div class="glass-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 2a.75.75 0 01.75.75v.258a33.186 33.186 0 016.668.83.75.75 0 01-.336 1.461 31.28 31.28 0 00-1.103-.232l1.702 7.545a.75.75 0 01-.387.832A4.981 4.981 0 0115 14c-.825 0-1.606-.2-2.294-.556a.75.75 0 01-.387-.832l1.77-7.849a31.743 31.743 0 00-3.339-.254v11.505a20.01 20.01 0 013.78.501.75.75 0 11-.339 1.462A18.558 18.558 0 0010 17.5c-1.442 0-2.845.165-4.191.477a.75.75 0 01-.338-1.462 20.01 20.01 0 013.779-.501V4.509c-1.129.026-2.243.112-3.34.254l1.771 7.85a.75.75 0 01-.387.83A4.981 4.981 0 015 14a4.981 4.981 0 01-2.294-.556.75.75 0 01-.387-.832L4.02 5.067c-.37.07-.738.148-1.103.232a.75.75 0 01-.336-1.462 33.053 33.053 0 016.668-.829V2.75A.75.75 0 0110 2zM5 12.662l-1.395-6.178A31.27 31.27 0 005 6.19c.474-.034.95-.058 1.428-.074L5 12.662zm10 0l-1.395-6.546c.478.016.954.04 1.428.074.466.034.93.077 1.395.128L15 12.662z" clip-rule="evenodd"/>
              </svg>
              <h3 class="text-base font-semibold text-text">CFPB Transparency Report</h3>
            </div>
            <p class="text-xs text-muted mb-3">Public data from the Consumer Financial Protection Bureau</p>
            <dl class="space-y-2">
              {lender.cfpb_data.resolution_rate > 0 && (
                <div class="flex items-center justify-between py-1.5">
                  <dt class="text-sm text-muted">Issues Resolved</dt>
                  <dd class:list={[
                    'text-sm font-semibold',
                    lender.cfpb_data.resolution_rate >= 90 ? 'text-positive' :
                    lender.cfpb_data.resolution_rate >= 70 ? 'text-warning' : 'text-negative'
                  ]}>
                    {lender.cfpb_data.resolution_rate}%
                  </dd>
                </div>
              )}
              {lender.cfpb_data.timely_response_rate > 0 && (
                <div class="flex items-center justify-between py-1.5">
                  <dt class="text-sm text-muted">Timely Responses</dt>
                  <dd class:list={[
                    'text-sm font-semibold',
                    lender.cfpb_data.timely_response_rate >= 90 ? 'text-positive' :
                    lender.cfpb_data.timely_response_rate >= 70 ? 'text-warning' : 'text-negative'
                  ]}>
                    {lender.cfpb_data.timely_response_rate}%
                  </dd>
                </div>
              )}
            </dl>
            <p class="mt-3 text-[10px] text-muted/70 leading-relaxed">
              Source: <a href="https://www.consumerfinance.gov/data-research/consumer-complaints/" target="_blank" rel="noopener noreferrer" class="underline hover:text-primary">consumerfinance.gov</a>
              {lender.cfpb_data.last_checked && ` | Last checked ${lender.cfpb_data.last_checked}`}
            </p>
          </div>
        )}

        <!-- Best For -->
        {lender.best_for.length > 0 && (
          <div class="glass-card p-5">
            <h3 class="text-base font-semibold text-text mb-3">Best For</h3>
            <ul class="space-y-2">
              {lender.best_for.map(item => (
                <li class="flex items-start gap-2 text-sm text-muted">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 text-primary shrink-0" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Last Updated -->
        <div class="text-center">
          <TrustBadge type="updated" text={`Updated ${lender.last_updated}`} />
        </div>
      </div>
    </div>
  </section>

  <!-- Compare With Section -->
  {comparisons.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <h2 class="text-xl font-bold text-text mb-4">Compare {lender.name} With Others</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {comparisonsWithOther.map(({ comp, otherSlug, otherLender }) => {
          return (
            <a
              href={`/compare/${comp.slug}/`}
              class="glass-card p-4 flex items-center gap-3 group"
            >
              <div class="w-10 h-10 rounded-lg bg-bg-alt border border-border flex items-center justify-center shrink-0">
                <span class="text-sm font-bold text-primary">vs</span>
              </div>
              <div>
                <p class="text-sm font-semibold text-text group-hover:text-primary transition-colors">
                  {lender.name} vs {otherLender?.name || otherSlug}
                </p>
                <p class="text-xs text-muted mt-0.5">Side-by-side comparison</p>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <!-- Related Lenders -->
  {relatedLenders.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <h2 class="text-xl font-bold text-text mb-4">{relatedLendersLabel}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {relatedLenders.map(related => (
          <LenderCard lender={related} />
        ))}
      </div>
    </section>
  )}

  <!-- Related Financial Wellness Guides -->
  {relatedWellnessGuides.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8">
      <h2 class="text-lg font-bold text-text mb-3">Financial Wellness Guides</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        {relatedWellnessGuides.map(guide => (
          <a href={`/financial-wellness/${guide.slug}/`} class="glass-card p-4 hover:border-primary transition-colors group">
            <h3 class="text-sm font-semibold text-text group-hover:text-primary transition-colors line-clamp-2">{guide.title}</h3>
            <p class="mt-1 text-xs text-muted line-clamp-2">{guide.description}</p>
            <span class="mt-2 inline-block text-xs text-primary font-medium">Read guide &rarr;</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Glossary Appendix -->
  {glossaryTerms.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <GlossaryAppendix terms={glossaryTerms} />
    </section>
  )}

  <!-- Affiliate Disclosure -->
  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="rounded-lg bg-bg-alt border border-border p-4">
      <p class="text-xs text-muted leading-relaxed">
        <strong class="text-text">Affiliate Disclosure:</strong> CreditDoc may earn a commission when you click links to {lender.name} and other services. These commissions help us maintain our free research. Our editorial team independently evaluates all services. Compensation does not influence our ratings or rankings. <a href="/disclosure/" class="text-primary hover:underline">Learn more</a>.
      </p>
    </div>
  </section>
</BaseLayout>
