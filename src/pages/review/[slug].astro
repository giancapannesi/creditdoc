---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import RatingStars from '../../components/RatingStars.astro';
import ProsCons from '../../components/ProsCons.astro';
import DiagnosisCard from '../../components/DiagnosisCard.astro';
import LenderCard from '../../components/LenderCard.astro';
import TrustBadge from '../../components/TrustBadge.astro';
import GlossaryAppendix from '../../components/GlossaryAppendix.astro';
import { linkifyDescription, autoParagraphs } from '../../utils/inline-linker';
import { getAllLenders, getLenderBySlug, formatPrice, getBbbClass, generateDiagnosis, getComparisons, getCategories, getWellnessGuidesByCategory, getGlossaryTermsForContext, getBadgeEligibility, getBrandInfo } from '../../utils/data';
import type { Lender } from '../../utils/data';

const STATE_ABBR: Record<string, string> = {
  'Alabama':'AL','Alaska':'AK','Arizona':'AZ','Arkansas':'AR','California':'CA',
  'Colorado':'CO','Connecticut':'CT','Delaware':'DE','Florida':'FL','Georgia':'GA',
  'Hawaii':'HI','Idaho':'ID','Illinois':'IL','Indiana':'IN','Iowa':'IA',
  'Kansas':'KS','Kentucky':'KY','Louisiana':'LA','Maine':'ME','Maryland':'MD',
  'Massachusetts':'MA','Michigan':'MI','Minnesota':'MN','Mississippi':'MS','Missouri':'MO',
  'Montana':'MT','Nebraska':'NE','Nevada':'NV','New Hampshire':'NH','New Jersey':'NJ',
  'New Mexico':'NM','New York':'NY','North Carolina':'NC','North Dakota':'ND','Ohio':'OH',
  'Oklahoma':'OK','Oregon':'OR','Pennsylvania':'PA','Rhode Island':'RI','South Carolina':'SC',
  'South Dakota':'SD','Tennessee':'TN','Texas':'TX','Utah':'UT','Vermont':'VT',
  'Virginia':'VA','Washington':'WA','West Virginia':'WV','Wisconsin':'WI','Wyoming':'WY',
  'District of Columbia':'DC'
};


const { slug } = Astro.params;
const lender = await getLenderBySlug(slug!);
if (!lender) return new Response('Not found', { status: 404 });

const allLenders = await getAllLenders();
const similarLenders = (await Promise.all(lender.similar_lenders.map(s => getLenderBySlug(s))))
  .filter((l): l is Lender => l !== undefined)
  .slice(0, 3);

const categories = await getCategories();
const category = categories.find(c => c.slug === lender.category);

// Fallback chain: similar → nearby → same category → same state
const usedSlugs = new Set([lender.slug]);

const nearbyLenders = similarLenders.length === 0
  ? allLenders
      .filter(l => !usedSlugs.has(l.slug) && l.company_info?.city === lender.company_info?.city && l.company_info?.state === lender.company_info?.state && l.company_info?.city)
      .sort((a, b) => (b.rating || 0) - (a.rating || 0))
      .slice(0, 3)
  : [];

const categoryLenders = similarLenders.length === 0 && nearbyLenders.length === 0
  ? allLenders
      .filter(l => !usedSlugs.has(l.slug) && l.category === lender.category && l.rating > 0)
      .sort((a, b) => (b.rating || 0) - (a.rating || 0))
      .slice(0, 3)
  : [];

// Last resort: same state, any category
const stateAbbr = lender.company_info?.state ? (STATE_ABBR[lender.company_info.state] || lender.company_info.state) : '';
const stateLenders = similarLenders.length === 0 && nearbyLenders.length === 0 && categoryLenders.length === 0 && stateAbbr
  ? allLenders
      .filter(l => !usedSlugs.has(l.slug) && l.company_info?.state === lender.company_info?.state && l.rating > 0)
      .sort((a, b) => (b.rating || 0) - (a.rating || 0))
      .slice(0, 3)
  : [];

const relatedLenders = similarLenders.length > 0 ? similarLenders : nearbyLenders.length > 0 ? nearbyLenders : categoryLenders.length > 0 ? categoryLenders : stateLenders;
const relatedLendersLabel = similarLenders.length > 0 ? 'Similar Companies' : nearbyLenders.length > 0 ? `More Lenders in ${lender.company_info?.city}` : categoryLenders.length > 0 ? `More ${category?.name || 'Lenders'}` : `More Lenders in ${lender.company_info?.state || 'Your Area'}`;

// Category-mapped wellness guides
const categoryGuideMap: Record<string, string> = {
  'credit-repair': 'credit-repair',
  'debt-relief': 'financial-recovery',
  'personal-loans': 'loans-and-interest',
  'check-cashing': 'everyday-finance',
  'credit-counseling': 'financial-recovery',
  'pawn-lenders': 'everyday-finance',
  'buy-here-pay-here': 'loans-and-interest',
};
const guideCategory = categoryGuideMap[lender.category] || 'understanding-credit';
const relatedWellnessGuides = (await getWellnessGuidesByCategory(guideCategory)).slice(0, 3);

// Map lender category to glossary contexts
const glossaryContextMap: Record<string, string[]> = {
  'credit-repair': ['review-credit-repair'],
  'build-credit': ['review-build-credit'],
  'credit-monitoring': ['review-credit-monitoring'],
  'personal-loans': ['review-personal-loans'],
  'business-loans': ['review-business-loans'],
  'emergency-cash': ['review-emergency-cash'],
  'payday-alternatives': ['review-emergency-cash'],
  'mortgages': ['review-mortgages'],
  'debt-relief': ['review-debt-relief'],
  'bankruptcy': ['review-debt-relief'],
  'credit-counseling': ['review-credit-repair', 'review-debt-relief'],
};
const glossaryContexts = glossaryContextMap[lender.category] || [];
const glossaryTerms = getGlossaryTermsForContext(glossaryContexts);

// Auto-link glossary terms and money keywords in description text.
// If lender has affiliate_url + affiliate_anchors, the first match of each
// anchor phrase becomes a highlighted affiliate CTA (takes priority).
const affiliateConfig = lender.affiliate_url && Array.isArray(lender.affiliate_anchors) && lender.affiliate_anchors.length
  ? { url: lender.affiliate_url, anchors: lender.affiliate_anchors }
  : undefined;

const linkedParagraphs = lender.description_long
  ? linkifyDescription(lender.description_long, glossaryTerms, lender.slug, affiliateConfig, lender.category)
  : [];

const comparisons = (await getComparisons()).filter(
  c => c.lender_a === lender.slug || c.lender_b === lender.slug
);
const comparisonsWithOther = await Promise.all(
  comparisons.map(async comp => {
    const otherSlug = comp.lender_a === lender.slug ? comp.lender_b : comp.lender_a;
    return { comp, otherSlug, otherLender: await getLenderBySlug(otherSlug) };
  })
);

const diagnosis = generateDiagnosis(lender);
const bbbClass = getBbbClass(lender.company_info.bbb_rating);
const lowestPrice = lender.pricing.tiers.length > 0
  ? Math.min(...lender.pricing.tiers.map(t => t.price))
  : lender.pricing.monthly_price;
const hasPricing = lowestPrice > 0 || lender.pricing.tiers.length > 0;
const isFreeService = lender.pricing.monthly_price === 0 && lender.pricing.setup_fee === 0 && lender.pricing.tiers.length === 0 && lender.pricing.free_consultation === true;
const badges = getBadgeEligibility(lender.category);
const bankingCategories = ['banking', 'credit-unions', 'mortgage-lenders', 'auto-loans-new', 'auto-loans-used', 'student-loans'];
const isRatesVaryCategory = bankingCategories.includes(lender.category);
const priceDisplay = hasPricing
  ? `From ${formatPrice(lowestPrice)}/mo`
  : (isFreeService && badges.freeToUse)
    ? 'Free to Use'
    : isRatesVaryCategory
      ? 'Rates vary'
      : null;

// Category-aware feature labels — credit repair features only show on credit repair pages
const creditRepairFeatures: Record<string, string> = {
  credit_monitoring: 'Credit Monitoring',
  all_three_bureaus: 'All Three Bureaus',
  goodwill_letters: 'Goodwill Letters',
  cease_desist_letters: 'Cease & Desist Letters',
  debt_validation: 'Debt Validation',
  credit_education: 'Credit Education',
  identity_theft_protection: 'Identity Theft Protection',
  score_tracking: 'Score Tracking',
  mobile_app: 'Mobile App',
  online_portal: 'Online Portal',
  personal_advisor: 'Personal Advisor',
  ai_powered: 'AI-Powered Tools',
};
const generalFeatures: Record<string, string> = {
  mobile_app: 'Mobile App',
  online_portal: 'Online Portal',
  personal_advisor: 'Personal Advisor',
  credit_education: 'Credit Education',
  score_tracking: 'Score Tracking',
  identity_theft_protection: 'Identity Theft Protection',
};
const featureLabels = category?.filter_type === 'credit-repair' ? creditRepairFeatures : generalFeatures;

const ratingCategories = [
  { label: 'Value', value: lender.rating_breakdown.value },
  { label: 'Effectiveness', value: lender.rating_breakdown.effectiveness },
  { label: 'Customer Service', value: lender.rating_breakdown.customer_service },
  { label: 'Transparency', value: lender.rating_breakdown.transparency },
  { label: 'Ease of Use', value: lender.rating_breakdown.ease_of_use },
];

const hq = lender.company_info?.headquarters?.trim();
const year = lender.company_info?.founded_year;
const bbb = lender.company_info?.bbb_rating?.trim();
const bbbAcc = lender.company_info?.bbb_accredited;

const legitParts = [`Yes. ${lender.name} is a registered company`];
if (hq) legitParts.push(`headquartered in ${hq}`);
if (year) legitParts.push(`founded in ${year}`);
let legitAnswer = legitParts.join(', ') + '.';
if (bbb && bbb !== 'NR' && bbb !== 'N/A' && bbb !== '') {
  legitAnswer += ` They hold a ${bbb} rating with the Better Business Bureau${bbbAcc ? ' and are BBB-accredited' : ''}.`;
}

const faqs = [
  { question: `Is ${lender.name} legitimate?`, answer: legitAnswer },
  ...(hasPricing ? [{
    question: `How much does ${lender.name} cost?`,
    answer: `${lender.name} plans start at ${formatPrice(lowestPrice)} per month${lender.pricing.setup_fee > 0 ? ` with a ${formatPrice(lender.pricing.setup_fee)} setup fee` : lender.pricing.first_work_fee > 0 ? `. There is no setup fee — only a ${formatPrice(lender.pricing.first_work_fee)} work fee charged after the detailed audit analysis` : ' with no setup fee'}. ${lender.pricing.money_back_guarantee ? lender.pricing.guarantee_details : 'No money-back guarantee is offered.'}`,
  }] : []),
  ...(lender.typical_results_timeline?.trim() ? [{
    question: `How long does ${lender.name} take to show results?`,
    answer: lender.typical_results_timeline,
  }] : []),
].filter(faq => faq.answer && faq.answer.trim().length > 0);

// Quality score — persisted by the autonomous engine, fallback to 0
const qualityScore = lender.quality_score ?? 0;
const isPendingApproval = lender.processing_status === 'pending_approval';
const isSkeleton = qualityScore < 3 || isPendingApproval || lender.no_index === true;
const isEnriched = lender.has_been_enriched === true || lender.data_source === 'enriched' || lender.data_source === 'editorial' || lender.data_source === 'verified';

// Website health warnings
const websiteStatus = (lender as any).website_status || '';
const hasWebsiteWarning = ['ssl_expired', 'dead', 'parked', 'hacked', 'redirect_suspicious'].includes(websiteStatus);
const websiteWarnings: Record<string, { label: string; detail: string }> = {
  ssl_expired: { label: 'Insecure Website (SSL Expired)', detail: 'This company\'s website has an expired SSL certificate. The site may be inaccessible or insecure. Exercise caution before sharing personal information.' },
  dead: { label: 'Website Unavailable', detail: 'This company\'s website appears to be offline or no longer operational. The company may have closed or moved to a different address.' },
  parked: { label: 'Website Not Active', detail: 'This company\'s website appears to be parked or for sale. The company may no longer be operating.' },
  hacked: { label: 'Website Compromised', detail: 'This company\'s website appears to have been compromised. Do not visit the site or enter any personal information.' },
  redirect_suspicious: { label: 'Suspicious Website Redirect', detail: 'This company\'s website redirects to an unrelated domain. The original business may no longer operate at this address.' },
};
const warning = websiteWarnings[websiteStatus];

// FinancialService inherits from LocalBusiness in schema.org.
// Google requires an eligible type (LocalBusiness, Product, etc.) for Review snippets.
// Array type includes both for semantic accuracy + rich result eligibility.
const financialService: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': ['FinancialService', 'LocalBusiness'],
  name: lender.name,
  description: lender.description_short,
  url: lender.website_url?.trim() ? lender.website_url : `https://www.creditdoc.co/review/${lender.slug}/`,
};

// Address (always have city/state from data)
if (lender.company_info?.city || lender.company_info?.state) {
  const addr: Record<string, string> = { '@type': 'PostalAddress' };
  if (lender.company_info.address) addr.streetAddress = lender.company_info.address;
  if (lender.company_info.city) addr.addressLocality = lender.company_info.city;
  if (lender.company_info.state) addr.addressRegion = lender.company_info.state;
  if (lender.company_info.zip) addr.postalCode = lender.company_info.zip;
  addr.addressCountry = 'US';
  financialService.address = addr;
}

// Phone
if (lender.company_info?.phone) {
  financialService.telephone = lender.company_info.phone;
}

const clampedRating = Math.min(5, Math.max(1, lender.rating));

// Review — CreditDoc organization-attributed algorithmic score (not a customer review).
// Enables star snippets in Google SERPs. Body references the methodology page so
// the scoring formula is discoverable + Rich Results-policy compliant.
if (lender.rating > 0 && lender.rating <= 5) {
  const diagnosisText = diagnosis?.summary || lender.description_short || '';
  financialService.review = {
    '@type': 'Review',
    author: {
      '@type': 'Organization',
      name: 'CreditDoc',
      url: 'https://www.creditdoc.co/',
    },
    reviewRating: {
      '@type': 'Rating',
      ratingValue: clampedRating.toFixed(1),
      bestRating: '5',
      worstRating: '1',
    },
    reviewBody: diagnosisText.length > 10
      ? `${diagnosisText} CreditDoc Rating derived from our 5-factor methodology — see https://www.creditdoc.co/methodology/ for scoring details.`
      : `CreditDoc Rating derived from our 5-factor methodology. See https://www.creditdoc.co/methodology/ for scoring details.`,
    datePublished: lender.last_reviewed_at || lender.last_updated || new Date().toISOString().slice(0,10),
  };
}

// Price range hint
if (lender.pricing?.monthly_price > 0) {
  financialService.priceRange = `$${lender.pricing.monthly_price}/mo`;
}

// Product schema for credit cards (annual_fee tiers)
const isCardProduct = lender.pricing?.tiers?.some((t: any) => t.price_type === 'annual_fee');
const productImage = lender.logo_url?.trim()
  ? (lender.logo_url.startsWith('http') ? lender.logo_url : `https://www.creditdoc.co${lender.logo_url}`)
  : 'https://www.creditdoc.co/og-default.png';
const cardProductSchema = isCardProduct ? {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: lender.name,
  description: lender.description_short,
  image: productImage,
  brand: {
    '@type': 'Brand',
    name: lender.company_info?.issuing_bank || lender.name,
  },
  category: 'Credit Card',
  ...(lender.rating > 0 && lender.rating <= 5 ? {
    review: {
      '@type': 'Review',
      author: {
        '@type': 'Organization',
        name: 'CreditDoc',
        url: 'https://www.creditdoc.co/',
      },
      reviewRating: {
        '@type': 'Rating',
        ratingValue: Math.min(5, Math.max(1, lender.rating)).toFixed(1),
        bestRating: '5',
        worstRating: '1',
      },
      reviewBody: `CreditDoc Rating derived from our 5-factor methodology. See https://www.creditdoc.co/methodology/ for scoring details.`,
    },
  } : {}),
  offers: lender.pricing.tiers.map((tier: any) => ({
    '@type': 'Offer',
    name: tier.name,
    price: tier.price.toString(),
    priceCurrency: 'USD',
    priceSpecification: {
      '@type': 'UnitPriceSpecification',
      price: tier.price.toString(),
      priceCurrency: 'USD',
      unitText: 'YEAR',
      description: `${tier.name} annual fee`,
    },
    availability: 'https://schema.org/InStock',
    url: lender.affiliate_url || lender.website_url || `https://www.creditdoc.co/review/${lender.slug}/`,
    // Credit cards ship digitally — include explicit policies to satisfy
    // Google's Product rich results validation.
    hasMerchantReturnPolicy: {
      '@type': 'MerchantReturnPolicy',
      applicableCountry: 'US',
      returnPolicyCategory: 'https://schema.org/MerchantReturnNotPermitted',
    },
    shippingDetails: {
      '@type': 'OfferShippingDetails',
      shippingRate: {
        '@type': 'MonetaryAmount',
        value: '0',
        currency: 'USD',
      },
      shippingDestination: {
        '@type': 'DefinedRegion',
        addressCountry: 'US',
      },
      deliveryTime: {
        '@type': 'ShippingDeliveryTime',
        handlingTime: { '@type': 'QuantitativeValue', minValue: 0, maxValue: 1, unitCode: 'DAY' },
        transitTime: { '@type': 'QuantitativeValue', minValue: 5, maxValue: 10, unitCode: 'DAY' },
      },
    },
  })),
} : null;

const jsonLd = [
  financialService,
  ...(cardProductSchema ? [cardProductSchema] : []),
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.creditdoc.co/' },
      { '@type': 'ListItem', position: 2, name: category?.name || lender.category, item: `https://www.creditdoc.co/categories/${lender.category}/` },
      { '@type': 'ListItem', position: 3, name: lender.name, item: `https://www.creditdoc.co/review/${lender.slug}/` },
    ],
  },
  ...(faqs.length > 0 ? [{
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map(faq => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.answer,
      },
    })),
  }] : []),
];

const canonicalUrl = `https://www.creditdoc.co/review/${lender.slug}/`;

// Brand/chain link — only present if lender belongs to an approved chain
const brandInfo = lender.brand_slug ? await getBrandInfo(lender.brand_slug) : null;

// Per-entity OG image: prefer logo, fall through to default in BaseLayout
const ogImageUrl = lender.logo_url?.trim()
  ? (lender.logo_url.startsWith('http') ? lender.logo_url : `https://www.creditdoc.co${lender.logo_url}`)
  : undefined;
---

<BaseLayout
  canonical={canonicalUrl}
  ogImage={ogImageUrl}
  title={(() => {
    if (lender.seo_title) return lender.seo_title;
    const city = lender.company_info?.city;
    const state = lender.company_info?.state;
    const stAbbr = state ? (STATE_ABBR[state] || state.slice(0, 2).toUpperCase()) : '';
    const locSuffix = city ? ` in ${city}${stAbbr ? ', ' + stAbbr : ''}` : '';
    const nameWithLoc = locSuffix ? `${lender.name}${locSuffix}` : lender.name;
    if (nameWithLoc.length <= 45) return `${nameWithLoc} | CreditDoc`;
    if (nameWithLoc.length <= 60) return nameWithLoc;
    return nameWithLoc.slice(0, 60);
  })()}
  description={(() => {
    const base = lender.description_short || `${lender.name} review with pricing, ratings, and features.`;
    const city = lender.company_info?.city;
    if (city && !base.includes(city)) {
      const locNote = ` Located in ${city}${lender.company_info?.state ? ', ' + lender.company_info.state : ''}.`;
      return (base + locNote).slice(0, 155);
    }
    return base.slice(0, 155);
  })()}
  jsonLd={jsonLd}
  noindex={isSkeleton}
>
  <!-- Breadcrumbs -->
  <nav class="mx-auto max-w-7xl px-4 pt-6 sm:px-6 lg:px-8" aria-label="Breadcrumb">
    <ol class="flex items-center gap-1.5 text-sm text-muted">
      <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
      <li><span class="mx-1">/</span></li>
      <li><a href={`/categories/${lender.category}/`} class="hover:text-primary transition-colors">{category?.name || lender.category}</a></li>
      <li><span class="mx-1">/</span></li>
      <li class="text-text font-medium">{lender.name}{(() => {
        const city = lender.company_info?.city;
        const state = lender.company_info?.state;
        const stAbbr = state ? (STATE_ABBR[state] || state.slice(0, 2).toUpperCase()) : '';
        if (!city) return '';
        return ` — ${city}${stAbbr ? ', ' + stAbbr : ''}`;
      })()}</li>
    </ol>
  </nav>

  <!-- Brand/Chain Callout — only for chain locations -->
  {brandInfo && (
    <div class="mx-auto max-w-7xl px-4 pt-3 sm:px-6 lg:px-8">
      <div class="text-sm text-muted">
        Part of the <a href={`/brand/${lender.brand_slug}/`} class="text-primary hover:underline font-medium">{brandInfo.display_name}</a> chain &middot; {brandInfo.location_count} locations
      </div>
    </div>
  )}

  <!-- Website Health Warning Banner -->
  {hasWebsiteWarning && warning && (
    <div class="mx-auto max-w-7xl px-4 pt-4 sm:px-6 lg:px-8">
      <div class="rounded-lg border-2 border-red-500/40 bg-red-500/10 p-4 flex items-start gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-400 shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.168 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
        </svg>
        <div>
          <p class="font-bold text-red-400 text-sm">{warning.label}</p>
          <p class="text-sm text-red-300/80 mt-1">{warning.detail}</p>
        </div>
      </div>
    </div>
  )}

  <!-- Header Section -->
  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="glass-card p-6 sm:p-8">
      <div class="flex flex-col sm:flex-row items-start gap-6">
        <!-- Logo -->
        <div class="w-20 h-20 rounded-2xl bg-bg-alt border border-border flex items-center justify-center shrink-0 overflow-hidden">
          {lender.logo_url && !lender.logo_url.includes('googleusercontent.com') ? (
            <img src={lender.logo_url} alt={`${lender.name} logo`} class="w-14 h-14 object-contain" loading="lazy" onerror={`this.onerror=null;this.parentElement.innerHTML='<span class="text-2xl font-bold text-primary">${lender.name.charAt(0)}</span>'`} />
          ) : lender.website_url ? (
            <img src={`https://icons.duckduckgo.com/ip3/${new URL(lender.website_url).hostname}.ico`} alt={`${lender.name} logo`} class="w-14 h-14 object-contain" loading="lazy" onerror={`this.onerror=function(){this.onerror=null;this.parentElement.innerHTML='<span class=\"text-2xl font-bold text-primary\">${lender.name.charAt(0)}</span>'};this.src='https://icon.horse/icon/${new URL(lender.website_url).hostname}?size=large'`} />
          ) : (
            <span class="text-2xl font-bold text-primary">{lender.name.charAt(0)}</span>
          )}
        </div>

        <div class="flex-1">
          <h1 class="text-2xl sm:text-3xl font-bold text-text">
            {lender.name}{(() => {
              const city = lender.company_info?.city;
              const state = lender.company_info?.state;
              const stAbbr = state ? (STATE_ABBR[state] || state.slice(0, 2).toUpperCase()) : '';
              if (!city) return '';
              return ` in ${city}${stAbbr ? ', ' + stAbbr : ''}`;
            })()}
          </h1>
          <div class="flex items-center gap-3 mt-2">
            <RatingStars rating={lender.rating} size="md" showValue={true} />
          </div>
          <p class="mt-3 text-muted leading-relaxed">{lender.description_short}</p>
          {lender.is_protected ? (
            <p class="mt-2 text-xs text-muted">
              Editorially reviewed by <a href="/about/harvey-brooks/" class="text-primary hover:underline">Harvey Brooks</a>
              · Rating from <a href="/methodology/" class="text-primary hover:underline">CreditDoc methodology</a>
            </p>
          ) : (
            <p class="mt-2 text-xs text-muted">
              Data compiled from public sources
              · Rating from <a href="/methodology/" class="text-primary hover:underline">CreditDoc methodology</a>
            </p>
          )}
        </div>
      </div>

      <!-- Quick Badges -->
