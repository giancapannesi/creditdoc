---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RatingStars from '../../components/RatingStars.astro';
import ProsCons from '../../components/ProsCons.astro';
import DiagnosisCard from '../../components/DiagnosisCard.astro';
import LenderCard from '../../components/LenderCard.astro';
import TrustBadge from '../../components/TrustBadge.astro';
import GlossaryAppendix from '../../components/GlossaryAppendix.astro';
import { getAllLenders, getLenderBySlug, formatPrice, getBbbClass, generateDiagnosis, getComparisons, getCategories, getWellnessGuidesByCategory, getGlossaryTermsForContext } from '../../utils/data';
import type { Lender } from '../../utils/data';

export function getStaticPaths() {
  const lenders = getAllLenders();
  return lenders.map(lender => ({
    params: { slug: lender.slug },
  }));
}

const { slug } = Astro.params;
const lender = getLenderBySlug(slug!)!;

const allLenders = getAllLenders();
const similarLenders = lender.similar_lenders
  .map(s => getLenderBySlug(s))
  .filter((l): l is Lender => l !== undefined)
  .slice(0, 3);

const categories = getCategories();
const category = categories.find(c => c.slug === lender.category);

// Fallback: nearby lenders when similar_lenders is empty
const nearbyLenders = similarLenders.length === 0
  ? allLenders
      .filter(l => l.slug !== lender.slug && l.company_info?.city === lender.company_info?.city && l.company_info?.state === lender.company_info?.state && l.company_info?.city)
      .sort((a, b) => (b.rating || 0) - (a.rating || 0))
      .slice(0, 3)
  : [];

// Same-category lenders when no similar and no nearby
const categoryLenders = similarLenders.length === 0 && nearbyLenders.length === 0
  ? allLenders
      .filter(l => l.slug !== lender.slug && l.category === lender.category && l.rating > 0)
      .sort((a, b) => (b.rating || 0) - (a.rating || 0))
      .slice(0, 3)
  : [];

const relatedLenders = similarLenders.length > 0 ? similarLenders : nearbyLenders.length > 0 ? nearbyLenders : categoryLenders;
const relatedLendersLabel = similarLenders.length > 0 ? 'Similar Companies' : nearbyLenders.length > 0 ? `More Lenders in ${lender.company_info?.city}` : `More ${category?.name || 'Lenders'}`;

// Category-mapped wellness guides
const categoryGuideMap: Record<string, string> = {
  'credit-repair': 'credit-repair',
  'debt-relief': 'financial-recovery',
  'personal-loans': 'loans-and-interest',
  'check-cashing': 'everyday-finance',
  'credit-counseling': 'financial-recovery',
  'pawn-lenders': 'everyday-finance',
  'buy-here-pay-here': 'loans-and-interest',
};
const guideCategory = categoryGuideMap[lender.category] || 'understanding-credit';
const relatedWellnessGuides = getWellnessGuidesByCategory(guideCategory).slice(0, 3);

// Map lender category to glossary contexts
const glossaryContextMap: Record<string, string[]> = {
  'fix-my-credit': ['review-credit-repair'],
  'credit-repair': ['review-credit-repair'],
  'build-credit': ['review-build-credit'],
  'credit-monitoring': ['review-credit-monitoring'],
  'personal-loans': ['review-personal-loans'],
  'business-loans': ['review-business-loans'],
  'emergency-cash': ['review-emergency-cash'],
  'payday-alternatives': ['review-emergency-cash'],
  'mortgages': ['review-mortgages'],
  'debt-relief': ['review-debt-relief'],
  'bankruptcy': ['review-debt-relief'],
  'credit-counseling': ['review-credit-repair', 'review-debt-relief'],
};
const glossaryContexts = glossaryContextMap[lender.category] || [];
const glossaryTerms = getGlossaryTermsForContext(glossaryContexts);

const comparisons = getComparisons().filter(
  c => c.lender_a === lender.slug || c.lender_b === lender.slug
);

const diagnosis = generateDiagnosis(lender);
const bbbClass = getBbbClass(lender.company_info.bbb_rating);
const lowestPrice = lender.pricing.tiers.length > 0
  ? Math.min(...lender.pricing.tiers.map(t => t.price))
  : lender.pricing.monthly_price;
const hasPricing = lowestPrice > 0 || lender.pricing.tiers.length > 0;
const priceDisplay = hasPricing ? `From ${formatPrice(lowestPrice)}/mo` : 'Contact for Pricing';

// Category-aware feature labels — credit repair features only show on credit repair pages
const creditRepairFeatures: Record<string, string> = {
  credit_monitoring: 'Credit Monitoring',
  all_three_bureaus: 'All Three Bureaus',
  goodwill_letters: 'Goodwill Letters',
  cease_desist_letters: 'Cease & Desist Letters',
  debt_validation: 'Debt Validation',
  credit_education: 'Credit Education',
  identity_theft_protection: 'Identity Theft Protection',
  score_tracking: 'Score Tracking',
  mobile_app: 'Mobile App',
  online_portal: 'Online Portal',
  personal_advisor: 'Personal Advisor',
  ai_powered: 'AI-Powered Tools',
};
const generalFeatures: Record<string, string> = {
  mobile_app: 'Mobile App',
  online_portal: 'Online Portal',
  personal_advisor: 'Personal Advisor',
  credit_education: 'Credit Education',
  score_tracking: 'Score Tracking',
  identity_theft_protection: 'Identity Theft Protection',
};
const featureLabels = category?.filter_type === 'credit-repair' ? creditRepairFeatures : generalFeatures;

const ratingCategories = [
  { label: 'Value', value: lender.rating_breakdown.value },
  { label: 'Effectiveness', value: lender.rating_breakdown.effectiveness },
  { label: 'Customer Service', value: lender.rating_breakdown.customer_service },
  { label: 'Transparency', value: lender.rating_breakdown.transparency },
  { label: 'Ease of Use', value: lender.rating_breakdown.ease_of_use },
];

const faqs = [
  {
    question: `Is ${lender.name} legitimate?`,
    answer: `Yes. ${lender.name} is a registered company headquartered in ${lender.company_info.headquarters}${lender.company_info.founded_year ? `, founded in ${lender.company_info.founded_year}` : ''}. They hold a ${lender.company_info.bbb_rating} rating with the Better Business Bureau${lender.company_info.bbb_accredited ? ' and are BBB-accredited' : ''}.`,
  },
  ...(hasPricing ? [{
    question: `How much does ${lender.name} cost?`,
    answer: `${lender.name} plans start at ${formatPrice(lowestPrice)} per month${lender.pricing.setup_fee > 0 ? ` with a ${formatPrice(lender.pricing.setup_fee)} setup fee` : lender.pricing.first_work_fee > 0 ? `. There is no setup fee — only a ${formatPrice(lender.pricing.first_work_fee)} work fee charged after the detailed audit analysis` : ' with no setup fee'}. ${lender.pricing.money_back_guarantee ? lender.pricing.guarantee_details : 'No money-back guarantee is offered.'}`,
  }] : []),
  ...(lender.typical_results_timeline?.trim() ? [{
    question: `How long does ${lender.name} take to show results?`,
    answer: lender.typical_results_timeline,
  }] : []),
].filter(faq => faq.answer && faq.answer.trim().length > 0);

// Quality score — persisted by the autonomous engine, fallback to 0
const qualityScore = lender.quality_score ?? 0;
const isSkeleton = qualityScore < 3;
const isEnriched = lender.has_been_enriched === true || lender.data_source === 'enriched' || lender.data_source === 'editorial' || lender.data_source === 'verified';

// Website health warnings
const websiteStatus = (lender as any).website_status || '';
const hasWebsiteWarning = ['ssl_expired', 'dead', 'parked', 'hacked', 'redirect_suspicious'].includes(websiteStatus);
const websiteWarnings: Record<string, { label: string; detail: string }> = {
  ssl_expired: { label: 'Insecure Website (SSL Expired)', detail: 'This company\'s website has an expired SSL certificate. The site may be inaccessible or insecure. Exercise caution before sharing personal information.' },
  dead: { label: 'Website Unavailable', detail: 'This company\'s website appears to be offline or no longer operational. The company may have closed or moved to a different address.' },
  parked: { label: 'Website Not Active', detail: 'This company\'s website appears to be parked or for sale. The company may no longer be operating.' },
  hacked: { label: 'Website Compromised', detail: 'This company\'s website appears to have been compromised. Do not visit the site or enter any personal information.' },
  redirect_suspicious: { label: 'Suspicious Website Redirect', detail: 'This company\'s website redirects to an unrelated domain. The original business may no longer operate at this address.' },
};
const warning = websiteWarnings[websiteStatus];

// Build FinancialService (LocalBusiness subtype) — proper schema for financial services
const financialService: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': 'FinancialService',
  name: lender.name,
  description: lender.description_short,
  url: lender.website_url?.trim() ? lender.website_url : `https://creditdoc.co/review/${lender.slug}/`,
};

// Address (always have city/state from data)
if (lender.company_info?.city || lender.company_info?.state) {
  const addr: Record<string, string> = { '@type': 'PostalAddress' };
  if (lender.company_info.address) addr.streetAddress = lender.company_info.address;
  if (lender.company_info.city) addr.addressLocality = lender.company_info.city;
  if (lender.company_info.state) addr.addressRegion = lender.company_info.state;
  if (lender.company_info.zip) addr.postalCode = lender.company_info.zip;
  addr.addressCountry = 'US';
  financialService.address = addr;
}

// Phone
if (lender.company_info?.phone) {
  financialService.telephone = lender.company_info.phone;
}

// AggregateRating — must match visible RatingStars component on page.
// When Google reviews exist, use reviewCount. Otherwise use ratingCount (editorial assessment).
// Without this, pages showing stars but no structured rating trigger GSC
// "Review snippets: Invalid object type for field <parent_node>" errors.
if (lender.rating > 0 && lender.rating <= 5) {
  financialService.aggregateRating = {
    '@type': 'AggregateRating',
    ratingValue: lender.rating.toString(),
    bestRating: '5',
    worstRating: '1',
    ...((lender.google_reviews_count || 0) > 0
      ? { reviewCount: lender.google_reviews_count.toString() }
      : { ratingCount: '1' }
    ),
  };
}

// Price range hint
if (lender.pricing?.monthly_price > 0) {
  financialService.priceRange = `$${lender.pricing.monthly_price}/mo`;
}

const jsonLd = [
  financialService,
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://creditdoc.co/' },
      { '@type': 'ListItem', position: 2, name: category?.name || lender.category, item: `https://creditdoc.co/categories/${lender.category}/` },
      { '@type': 'ListItem', position: 3, name: lender.name, item: `https://creditdoc.co/review/${lender.slug}/` },
    ],
  },
  ...(faqs.length > 0 ? [{
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map(faq => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.answer,
      },
    })),
  }] : []),
];
---

<BaseLayout
  title={lender.seo_title || (lender.name.length <= 35 ? `${lender.name} Review (2026) | CreditDoc` : lender.name.length <= 50 ? `${lender.name} Review (2026)` : `${lender.name.slice(0, 53)} Review`)}
  description={lender.description_short}
  jsonLd={jsonLd}
  noindex={isSkeleton}
>
  <!-- Breadcrumbs -->
  <nav class="mx-auto max-w-7xl px-4 pt-6 sm:px-6 lg:px-8" aria-label="Breadcrumb">
    <ol class="flex items-center gap-1.5 text-sm text-muted">
      <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
      <li><span class="mx-1">/</span></li>
      <li><a href={`/categories/${lender.category}/`} class="hover:text-primary transition-colors">{category?.name || lender.category}</a></li>
      <li><span class="mx-1">/</span></li>
      <li class="text-text font-medium">{lender.name}</li>
    </ol>
  </nav>

  <!-- Website Health Warning Banner -->
  {hasWebsiteWarning && warning && (
    <div class="mx-auto max-w-7xl px-4 pt-4 sm:px-6 lg:px-8">
      <div class="rounded-lg border-2 border-red-500/40 bg-red-500/10 p-4 flex items-start gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-400 shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.168 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
        </svg>
        <div>
          <p class="font-bold text-red-400 text-sm">{warning.label}</p>
          <p class="text-sm text-red-300/80 mt-1">{warning.detail}</p>
        </div>
      </div>
    </div>
  )}

  <!-- Header Section -->
  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="glass-card p-6 sm:p-8">
      <div class="flex flex-col sm:flex-row items-start gap-6">
        <!-- Logo -->
        <div class="w-20 h-20 rounded-2xl bg-bg-alt border border-border flex items-center justify-center shrink-0 overflow-hidden">
          {lender.logo_url ? (
            <img src={lender.logo_url} alt={`${lender.name} logo`} class="w-14 h-14 object-contain" />
          ) : (
            <span class="text-2xl font-bold text-primary">{lender.name.charAt(0)}</span>
          )}
        </div>

        <div class="flex-1">
          <h1 class="text-2xl sm:text-3xl font-bold text-text">{lender.name}</h1>
          <div class="flex items-center gap-3 mt-2">
            <RatingStars rating={lender.rating} size="md" showValue={true} />
          </div>
          <p class="mt-3 text-muted leading-relaxed">{lender.description_short}</p>
          {isEnriched && (
            <p class="mt-2 text-xs text-muted">
              Editorially reviewed by <a href="/about/" class="text-primary hover:underline">CreditDoc Editorial Team</a>
            </p>
          )}
        </div>
      </div>

      <!-- Quick Badges -->
      <div class="mt-6 flex flex-wrap items-center gap-3">
        <span class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-semibold bg-primary-light text-primary">
          {priceDisplay}
        </span>
        <span class:list={['inline-flex items-center px-3 py-1.5 rounded-full text-sm font-semibold', bbbClass]}>
          BBB: {lender.company_info.bbb_rating}
        </span>
        {lender.verified_provider && (
          <TrustBadge type="verified-provider" text="Verified Provider" />
        )}
        {lender.pricing.free_consultation && (
          <TrustBadge type="verified" text="Free Consultation" />
        )}
        {lender.pricing.money_back_guarantee && (
          <TrustBadge type="money-back" text="Money-Back Guarantee" />
        )}
        {(lender.affiliate_url || lender.website_url) && (
        <a
          href={lender.affiliate_url || lender.website_url}
          target="_blank"
          rel="noopener noreferrer nofollow"
          class="inline-flex items-center px-5 py-2 rounded-lg bg-primary text-white text-sm font-semibold hover:bg-primary-hover transition-colors ml-auto"
        >
          Visit Website
          <svg xmlns="http://www.w3.org/2000/svg" class="ml-1.5 h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 00-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 00.75-.75v-4a.75.75 0 011.5 0v4A2.25 2.25 0 0112.75 17h-8.5A2.25 2.25 0 012 14.75v-8.5A2.25 2.25 0 014.25 4h5a.75.75 0 010 1.5h-5zm7.5-2.25a.75.75 0 01.75-.75h4a.75.75 0 01.75.75v4a.75.75 0 01-1.5 0V5.56l-5.22 5.22a.75.75 0 11-1.06-1.06l5.22-5.22h-2.19a.75.75 0 01-.75-.75z" clip-rule="evenodd"/>
          </svg>
        </a>
        )}
      </div>
    </div>
  </section>

  <!-- Two-Column Layout -->
  <section class="mx-auto max-w-7xl px-4 pb-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main Content -->
      <div class="lg:col-span-2 space-y-8">
        <!-- Description -->
        <div class="glass-card p-6">
          <h2 class="text-xl font-bold text-text mb-4">{lender.name} Review</h2>
          <div class="prose prose-sm max-w-none text-muted leading-relaxed">
            {lender.description_long.split('\n\n').map(paragraph => (
              <p class="mb-4">{paragraph}</p>
            ))}
          </div>
        </div>

        <!-- Services & Features -->
        <div class="glass-card p-6">
          <h2 class="text-xl font-bold text-text mb-4">Services & Features</h2>

          <!-- Services list -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-6">
            {lender.services.map(service => (
              <div class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 text-positive shrink-0" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
                </svg>
                <span class="text-sm text-text">{service}</span>
              </div>
            ))}
          </div>

          <!-- Feature grid -->
          <h3 class="text-base font-semibold text-text mb-3">Feature Checklist</h3>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            {Object.entries(lender.features).filter(([key]) => key in featureLabels).map(([key, value]) => (
              <div class="flex items-center gap-2">
                {value ? (
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-positive shrink-0" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/>
                  </svg>
                ) : (
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-border shrink-0" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd"/>
                  </svg>
                )}
                <span class:list={['text-xs', value ? 'text-text' : 'text-muted']}>
                  {featureLabels[key]}
                </span>
              </div>
            ))}
          </div>
        </div>

        <!-- Pricing Tiers -->
        {lender.pricing.tiers.length > 0 && (
          <div class="glass-card p-6">
            <h2 class="text-xl font-bold text-text mb-4">Pricing Plans</h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              {lender.pricing.tiers.map((tier, i) => (
                <div class:list={[
                  'rounded-xl border p-5 flex flex-col',
                  i === 1 ? 'border-primary bg-primary-light/20 ring-1 ring-primary/20' : 'border-border bg-white'
                ]}>
                  {i === 1 && (
                    <span class="inline-flex self-start items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-primary text-white mb-2">
                      Most Popular
                    </span>
                  )}
                  <h3 class="text-base font-semibold text-text">{tier.name}</h3>
                  <div class="mt-2">
                    {/\d+-month|flat.rate/i.test(tier.name) ? (
                      <>
                        <span class="text-2xl font-bold text-text">{formatPrice(tier.price)}</span>
                        <span class="text-sm text-muted"> total</span>
                      </>
                    ) : (
                      <>
                        <span class="text-2xl font-bold text-text">{formatPrice(tier.price)}</span>
                        <span class="text-sm text-muted">/mo</span>
                      </>
                    )}
                  </div>
                  {lender.pricing.setup_fee > 0 ? (
                    <p class="text-xs text-muted mt-1">+ {formatPrice(lender.pricing.setup_fee)} setup fee</p>
                  ) : lender.pricing.first_work_fee > 0 ? (
                    <p class="text-xs text-muted mt-1">No setup fee — {formatPrice(lender.pricing.first_work_fee)} work fee after audit only</p>
                  ) : null}
                  <ul class="mt-4 space-y-2 flex-1">
                    {tier.features.map(feature => (
                      <li class="flex items-start gap-2 text-sm text-muted">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 text-positive shrink-0" viewBox="0 0 20 20" fill="currentColor">
                          <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
                        </svg>
                        {feature}
                      </li>
                    ))}
                  </ul>
                  {(lender.affiliate_url || lender.website_url) && (
                  <a
                    href={lender.affiliate_url || lender.website_url}
                    target="_blank"
                    rel="noopener noreferrer nofollow"
                    class:list={[
                      'mt-4 flex items-center justify-center rounded-lg px-4 py-2.5 text-sm font-semibold transition-colors min-h-[44px]',
                      i === 1 ? 'bg-primary text-white hover:bg-primary-hover' : 'border border-border text-text hover:bg-bg-alt'
                    ]}
                  >
                    Get Started
                  </a>
                  )}
                </div>
              ))}
            </div>
            {lender.pricing.money_back_guarantee && lender.pricing.guarantee_name && (
              <div class="mt-6 rounded-xl border-2 border-amber-300 bg-amber-50 p-5">
                <div class="flex items-start gap-3">
                  <div class="shrink-0 mt-0.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-amber-600" viewBox="0 0 24 24" fill="currentColor">
                      <path fill-rule="evenodd" d="M12.516 2.17a.75.75 0 00-1.032 0 11.209 11.209 0 01-7.877 3.08.75.75 0 00-.722.515A12.74 12.74 0 002.25 9.75c0 5.942 4.064 10.932 9.563 12.348a.749.749 0 00.374 0c5.499-1.416 9.563-6.406 9.563-12.348 0-1.39-.223-2.73-.635-3.985a.75.75 0 00-.722-.516l-.143.001c-2.996 0-5.717-1.17-7.734-3.08zm3.094 8.016a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd"/>
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-lg font-bold text-amber-900">{lender.pricing.guarantee_name}</h3>
                    <p class="mt-1 text-sm text-amber-800 leading-relaxed">{lender.pricing.guarantee_details}</p>
                  </div>
                </div>
              </div>
            )}
            {lender.pricing.money_back_guarantee && !lender.pricing.guarantee_name && (
              <p class="mt-4 text-xs text-muted text-center">
                {lender.pricing.guarantee_details}
              </p>
            )}
          </div>
        )}

        <!-- Pros & Cons -->
        <div>
          <h2 class="text-xl font-bold text-text mb-4">Pros & Cons</h2>
          <ProsCons pros={lender.pros} cons={lender.cons} />
        </div>

        <!-- Rating Breakdown -->
        <div class="glass-card p-6">
          <h2 class="text-xl font-bold text-text mb-4">Rating Breakdown</h2>
          <div class="space-y-3">
            {ratingCategories.map(cat => (
              <div class="flex items-center gap-4">
                <span class="text-sm font-medium text-text w-32 shrink-0">{cat.label}</span>
                <div class="flex-1 h-2.5 bg-bg-alt rounded-full overflow-hidden">
                  <div
                    class="h-full bg-primary rounded-full transition-all"
                    style={`width: ${(cat.value / 5) * 100}%`}
                  ></div>
                </div>
                <span class="text-sm font-semibold text-text w-8 text-right">{cat.value.toFixed(1)}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- FAQ -->
        <div class="glass-card p-6">
          <h2 class="text-xl font-bold text-text mb-4">Frequently Asked Questions</h2>
          <div class="space-y-4">
            {faqs.map(faq => (
              <details class="group border-b border-border pb-4 last:border-0 last:pb-0">
                <summary class="flex items-center justify-between cursor-pointer text-sm font-semibold text-text hover:text-primary transition-colors py-1">
                  {faq.question}
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-muted group-open:rotate-180 transition-transform shrink-0 ml-2" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 011.06 0L10 11.94l3.72-3.72a.75.75 0 111.06 1.06l-4.25 4.25a.75.75 0 01-1.06 0L5.22 9.28a.75.75 0 010-1.06z" clip-rule="evenodd"/>
                  </svg>
                </summary>
                <p class="mt-2 text-sm text-muted leading-relaxed">{faq.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Quick Facts -->
        <div class="glass-card p-5">
          <h3 class="text-base font-semibold text-text mb-4">Quick Facts</h3>
          <dl class="space-y-3">
            {lender.company_info.founded_year > 0 && (
              <div class="flex items-center justify-between py-2 border-b border-border/50">
                <dt class="text-sm text-muted">Founded</dt>
                <dd class="text-sm font-medium text-text">{lender.company_info.founded_year}</dd>
              </div>
            )}
            <div class="flex items-center justify-between py-2 border-b border-border/50">
              <dt class="text-sm text-muted">Headquarters</dt>
              <dd class="text-sm font-medium text-text">{lender.company_info.headquarters}</dd>
            </div>
            {lender.company_info.employees && (
              <div class="flex items-center justify-between py-2 border-b border-border/50">
                <dt class="text-sm text-muted">Employees</dt>
                <dd class="text-sm font-medium text-text">{lender.company_info.employees}</dd>
              </div>
            )}
            <div class="flex items-center justify-between py-2 border-b border-border/50">
              <dt class="text-sm text-muted">BBB Rating</dt>
              <dd>
                <span class:list={['inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold', bbbClass]}>
                  {lender.company_info.bbb_rating}
                </span>
              </dd>
            </div>
            <div class="flex items-center justify-between py-2 border-b border-border/50">
              <dt class="text-sm text-muted">BBB Accredited</dt>
              <dd class="text-sm font-medium text-text">{lender.company_info.bbb_accredited ? 'Yes' : 'No'}</dd>
            </div>
            {lender.company_info.certifications && lender.company_info.certifications.length > 0 && (
              <div class="py-2 border-b border-border/50">
                <dt class="text-sm text-muted mb-1">Certifications</dt>
                <dd class="flex flex-wrap gap-1">
                  {lender.company_info.certifications.map(cert => (
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-primary/10 text-primary">
                      {cert}
                    </span>
                  ))}
                </dd>
              </div>
            )}
            <div class="flex items-center justify-between py-2 border-b border-border/50">
              <dt class="text-sm text-muted">Starting Price</dt>
              <dd class="text-sm font-medium text-text">{hasPricing ? `${formatPrice(lowestPrice)}/mo` : 'Contact provider'}</dd>
            </div>
            {lender.pricing.setup_fee > 0 ? (
            <div class="flex items-center justify-between py-2 border-b border-border/50">
              <dt class="text-sm text-muted">Setup Fee</dt>
              <dd class="text-sm font-medium text-text">{formatPrice(lender.pricing.setup_fee)}</dd>
            </div>
            ) : lender.pricing.first_work_fee > 0 ? (
            <div class="flex items-center justify-between py-2 border-b border-border/50">
              <dt class="text-sm text-muted">Fees</dt>
              <dd class="text-sm font-medium text-text">No Setup Fee — {formatPrice(lender.pricing.first_work_fee)} Work Fee only after audit</dd>
            </div>
            ) : (
            <div class="flex items-center justify-between py-2 border-b border-border/50">
              <dt class="text-sm text-muted">Setup Fee</dt>
              <dd class="text-sm font-medium text-text">None</dd>
            </div>
            )}
            <div class="flex items-center justify-between py-2 border-b border-border/50">
              <dt class="text-sm text-muted">Free Consultation</dt>
              <dd class="text-sm font-medium text-text">{lender.pricing.free_consultation ? 'Yes' : 'No'}</dd>
            </div>
            <div class="flex items-center justify-between py-2">
              <dt class="text-sm text-muted">Money-Back Guarantee</dt>
              <dd class="text-sm font-medium text-text">{lender.pricing.money_back_guarantee ? 'Yes' : 'No'}</dd>
            </div>
          </dl>
          {(lender.affiliate_url || lender.website_url) ? (
          <a
            href={lender.affiliate_url || lender.website_url}
            target="_blank"
            rel="noopener noreferrer nofollow"
            class="mt-5 flex items-center justify-center w-full rounded-lg bg-primary px-4 py-3 text-sm font-semibold text-white hover:bg-primary-hover transition-colors min-h-[44px]"
          >
            Visit {lender.name}
          </a>
          ) : (
          <p class="mt-5 text-center text-sm text-muted">No Website Currently Available</p>
          )}

          {/* Contact & Location */}
          {(lender.phone || lender.address) && (
            <div class="mt-4 pt-4 border-t border-border/50 space-y-2">
              {lender.phone && (
                <a href={`tel:${lender.phone}`} class="flex items-center gap-2 text-sm text-muted hover:text-primary transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M2 3.5A1.5 1.5 0 013.5 2h1.148a1.5 1.5 0 011.465 1.175l.716 3.223a1.5 1.5 0 01-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 006.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 011.767-1.052l3.223.716A1.5 1.5 0 0118 15.352V16.5a1.5 1.5 0 01-1.5 1.5H15c-1.149 0-2.263-.15-3.326-.43A13.022 13.022 0 012.43 8.326 13.019 13.019 0 012 5V3.5z" clip-rule="evenodd"/>
                  </svg>
                  {lender.phone}
                </a>
              )}
              {lender.address && (
                <a
                  href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(lender.address)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-start gap-2 text-sm text-muted hover:text-primary transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                  </svg>
                  <span>{lender.address}</span>
                </a>
              )}
            </div>
          )}

          {/* Embedded Map */}
          {lender.address && (
            <div class="mt-4 rounded-lg overflow-hidden border border-border/50">
              <iframe
                src={`https://www.google.com/maps?q=${encodeURIComponent(lender.address)}&output=embed`}
                width="100%"
                height="180"
                style="border:0"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title={`${lender.name} location map`}
              ></iframe>
            </div>
          )}
        </div>

        <!-- Diagnosis Card -->
        <DiagnosisCard diagnosis={diagnosis} lenderName={lender.name} />

        <!-- CFPB Transparency Report -->
        {lender.cfpb_data?.found_in_cfpb && (
          <div class="glass-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 2a.75.75 0 01.75.75v.258a33.186 33.186 0 016.668.83.75.75 0 01-.336 1.461 31.28 31.28 0 00-1.103-.232l1.702 7.545a.75.75 0 01-.387.832A4.981 4.981 0 0115 14c-.825 0-1.606-.2-2.294-.556a.75.75 0 01-.387-.832l1.77-7.849a31.743 31.743 0 00-3.339-.254v11.505a20.01 20.01 0 013.78.501.75.75 0 11-.339 1.462A18.558 18.558 0 0010 17.5c-1.442 0-2.845.165-4.191.477a.75.75 0 01-.338-1.462 20.01 20.01 0 013.779-.501V4.509c-1.129.026-2.243.112-3.34.254l1.771 7.85a.75.75 0 01-.387.83A4.981 4.981 0 015 14a4.981 4.981 0 01-2.294-.556.75.75 0 01-.387-.832L4.02 5.067c-.37.07-.738.148-1.103.232a.75.75 0 01-.336-1.462 33.053 33.053 0 016.668-.829V2.75A.75.75 0 0110 2zM5 12.662l-1.395-6.178A31.27 31.27 0 005 6.19c.474-.034.95-.058 1.428-.074L5 12.662zm10 0l-1.395-6.546c.478.016.954.04 1.428.074.466.034.93.077 1.395.128L15 12.662z" clip-rule="evenodd"/>
              </svg>
              <h3 class="text-base font-semibold text-text">CFPB Transparency Report</h3>
            </div>
            <p class="text-xs text-muted mb-3">Public data from the Consumer Financial Protection Bureau</p>
            <dl class="space-y-2">
              {lender.cfpb_data.resolution_rate > 0 && (
                <div class="flex items-center justify-between py-1.5">
                  <dt class="text-sm text-muted">Issues Resolved</dt>
                  <dd class:list={[
                    'text-sm font-semibold',
                    lender.cfpb_data.resolution_rate >= 90 ? 'text-positive' :
                    lender.cfpb_data.resolution_rate >= 70 ? 'text-warning' : 'text-negative'
                  ]}>
                    {lender.cfpb_data.resolution_rate}%
                  </dd>
                </div>
              )}
              {lender.cfpb_data.timely_response_rate > 0 && (
                <div class="flex items-center justify-between py-1.5">
                  <dt class="text-sm text-muted">Timely Responses</dt>
                  <dd class:list={[
                    'text-sm font-semibold',
                    lender.cfpb_data.timely_response_rate >= 90 ? 'text-positive' :
                    lender.cfpb_data.timely_response_rate >= 70 ? 'text-warning' : 'text-negative'
                  ]}>
                    {lender.cfpb_data.timely_response_rate}%
                  </dd>
                </div>
              )}
            </dl>
            <p class="mt-3 text-[10px] text-muted/70 leading-relaxed">
              Source: <a href="https://www.consumerfinance.gov/data-research/consumer-complaints/" target="_blank" rel="noopener noreferrer" class="underline hover:text-primary">consumerfinance.gov</a>
              {lender.cfpb_data.last_checked && ` | Last checked ${lender.cfpb_data.last_checked}`}
            </p>
          </div>
        )}

        <!-- Best For -->
        {lender.best_for.length > 0 && (
          <div class="glass-card p-5">
            <h3 class="text-base font-semibold text-text mb-3">Best For</h3>
            <ul class="space-y-2">
              {lender.best_for.map(item => (
                <li class="flex items-start gap-2 text-sm text-muted">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 text-primary shrink-0" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Last Updated -->
        <div class="text-center">
          <TrustBadge type="updated" text={`Updated ${lender.last_updated}`} />
        </div>
      </div>
    </div>
  </section>

  <!-- Compare With Section -->
  {comparisons.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <h2 class="text-xl font-bold text-text mb-4">Compare {lender.name} With Others</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {comparisons.map(comp => {
          const otherSlug = comp.lender_a === lender.slug ? comp.lender_b : comp.lender_a;
          const otherLender = getLenderBySlug(otherSlug);
          return (
            <a
              href={`/compare/${comp.slug}/`}
              class="glass-card p-4 flex items-center gap-3 group"
            >
              <div class="w-10 h-10 rounded-lg bg-bg-alt border border-border flex items-center justify-center shrink-0">
                <span class="text-sm font-bold text-primary">vs</span>
              </div>
              <div>
                <p class="text-sm font-semibold text-text group-hover:text-primary transition-colors">
                  {lender.name} vs {otherLender?.name || otherSlug}
                </p>
                <p class="text-xs text-muted mt-0.5">Side-by-side comparison</p>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <!-- Related Lenders -->
  {relatedLenders.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <h2 class="text-xl font-bold text-text mb-4">{relatedLendersLabel}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {relatedLenders.map(related => (
          <LenderCard lender={related} />
        ))}
      </div>
    </section>
  )}

  <!-- Related Financial Wellness Guides -->
  {relatedWellnessGuides.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8">
      <h2 class="text-lg font-bold text-text mb-3">Financial Wellness Guides</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        {relatedWellnessGuides.map(guide => (
          <a href={`/financial-wellness/${guide.slug}/`} class="glass-card p-4 hover:border-primary transition-colors group">
            <h3 class="text-sm font-semibold text-text group-hover:text-primary transition-colors line-clamp-2">{guide.title}</h3>
            <p class="mt-1 text-xs text-muted line-clamp-2">{guide.description}</p>
            <span class="mt-2 inline-block text-xs text-primary font-medium">Read guide &rarr;</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Glossary Appendix -->
  {glossaryTerms.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <GlossaryAppendix terms={glossaryTerms} />
    </section>
  )}

  <!-- Affiliate Disclosure -->
  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="rounded-lg bg-bg-alt border border-border p-4">
      <p class="text-xs text-muted leading-relaxed">
        <strong class="text-text">Affiliate Disclosure:</strong> CreditDoc may earn a commission when you click links to {lender.name} and other services. These commissions help us maintain our free research. Our editorial team independently evaluates all services. Compensation does not influence our ratings or rankings. <a href="/disclosure/" class="text-primary hover:underline">Learn more</a>.
      </p>
    </div>
  </section>
</BaseLayout>
