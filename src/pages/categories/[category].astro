---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import LenderCard from '../../components/LenderCard.astro';
import { getCategories, getLendersByCategory, getWellnessGuidesByCategory } from '../../utils/data';


const { category: categorySlug } = Astro.params;
const categories = await getCategories();
const category = categories.find(c => c.slug === categorySlug)!;
const lenders = await getLendersByCategory(categorySlug!);

const isLoanCategory = category.filter_type === 'loan';
const isServiceCategory = category.filter_type === 'service';

// Map category to wellness guide category
const guideMap: Record<string, string> = {
  'credit-repair': 'credit-repair',
  'debt-relief': 'financial-recovery',
  'personal-loans': 'loans-and-interest',
  'check-cashing': 'everyday-finance',
  'credit-counseling': 'financial-recovery',
  'pawn-lenders': 'everyday-finance',
  'buy-here-pay-here': 'loans-and-interest',
};
const guideCategory = guideMap[categorySlug!] || 'understanding-credit';
const categoryWellnessGuides = (await getWellnessGuidesByCategory(guideCategory)).slice(0, 4);

// Build top lenders list for ItemList schema (up to 10)
const topLenders = [...lenders].sort((a, b) => b.rating - a.rating).slice(0, 10);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: category.name,
    description: category.seo_description,
    url: `https://www.creditdoc.co/categories/${categorySlug}/`,
    numberOfItems: lenders.length,
    provider: {
      '@type': 'Organization',
      name: 'CreditDoc',
      url: 'https://www.creditdoc.co',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.creditdoc.co/' },
      { '@type': 'ListItem', position: 2, name: 'Categories', item: 'https://www.creditdoc.co/' },
      { '@type': 'ListItem', position: 3, name: category.name, item: `https://www.creditdoc.co/categories/${categorySlug}/` },
    ],
  },
  ...(topLenders.length > 0 ? [{
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: `Top ${category.name} Companies`,
    itemListOrder: 'https://schema.org/ItemListOrderDescending',
    numberOfItems: topLenders.length,
    itemListElement: topLenders.map((l, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: l.name,
      url: `https://www.creditdoc.co/review/${l.slug}/`,
    })),
  }] : []),
];
---

<BaseLayout
  title={category.seo_title}
  description={category.seo_description}
  noindex={lenders.length === 0}
  jsonLd={jsonLd}
>
  <!-- Breadcrumbs -->
  <nav class="mx-auto max-w-7xl px-4 pt-6 sm:px-6 lg:px-8" aria-label="Breadcrumb">
    <ol class="flex items-center gap-1.5 text-sm text-muted">
      <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
      <li><span class="mx-1">/</span></li>
      <li><a href="/" class="hover:text-primary transition-colors">Categories</a></li>
      <li><span class="mx-1">/</span></li>
      <li class="text-text font-medium">{category.name}</li>
    </ol>
  </nav>

  <!-- Header -->
  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <h1 class="text-2xl sm:text-3xl font-bold text-text">{category.name}</h1>
      <p class="mt-3 text-muted leading-relaxed">{category.description}</p>
    </div>
  </section>

  <!-- Lender Grid or Empty State -->
  <section class="mx-auto max-w-7xl px-4 pb-16 sm:px-6 lg:px-8">
    {lenders.length > 0 ? (
      <div>
        <p class="text-sm text-muted mb-6">{lenders.length} {lenders.length === 1 ? 'company' : 'companies'} found</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {lenders.sort((a, b) => b.rating - a.rating).slice(0, 48).map(lender => (
            <LenderCard lender={lender} />
          ))}
        </div>
        {lenders.length > 48 && (
          <div class="mt-8 text-center">
            <a
              href={`/search/?category=${categorySlug}`}
              class="inline-flex items-center px-6 py-3 rounded-lg border-2 border-primary text-primary text-sm font-semibold hover:bg-primary-light transition-colors"
            >
              View All {lenders.length} Companies
              <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
              </svg>
            </a>
          </div>
        )}
      </div>
    ) : (
      <div class="glass-card p-12 text-center">
        <div class="mx-auto w-16 h-16 rounded-2xl bg-primary-light flex items-center justify-center mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m5.231 13.481L15 17.25m-4.5-15H5.625c-.621 0-1.125.504-1.125 1.125v16.5c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9zm3.75 11.625a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
          </svg>
        </div>
        <h2 class="text-lg font-semibold text-text">Our team is reviewing {category.name} providers</h2>
        <p class="mt-2 text-sm text-muted max-w-md mx-auto">
          We're researching pricing, features, and customer reviews to bring you unbiased comparisons. In the meantime, explore our reviewed categories.
        </p>
        <div class="mt-6 flex flex-col sm:flex-row items-center justify-center gap-3">
          <a
            href="/categories/credit-repair/"
            class="inline-flex items-center px-5 py-2.5 rounded-lg bg-primary text-white text-sm font-medium hover:bg-primary-hover transition-colors"
          >
            Browse Credit Repair Companies
          </a>
          <a
            href="/search/"
            class="inline-flex items-center px-5 py-2.5 rounded-lg border border-border text-sm font-medium text-text hover:bg-bg-alt transition-colors"
          >
            Search All Services
          </a>
        </div>
      </div>
    )}

    <!-- Related Financial Wellness Guides -->
    {categoryWellnessGuides.length > 0 && (
      <div class="mt-10">
        <h2 class="text-lg font-bold text-text mb-3">Learn Before You Borrow</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
          {categoryWellnessGuides.map(guide => (
            <a href={`/financial-wellness/${guide.slug}/`} class="glass-card p-4 hover:border-primary transition-colors group">
              <span class="inline-block px-2 py-0.5 rounded-full text-[10px] font-semibold bg-primary-light text-primary mb-2">{guide.category_label}</span>
              <h3 class="text-sm font-semibold text-text group-hover:text-primary transition-colors line-clamp-2">{guide.title}</h3>
              <p class="mt-1 text-xs text-muted line-clamp-2">{guide.description}</p>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Loan Disclaimer (loan categories only) -->
    {isLoanCategory && (
      <div class="mt-8 p-4 rounded-lg bg-bg-alt border border-border">
        <p class="text-xs text-muted">
          <strong>Important:</strong> CreditDoc is not a lender, broker, or financial advisor.
          APR ranges shown are from each lender's published rates. Your actual rate depends on
          your creditworthiness, loan amount, and term. We do not collect your personal financial
          information. <a href="/disclaimer/" class="text-primary hover:underline">Full disclaimer</a>.
        </p>
      </div>
    )}
  </section>
</BaseLayout>
