---
import BaseLayout from '../layouts/BaseLayout.astro';
import FilterBar from '../components/FilterBar.astro';
import TopPicksTable from '../components/TopPicksTable.astro';
import CategoryCard from '../components/CategoryCard.astro';
import { getAllLenders, getCategories, getSpecials, getWellnessGuides, formatPrice } from '../utils/data';

const lenders = getAllLenders();
const categories = getCategories();
const specials = getSpecials().slice(0, 3);
const wellnessGuides = getWellnessGuides().slice(0, 3);

// Order categories for the 2x4 grid layout
const categoryOrder = [
  'fix-my-credit',
  'personal-loans',
  'emergency-cash',
  'payday-alternatives',
  'debt-relief',
  'build-credit',
  'credit-monitoring',
  'free-help',
];
const orderedCategories = categoryOrder
  .map(slug => categories.find(c => c.slug === slug))
  .filter((c): c is NonNullable<typeof c> => c !== undefined);

const steps = [
  {
    number: '1',
    title: 'Browse',
    description: 'Explore 200+ credit repair companies with honest reviews, pricing breakdowns, and BBB ratings.',
    icon: '<path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd"/>',
  },
  {
    number: '2',
    title: 'Compare',
    description: 'Use side-by-side comparisons to see how companies stack up on features, pricing, and guarantees.',
    icon: '<path fill-rule="evenodd" d="M2 3.75A.75.75 0 012.75 3h14.5a.75.75 0 010 1.5H2.75A.75.75 0 012 3.75zm0 4.167a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H2.75a.75.75 0 01-.75-.75zm0 4.166a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H2.75a.75.75 0 01-.75-.75zm0 4.167a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H2.75a.75.75 0 01-.75-.75z" clip-rule="evenodd"/>',
  },
  {
    number: '3',
    title: 'Choose',
    description: 'Read our diagnosis for each company to find the one that matches your credit situation and budget.',
    icon: '<path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>',
  },
  {
    number: '4',
    title: 'Apply',
    description: 'Click through to the company website to sign up. Many offer free consultations to get started.',
    icon: '<path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>',
  },
];

const whyCreditDoc = [
  {
    title: 'Independent Reviews',
    description: "We're not a lender, broker, or credit repair company. We compare them.",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>',
  },
  {
    title: 'Real Data',
    description: 'CFPB complaints, BBB ratings, licensing verification, and published APR rates.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605"/>',
  },
  {
    title: 'No Personal Info Required',
    description: 'Browse and compare without entering your Social Security number or income.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>',
  },
  {
    title: 'Consumer Rights First',
    description: 'Every page includes your rights under FCRA, CROA, and state laws.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>',
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'CreditDoc',
    url: 'https://creditdoc.co',
    logo: 'https://creditdoc.co/favicon.svg',
    description: 'Unbiased credit repair company reviews and comparisons. We diagnose the fine print so you don\'t have to.',
    foundingDate: '2025',
    sameAs: [],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'CreditDoc',
    url: 'https://creditdoc.co',
    potentialAction: {
      '@type': 'SearchAction',
      target: {
        '@type': 'EntryPoint',
        urlTemplate: 'https://creditdoc.co/search/?q={search_term_string}',
      },
      'query-input': 'required name=search_term_string',
    },
  },
];
---

<BaseLayout
  title="Compare the Top Credit Repair Companies (2026) | CreditDoc"
  description="Compare 200+ credit repair companies by price, BBB rating, and services. Unbiased reviews, side-by-side comparisons, and expert diagnoses."
  jsonLd={jsonLd}
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-white border-b border-border">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-light/40 via-transparent to-accent/5"></div>
    <div class="relative mx-auto max-w-7xl px-4 py-16 sm:py-20 lg:py-24 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-3xl font-bold tracking-tight text-text sm:text-4xl lg:text-5xl">
          Your Credit. Your Terms.
          <span class="text-primary"> We Just Compare.</span>
        </h1>
        <p class="mt-4 text-lg text-muted sm:text-xl leading-relaxed">
          We've diagnosed the fine print on 200+ credit repair companies, lenders, and financial services. Compare by price, rating, and what actually matters.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
          <a
            href="#top-picks"
            class="inline-flex items-center px-6 py-3 rounded-lg bg-primary text-white font-semibold text-sm hover:bg-primary-hover transition-colors min-h-[44px]"
          >
            See Top Picks
            <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 011.06 0L10 11.94l3.72-3.72a.75.75 0 111.06 1.06l-4.25 4.25a.75.75 0 01-1.06 0L5.22 9.28a.75.75 0 010-1.06z" clip-rule="evenodd"/>
            </svg>
          </a>
          <a
            href="/search/"
            class="inline-flex items-center px-6 py-3 rounded-lg border border-border text-text font-semibold text-sm hover:bg-bg-alt transition-colors min-h-[44px]"
          >
            Search by Location
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Filter Bar -->
  <section class="mx-auto max-w-7xl px-4 -mt-6 relative z-10 sm:px-6 lg:px-8">
    <FilterBar />
  </section>

  <!-- Top Picks Table -->
  <section id="top-picks" class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-text">Top Picks</h2>
      <span class="text-sm text-muted">{lenders.length} companies reviewed</span>
    </div>
    <div class="glass-card p-4 sm:p-6">
      <TopPicksTable lenders={lenders.sort((a, b) => b.rating - a.rating).slice(0, 10)} />
    </div>
  </section>

  <!-- Browse by Category -->
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="text-center mb-8">
      <h2 class="text-2xl font-bold text-text">Browse by Category</h2>
      <p class="mt-2 text-muted">Find the right service for your specific financial need.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {orderedCategories.map(category => (
        <CategoryCard category={category} />
      ))}
    </div>
  </section>

  <!-- Why CreditDoc? -->
  <section class="bg-white border-t border-b border-border">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold text-text">Why CreditDoc?</h2>
        <p class="mt-2 text-muted">What makes us different from the companies we review.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {whyCreditDoc.map(item => (
          <div class="glass-card p-6 flex gap-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-primary-light flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <Fragment set:html={item.icon} />
              </svg>
            </div>
            <div>
              <h3 class="text-base font-semibold text-text">{item.title}</h3>
              <p class="mt-1 text-sm text-muted leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Current Deals -->
  {specials.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-text">Current Deals</h2>
        <a href="/deals/" class="text-sm font-medium text-primary hover:text-primary-hover transition-colors">
          View all deals &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {specials.map(special => (
          <div class="glass-card p-5">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-lg bg-primary-light flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M5.5 3A2.5 2.5 0 003 5.5v2.879a2.5 2.5 0 00.732 1.767l6.5 6.5a2.5 2.5 0 003.536 0l2.878-2.878a2.5 2.5 0 000-3.536l-6.5-6.5A2.5 2.5 0 008.38 3H5.5zM6 7a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-text">{special.lender_name}</h3>
                <p class="text-xs text-primary font-medium">{special.deal_title}</p>
              </div>
            </div>
            <p class="text-sm text-muted leading-relaxed">{special.deal_description}</p>
            {special.promo_code && (
              <div class="mt-3 inline-flex items-center px-3 py-1.5 rounded-lg bg-warning-light border border-warning/20 text-xs font-mono font-semibold text-warning">
                Code: {special.promo_code}
              </div>
            )}
            <a
              href={special.url}
              target="_blank"
              rel="noopener noreferrer nofollow"
              class="mt-4 flex items-center justify-center w-full rounded-lg border border-primary text-primary px-4 py-2.5 text-sm font-medium hover:bg-primary-light transition-colors"
            >
              Get This Deal
            </a>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Financial Wellness Guides -->
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h2 class="text-2xl font-bold text-text">Financial Wellness Guides</h2>
        <p class="mt-1 text-sm text-muted">Free educational guides written by finance professionals.</p>
      </div>
      <a href="/financial-wellness/" class="text-sm font-medium text-primary hover:text-primary-hover transition-colors">
        View all guides &rarr;
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {wellnessGuides.map(guide => (
        <a href={`/financial-wellness/${guide.slug}/`} class="glass-card p-5 hover:shadow-lg transition-shadow group">
          <div class="flex items-center gap-2 mb-2">
            <span class="inline-block rounded-full bg-primary-light px-2.5 py-0.5 text-[11px] font-semibold text-primary uppercase tracking-wider">
              {guide.category.replace(/-/g, ' ')}
            </span>
            <span class="text-xs text-muted">{guide.read_time}</span>
          </div>
          <h3 class="text-sm font-semibold text-text group-hover:text-primary transition-colors leading-snug">{guide.title}</h3>
          <p class="mt-1.5 text-xs text-muted leading-relaxed line-clamp-2">{guide.description}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- How It Works -->
  <section class="bg-white border-t border-b border-border">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold text-text">How It Works</h2>
        <p class="mt-2 text-muted">Four steps to finding the right credit repair company.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {steps.map(step => (
          <div class="text-center">
            <div class="mx-auto w-14 h-14 rounded-2xl bg-primary-light flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" viewBox="0 0 20 20" fill="currentColor">
                <Fragment set:html={step.icon} />
              </svg>
            </div>
            <div class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-primary text-white text-xs font-bold mb-2">
              {step.number}
            </div>
            <h3 class="text-base font-semibold text-text">{step.title}</h3>
            <p class="mt-1 text-sm text-muted leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Borrowing Power Quiz CTA -->
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-2xl bg-gradient-to-r from-primary to-primary-hover p-8 sm:p-10">
      <div class="absolute top-0 right-0 w-40 h-40 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
      <div class="absolute bottom-0 left-0 w-32 h-32 bg-white/5 rounded-full translate-y-1/2 -translate-x-1/2"></div>
      <div class="relative flex flex-col sm:flex-row items-center justify-between gap-6">
        <div class="text-center sm:text-left">
          <h2 class="text-2xl font-bold text-white">Not sure where to start?</h2>
          <p class="mt-2 text-white/80 max-w-lg">Take our 60-second quiz to find out how much you could borrow and get matched with lenders for your situation. Free, private, no credit impact.</p>
        </div>
        <a
          href="/tools/borrowing-power-quiz/"
          class="inline-flex items-center gap-2 bg-white text-primary font-semibold px-6 py-3 rounded-xl hover:bg-white/90 transition-colors flex-shrink-0 shadow-lg"
        >
          Take the Quiz
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Client-side filtering for the homepage table
  const searchInput = document.getElementById('filter-search') as HTMLInputElement | null;
  const categoryFilter = document.getElementById('filter-category') as HTMLSelectElement | null;
  const sortFilter = document.getElementById('filter-sort') as HTMLSelectElement | null;
  const tableBody = document.querySelector('#top-picks-table tbody');

  function filterAndSort() {
    if (!tableBody) return;
    const rows = Array.from(tableBody.querySelectorAll('tr')) as HTMLTableRowElement[];
    const search = searchInput?.value.toLowerCase() || '';
    const category = categoryFilter?.value || '';
    const sort = sortFilter?.value || 'rating';

    rows.forEach(row => {
      const name = row.dataset.name || '';
      const cat = row.dataset.category || '';
      const matchesSearch = !search || name.includes(search);
      const matchesCategory = !category || cat === category;
      row.style.display = matchesSearch && matchesCategory ? '' : 'none';
    });

    const visibleRows = rows.filter(r => r.style.display !== 'none');
    visibleRows.sort((a, b) => {
      if (sort === 'rating') return parseFloat(b.dataset.rating || '0') - parseFloat(a.dataset.rating || '0');
      if (sort === 'price-low') return parseFloat(a.dataset.price || '0') - parseFloat(b.dataset.price || '0');
      if (sort === 'price-high') return parseFloat(b.dataset.price || '0') - parseFloat(a.dataset.price || '0');
      if (sort === 'name') return (a.dataset.name || '').localeCompare(b.dataset.name || '');
      return 0;
    });

    visibleRows.forEach(row => tableBody.appendChild(row));
  }

  searchInput?.addEventListener('input', filterAndSort);
  categoryFilter?.addEventListener('change', filterAndSort);
  sortFilter?.addEventListener('change', filterAndSort);
</script>
