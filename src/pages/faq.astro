---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqs = [
  {
    category: 'About CreditDoc',
    questions: [
      {
        q: 'What is CreditDoc?',
        a: 'CreditDoc is a free comparison and review website that helps consumers find credit repair companies, personal lenders, debt relief services, and other financial products. We research and rate thousands of companies so you can make informed decisions.',
      },
      {
        q: 'Is CreditDoc free to use?',
        a: 'Yes, CreditDoc is completely free for consumers. We earn revenue through affiliate partnerships with some of the companies listed on our site. When you click certain links and sign up, we may receive a referral fee. This never affects our ratings or recommendations.',
      },
      {
        q: 'How does CreditDoc make money?',
        a: 'We earn commissions when visitors click affiliate links on our site and sign up for services. This is clearly disclosed on every page. Our editorial team independently reviews all services, and compensation never influences our ratings. Learn more on our <a href="/disclosure/" class="text-primary hover:underline">Disclosure page</a>.',
      },
      {
        q: 'Who runs CreditDoc?',
        a: 'CreditDoc is a property of Cosmic Phoenix LLC, a Wyoming limited liability company. Our editorial team has over a decade of experience in consumer finance.',
      },
    ],
  },
  {
    category: 'Ratings & Reviews',
    questions: [
      {
        q: 'How do you rate companies?',
        a: 'We use a 5-factor rating system that evaluates reputation and trust, pricing and value, service quality, customer satisfaction, and transparency. Each factor is weighted and combined into an overall score from 1.0 to 5.0. Full details are on our <a href="/methodology/" class="text-primary hover:underline">Methodology page</a>.',
      },
      {
        q: 'Where does your data come from?',
        a: 'We collect data from multiple verified sources including Google Maps reviews, the Better Business Bureau (BBB), the Consumer Financial Protection Bureau (CFPB), the FDIC, NCUA, HUD-approved counseling agencies, and direct company research.',
      },
      {
        q: 'How often are reviews updated?',
        a: 'Pricing and service tiers are verified monthly. Full reviews and ratings are updated quarterly. BBB ratings, CFPB complaints, and regulatory changes are monitored on an ongoing basis.',
      },
      {
        q: 'Can companies pay for a better rating?',
        a: 'No. Our ratings are determined solely by our research methodology. Companies cannot pay to influence their score, ranking, or review content. We frequently recommend companies that have no affiliate relationship with us.',
      },
      {
        q: 'I think a review is inaccurate. How do I report it?',
        a: 'Email us at <a href="mailto:contact@creditdoc.co" class="text-primary hover:underline">contact@creditdoc.co</a> with the subject line "Correction Request." Include the page URL, what you believe is incorrect, and the correct information with a source if possible. We review all requests within 5 business days.',
      },
    ],
  },
  {
    category: 'Credit Repair',
    questions: [
      {
        q: 'What is credit repair?',
        a: 'Credit repair is the process of disputing inaccurate, incomplete, or unverifiable information on your credit reports with the three major credit bureaus (Equifax, Experian, TransUnion). Legitimate credit repair companies help you identify and challenge errors that may be hurting your credit score.',
      },
      {
        q: 'Is credit repair legal?',
        a: 'Yes. Credit repair is legal and protected by federal law. The Credit Repair Organizations Act (CROA) regulates credit repair companies and gives consumers the right to dispute inaccurate information on their credit reports. However, no company can legally guarantee specific results.',
      },
      {
        q: 'How much does credit repair cost?',
        a: 'Credit repair services typically charge a monthly fee ranging from $49 to $149 per month, plus a one-time setup fee of $0 to $199. Some companies offer pay-per-deletion pricing. Under federal law, companies cannot charge you before performing any work.',
      },
      {
        q: 'How long does credit repair take?',
        a: 'Most credit repair processes take 3 to 6 months, though results can vary significantly depending on the number and nature of items being disputed. Some consumers see improvements within the first 30-45 days, while complex cases may take longer.',
      },
      {
        q: 'Can I repair my credit myself?',
        a: 'Yes. Everything a credit repair company does, you can do yourself for free. You can request your credit reports at AnnualCreditReport.com, identify errors, and file disputes directly with the credit bureaus. Credit repair companies offer convenience and expertise, but self-repair is always an option.',
      },
    ],
  },
  {
    category: 'Personal Loans & Debt',
    questions: [
      {
        q: 'What types of lenders does CreditDoc cover?',
        a: 'We cover personal loan providers, credit repair companies, debt relief and settlement services, credit counseling agencies (including HUD-approved), buy-here-pay-here dealers, check cashing services, pawn shops, and other consumer financial services.',
      },
      {
        q: 'What is debt relief?',
        a: 'Debt relief refers to strategies and services that help you reduce or manage overwhelming debt. This includes debt settlement (negotiating to pay less than you owe), debt management plans (consolidating payments at lower interest rates), and debt consolidation loans.',
      },
      {
        q: 'How do I know which service is right for me?',
        a: 'It depends on your situation. If you have errors on your credit report, credit repair may help. If you are struggling with debt payments, debt relief or credit counseling might be appropriate. If you need funds for a specific purpose, a personal loan could work. Our <a href="/categories/fix-my-credit/" class="text-primary hover:underline">category guides</a> can help you determine the best path.',
      },
    ],
  },
  {
    category: 'Privacy & Your Data',
    questions: [
      {
        q: 'Does CreditDoc collect my personal information?',
        a: 'We collect minimal data: standard web analytics (IP address, browser type, pages visited) via Google Analytics, and your email address if you contact us. We do not collect Social Security numbers, financial account numbers, credit scores, or any sensitive financial data.',
      },
      {
        q: 'Does CreditDoc sell my data?',
        a: 'No. CreditDoc does not sell, rent, or trade your personal information to third parties. See our <a href="/do-not-sell/" class="text-primary hover:underline">Do Not Sell page</a> and <a href="/privacy/" class="text-primary hover:underline">Privacy Policy</a> for full details.',
      },
      {
        q: 'What happens when I click an affiliate link?',
        a: 'When you click an affiliate link, you are taken to the third-party company\'s website. That company may collect information about you under their own privacy policy. CreditDoc does not control what third parties do with your data after you leave our site.',
      },
    ],
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.flatMap(cat => cat.questions.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a.replace(/<[^>]*>/g, ''),
    },
  }))),
};
---

<BaseLayout
  title="Frequently Asked Questions | Credit Repair & Financial Services - CreditDoc"
  description="Get answers to common questions about credit repair, personal loans, debt relief, how CreditDoc works, our rating methodology, and your privacy rights."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-white border-b border-border">
    <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8 text-center">
      <span class="inline-block rounded-full bg-primary-light px-4 py-1.5 text-xs font-semibold text-primary uppercase tracking-wider mb-6">Help Center</span>
      <h1 class="text-4xl font-bold text-text sm:text-5xl">Frequently Asked Questions</h1>
      <p class="mt-6 text-lg text-muted leading-relaxed max-w-2xl mx-auto">
        Find answers to common questions about CreditDoc, credit repair, personal loans, debt relief, and how we protect your privacy.
      </p>
    </div>
  </section>

  <!-- FAQ Content -->
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="space-y-12">

      {faqs.map(category => (
        <div>
          <h2 class="text-2xl font-bold text-text mb-6">{category.category}</h2>
          <div class="space-y-4">
            {category.questions.map(faq => (
              <details class="group rounded-xl border border-border bg-white overflow-hidden">
                <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-sm font-semibold text-text hover:bg-bg-alt transition-colors">
                  <span>{faq.q}</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-muted shrink-0 ml-4 transition-transform group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
                  </svg>
                </summary>
                <div class="px-6 pb-4">
                  <p class="text-sm text-muted leading-relaxed" set:html={faq.a} />
                </div>
              </details>
            ))}
          </div>
        </div>
      ))}

      <!-- Still Have Questions -->
      <div class="rounded-xl border border-primary/20 bg-primary-light/20 p-6 text-center">
        <h2 class="text-xl font-bold text-text mb-3">Still Have Questions?</h2>
        <p class="text-sm text-muted leading-relaxed mb-4">
          We're here to help. If you didn't find what you were looking for, reach out to our team.
        </p>
        <a href="mailto:contact@creditdoc.co" class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-2.5 text-sm font-semibold text-white hover:bg-primary-hover transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
            <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
          </svg>
          Contact Us
        </a>
      </div>

      <!-- Last Updated -->
      <div class="text-center">
        <p class="text-xs text-muted">
          Last updated: March 22, 2026 | CreditDoc is a property of Cosmic Phoenix LLC, a Wyoming limited liability company.
        </p>
      </div>

    </div>
  </section>
</BaseLayout>
