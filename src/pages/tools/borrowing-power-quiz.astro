  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const answers = {};
      let currentStep = 0; // 0 = intro

      const introEl = document.getElementById('quiz-intro');
      const questionsEl = document.getElementById('quiz-questions');
      const resultsEl = document.getElementById('quiz-results');
      const startBtn = document.getElementById('start-quiz-btn');
      const backBtn = document.getElementById('back-btn');
      const retakeBtn = document.getElementById('retake-btn');
      const progressBar = document.getElementById('progress-bar');
      const progressPct = document.getElementById('progress-pct');
      const currentQEl = document.getElementById('current-q');
      const steps = document.querySelectorAll('.quiz-step');

      function showStep(n) {
        steps.forEach(s => s.classList.add('hidden'));
        if (n >= 1 && n <= 5) {
          steps[n - 1].classList.remove('hidden');
          const pct = (n / 5) * 100;
          progressBar.style.width = pct + '%';
          progressPct.textContent = Math.round(pct) + '%';
          currentQEl.textContent = n;
          backBtn.classList.toggle('hidden', n <= 1);
        }
        currentStep = n;
      }

      startBtn.addEventListener('click', () => {
        introEl.classList.add('hidden');
        questionsEl.classList.remove('hidden');
        showStep(1);
      });

      backBtn.addEventListener('click', () => {
        if (currentStep > 1) {
          showStep(currentStep - 1);
        }
      });

      retakeBtn.addEventListener('click', () => {
        Object.keys(answers).forEach(k => delete answers[k]);
        resultsEl.classList.add('hidden');
        introEl.classList.remove('hidden');
        questionsEl.classList.add('hidden');
        // Clear selected states
        document.querySelectorAll('.quiz-option').forEach(o => o.classList.remove('selected'));
      });

      // Handle option clicks
      document.querySelectorAll('.quiz-option').forEach(opt => {
        opt.addEventListener('click', () => {
          const step = opt.closest('.quiz-step');
          const stepNum = parseInt(step.dataset.step);
          const value = opt.dataset.value;

          // Mark selected
          step.querySelectorAll('.quiz-option').forEach(o => o.classList.remove('selected'));
          opt.classList.add('selected');

          answers[stepNum] = value;

          // Auto-advance after brief delay
          setTimeout(() => {
            if (stepNum < 5) {
              showStep(stepNum + 1);
            } else {
              showResults();
            }
          }, 300);
        });
      });

      function showResults() {
        questionsEl.classList.add('hidden');
        resultsEl.classList.remove('hidden');

        const result = calculateBorrowingPower(answers);
        renderResults(result);
      }

      function calculateBorrowingPower(a) {
        // Income midpoints
        const incomeMap = { 'under25k': 20000, '25k-50k': 37500, '50k-75k': 62500, '75k-100k': 87500, 'over100k': 125000 };
        // Monthly debt midpoints
        const debtMap = { 'under500': 250, '500-1000': 750, '1000-2000': 1500, '2000-3000': 2500, 'over3000': 4000 };
        // Credit multipliers (affects rate and qualifying amount)
        const creditMult = { 'poor': 0.4, 'fair': 0.65, 'good': 0.85, 'excellent': 1.0, 'unknown': 0.55 };

        const income = incomeMap[a[1]] || 37500;
        const monthlyDebt = debtMap[a[2]] || 750;
        const creditFactor = creditMult[a[3]] || 0.55;
        const monthlyIncome = income / 12;

        // DTI calculation
        const currentDTI = monthlyDebt / monthlyIncome;

        // Max DTI lenders typically allow: 43% for good credit, 36% for fair, 50% for excellent
        const maxDTI = a[3] === 'excellent' ? 0.50 : a[3] === 'good' ? 0.43 : a[3] === 'fair' ? 0.40 : a[3] === 'poor' ? 0.36 : 0.38;

        // Available monthly payment capacity
        const availablePayment = Math.max(0, (maxDTI * monthlyIncome) - monthlyDebt);

        // Estimate borrowing power based on 5-year loan at estimated APR
        const aprMap = { 'poor': 0.28, 'fair': 0.18, 'good': 0.10, 'excellent': 0.065, 'unknown': 0.20 };
        const apr = aprMap[a[3]] || 0.20;
        const monthlyRate = apr / 12;
        const months = 60;

        let maxLoan = 0;
        if (monthlyRate > 0 && availablePayment > 0) {
          maxLoan = availablePayment * ((1 - Math.pow(1 + monthlyRate, -months)) / monthlyRate);
        }

        // Apply credit factor
        maxLoan = maxLoan * creditFactor;

        // Round to nearest $500
        maxLoan = Math.round(maxLoan / 500) * 500;

        // Calculate score 0-100
        let score = 0;
        // Income component (0-30)
        const incomeScore = Math.min(30, (income / 100000) * 30);
        // DTI component (0-30) — lower DTI = higher score
        const dtiScore = Math.max(0, 30 - (currentDTI * 60));
        // Credit component (0-40)
        const creditScore = creditFactor * 40;
        score = Math.round(incomeScore + dtiScore + creditScore);
        score = Math.max(5, Math.min(95, score));

        // Score label
        let label, color, badgeBg;
        if (score >= 75) { label = 'Strong'; color = '#10B981'; badgeBg = 'bg-positive-light text-positive'; }
        else if (score >= 55) { label = 'Moderate'; color = '#0D9488'; badgeBg = 'bg-primary-light text-primary'; }
        else if (score >= 35) { label = 'Building'; color = '#F59E0B'; badgeBg = 'bg-warning-light text-warning'; }
        else { label = 'Limited'; color = '#EF4444'; badgeBg = 'bg-negative-light text-negative'; }

        // Borrowing range
        const lowRange = Math.max(500, Math.round((maxLoan * 0.6) / 500) * 500);
        const highRange = Math.max(1000, Math.round((maxLoan * 1.2) / 500) * 500);

        // Category recommendations based on purpose
        const purposeCategories = {
          'debt-consolidation': ['debt-relief', 'personal-loans', 'credit-repair'],
          'emergency': ['emergency-cash', 'payday-alternatives', 'personal-loans'],
          'major-purchase': ['personal-loans', 'build-credit'],
          'credit-repair': ['credit-repair', 'credit-monitoring', 'free-help'],
          'just-looking': ['credit-monitoring', 'personal-loans', 'credit-repair'],
        };

        // Adjust categories based on credit score
        let categories = purposeCategories[a[4]] || ['personal-loans', 'credit-repair'];
        if (a[3] === 'poor' || a[3] === 'unknown') {
          // Prepend credit repair for poor/unknown credit
          categories = ['credit-repair', ...categories.filter(c => c !== 'credit-repair')];
        }

        // Build insights
        const insights = [];
        if (currentDTI < 0.2) {
          insights.push('Your debt-to-income ratio is excellent. Lenders see you as low risk.');
        } else if (currentDTI < 0.36) {
          insights.push('Your debt-to-income ratio is healthy. Most lenders will consider you.');
        } else if (currentDTI < 0.43) {
          insights.push('Your DTI is on the higher side. Paying down existing debt could unlock better rates.');
        } else {
          insights.push('Your DTI ratio is high. Focus on reducing existing debt before taking on more.');
        }

        if (a[3] === 'poor') {
          insights.push('With a score under 580, credit repair could save you thousands in interest. Even a 50-point improvement opens significantly better options.');
        } else if (a[3] === 'fair') {
          insights.push('A fair credit score gives you options, but rates will be higher. Improving to 670+ could cut your APR substantially.');
        } else if (a[3] === 'good') {
          insights.push('Good credit gives you access to competitive rates. You can shop confidently.');
        } else if (a[3] === 'excellent') {
          insights.push('Excellent credit means you qualify for the best rates. Use that leverage to negotiate.');
        } else {
          insights.push('Not knowing your score is common. Check it for free at AnnualCreditReport.com before applying anywhere.');
        }

        if (a[5] === 'asap') {
          insights.push('For urgent needs, look for same-day or next-day funding options. Pre-qualification checks (soft pulls) let you compare without hurting your score.');
        } else if (a[5] === 'months' || a[5] === 'no-rush') {
          insights.push('With time on your side, shop multiple lenders. Even a 1% APR difference on a $10,000 loan saves $300+ over the life of the loan.');
        }

        // Build actions
        const actions = [];
        if (a[3] === 'poor' || a[3] === 'unknown') {
          actions.push({ text: 'Check your credit report for free', link: '/financial-wellness/how-to-get-free-credit-report/', type: 'primary' });
          actions.push({ text: 'Explore credit repair companies', link: '/categories/credit-repair/', type: 'secondary' });
        }
        if (a[4] === 'debt-consolidation') {
          actions.push({ text: 'Compare debt relief options', link: '/categories/debt-relief/', type: 'primary' });
          actions.push({ text: 'Read: How debt consolidation works', link: '/financial-wellness/debt-consolidation-guide/', type: 'secondary' });
        } else if (a[4] === 'emergency') {
          actions.push({ text: 'Find emergency cash options', link: '/categories/emergency-cash/', type: 'primary' });
          actions.push({ text: 'Check payday alternatives first', link: '/categories/payday-alternatives/', type: 'secondary' });
        } else if (a[4] === 'major-purchase') {
          actions.push({ text: 'Compare personal loan rates', link: '/categories/personal-loans/', type: 'primary' });
        } else if (a[4] === 'credit-repair') {
          actions.push({ text: 'Compare credit repair companies', link: '/categories/credit-repair/', type: 'primary' });
          actions.push({ text: 'Read: DIY credit repair guide', link: '/financial-wellness/diy-credit-repair-step-by-step/', type: 'secondary' });
        }
        if (actions.length < 3) {
          actions.push({ text: 'Browse all categories', link: '/categories/credit-repair/', type: 'secondary' });
        }

        return { score, label, color, badgeBg, lowRange, highRange, maxLoan, currentDTI, apr, insights, actions, categories };
      }

      function renderResults(r) {
        // Badge
        const badge = document.getElementById('result-badge');
        badge.className = `inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-medium ${r.badgeBg}`;
        badge.textContent = r.label + ' Borrowing Power';

        // Meter animation
        const meterFill = document.getElementById('meter-fill');
        const totalArc = 251.2;
        const offset = totalArc - (r.score / 100) * totalArc;
        meterFill.style.stroke = r.color;
        setTimeout(() => { meterFill.style.strokeDashoffset = offset; }, 100);

        // Score counter animation
        const scoreDisplay = document.getElementById('result-score-display');
        let current = 0;
        const interval = setInterval(() => {
          current += Math.ceil(r.score / 30);
          if (current >= r.score) {
            current = r.score;
            clearInterval(interval);
          }
          scoreDisplay.textContent = current;
        }, 40);

        // Label
        document.getElementById('result-label').textContent = r.label + ' Borrowing Power';
        document.getElementById('result-label').style.color = r.color;

        // Range & DTI
        document.getElementById('result-range').textContent = '$' + r.lowRange.toLocaleString() + ' – $' + r.highRange.toLocaleString();
        document.getElementById('result-dti').textContent = Math.round(r.currentDTI * 100) + '%';
        document.getElementById('result-dti').style.color = r.currentDTI < 0.36 ? '#10B981' : r.currentDTI < 0.43 ? '#F59E0B' : '#EF4444';

        // Insights
        const insightsList = document.getElementById('insights-list');
        insightsList.innerHTML = '';
        r.insights.forEach(txt => {
          const li = document.createElement('li');
          li.className = 'flex items-start gap-2';
          li.innerHTML = `<svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg><span>${txt}</span>`;
          insightsList.appendChild(li);
        });

        // Actions
        const actionsList = document.getElementById('actions-list');
        actionsList.innerHTML = '';
        r.actions.forEach(action => {
          const a = document.createElement('a');
          a.href = action.link;
          a.className = action.type === 'primary'
            ? 'flex items-center gap-3 p-3 rounded-xl bg-primary text-white font-medium hover:bg-primary-hover transition-colors'
            : 'flex items-center gap-3 p-3 rounded-xl border border-border text-text font-medium hover:bg-bg-alt transition-colors';
          a.innerHTML = `<svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>${action.text}`;
          actionsList.appendChild(a);
        });

        // Lenders
        const lenderData = window.__LENDER_DATA || {};
        const lendersGrid = document.getElementById('lenders-grid');
        lendersGrid.innerHTML = '';
        const shown = new Set();
        r.categories.forEach(cat => {
          const catLenders = lenderData[cat] || [];
          catLenders.forEach(l => {
            if (shown.has(l.slug) || shown.size >= 6) return;
            shown.add(l.slug);
            const card = document.createElement('a');
            card.href = '/review/' + l.slug + '/';
            card.className = 'glass-card p-4 flex items-center gap-4 hover:bg-card-hover transition-all';
            card.innerHTML = `
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-text truncate">${l.name}</p>
                <p class="text-sm text-muted truncate">${l.description}</p>
              </div>
              <div class="text-right flex-shrink-0">
                <p class="font-bold text-primary">${l.rating.toFixed(1)}</p>
                <p class="text-xs text-muted">${l.free_consultation ? 'Free consult' : l.money_back ? 'Money-back' : 'View details'}</p>
              </div>
              <svg class="w-4 h-4 text-muted flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>`;
            lendersGrid.appendChild(card);
          });
        });

        if (shown.size === 0) {
          lendersGrid.innerHTML = '<p class="text-sm text-muted">We\'re building our lender recommendations. Browse our <a href="/categories/credit-repair/" class="text-primary hover:underline">categories</a> to explore options.</p>';
        }

        // GA4 event
        if (typeof gtag === 'function') {
          gtag('event', 'quiz_completed', {
            event_category: 'engagement',
            event_label: 'borrowing_power',
            quiz_score: r.score,
            quiz_label: r.label,
          });
        }
      }
    });
  </script>

  <style>
    .quiz-option {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem 1.25rem;
      background: var(--color-card-solid);
      border: 2px solid var(--color-border);
      border-radius: 12px;
      text-align: left;
      cursor: pointer;
      transition: all 0.2s ease;
      width: 100%;
    }
    .quiz-option:hover {
      border-color: var(--color-primary);
      background: var(--color-primary-light);
      transform: translateY(-1px);
    }
    .quiz-option.selected {
      border-color: var(--color-primary);
      background: var(--color-primary-light);
      box-shadow: 0 0 0 3px rgba(13, 148, 136, 0.15);
    }
    .quiz-option-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 2.5rem;
      height: 2.5rem;
      border-radius: 10px;
      background: var(--color-bg-alt);
      color: var(--color-primary);
      flex-shrink: 0;
    }
    .quiz-option-text {
      display: flex;
      flex-direction: column;
      gap: 0.125rem;
    }
  </style>
</BaseLayout>
