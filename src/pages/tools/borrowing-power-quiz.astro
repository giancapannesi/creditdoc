---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllLenders, getCategories } from '../../utils/data';

const categories = getCategories();
const allLenders = getAllLenders();

// Build recommendation data: top lenders per category (only enriched/quality ones)
const categoryRecommendations: Record<string, { name: string; slug: string; rating: number; category: string; description: string; website_url: string; free_consultation: boolean; money_back: boolean }[]> = {};

for (const cat of categories) {
  const catLenders = allLenders
    .filter(l => l.category === cat.slug && l.rating > 0 && l.description_short && l.description_short.length > 30)
    .sort((a, b) => b.rating - a.rating)
    .slice(0, 8)
    .map(l => ({
      name: l.name,
      slug: l.slug,
      rating: l.rating,
      category: l.category,
      description: l.description_short?.substring(0, 120) || '',
      website_url: l.website_url || '',
      free_consultation: l.pricing?.free_consultation || false,
      money_back: l.pricing?.money_back_guarantee || false,
    }));
  if (catLenders.length > 0) {
    categoryRecommendations[cat.slug] = catLenders;
  }
}

const title = "What's My Borrowing Power? — Free Quiz | CreditDoc";
const description = "Find out how much you could borrow in 60 seconds. Answer 5 quick questions about your income, debt, and credit to get personalized lender recommendations.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Borrowing Power Quiz",
  "description": description,
  "url": "https://creditdoc.co/tools/borrowing-power-quiz/",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Web",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "author": {
    "@type": "Person",
    "name": "CreditDoc Editorial Team",
    "jobTitle": "Chief Executive",
    "description": "International consumer finance executive with 15+ years of experience across multiple continents. MBA from a globally ranked university."
  },
  "publisher": {
    "@type": "Organization",
    "name": "CreditDoc",
    "url": "https://creditdoc.co"
  }
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How is my borrowing power calculated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your borrowing power estimate is based on your income, existing debt obligations, credit score range, and loan purpose. We use standard debt-to-income ratios used by lenders to estimate how much you could qualify for. This is an educational estimate, not a pre-approval."
      }
    },
    {
      "@type": "Question",
      "name": "Is the Borrowing Power Quiz free?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, the quiz is completely free and requires no personal information beyond the 5 multiple-choice questions. We never ask for your Social Security number, and the quiz does not affect your credit score."
      }
    },
    {
      "@type": "Question",
      "name": "Does this quiz affect my credit score?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. This quiz is purely educational and does not perform any credit checks. No information is sent to credit bureaus. Your credit score is not affected in any way."
      }
    }
  ]
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://creditdoc.co/" },
    { "@type": "ListItem", "position": 2, "name": "Tools", "item": "https://creditdoc.co/tools/" },
    { "@type": "ListItem", "position": 3, "name": "Borrowing Power Quiz", "item": "https://creditdoc.co/tools/borrowing-power-quiz/" }
  ]
};

const combinedJsonLd = [jsonLd, faqJsonLd, breadcrumbJsonLd];
---

<BaseLayout title={title} description={description} jsonLd={combinedJsonLd}>
  <!-- Breadcrumbs -->
  <nav class="max-w-3xl mx-auto px-4 pt-6 pb-2" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2 text-sm text-muted">
      <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
      <li class="text-border">/</li>
      <li><a href="/tools/" class="hover:text-primary transition-colors">Tools</a></li>
      <li class="text-border">/</li>
      <li class="text-text font-medium">Borrowing Power Quiz</li>
    </ol>
  </nav>

  <div class="max-w-3xl mx-auto px-4 py-8">
    <!-- Quiz Container -->
    <div id="quiz-container">
      <!-- Intro Screen -->
      <div id="quiz-intro" class="text-center">
        <div class="inline-flex items-center gap-2 bg-primary-light text-primary px-4 py-1.5 rounded-full text-sm font-medium mb-6">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>
          Free &middot; 60 Seconds &middot; No Credit Check
        </div>

        <h1 class="text-3xl md:text-4xl font-bold text-text mb-4">What's My Borrowing Power?</h1>
        <p class="text-lg text-muted mb-8 max-w-xl mx-auto">Answer 5 quick questions to get a personalized estimate of how much you could borrow — plus lender recommendations matched to your situation.</p>

        <div class="grid grid-cols-3 gap-4 max-w-md mx-auto mb-8">
          <div class="text-center">
            <div class="w-10 h-10 mx-auto mb-2 rounded-full bg-primary-light flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>
            </div>
            <p class="text-xs text-muted">100% Private</p>
          </div>
          <div class="text-center">
            <div class="w-10 h-10 mx-auto mb-2 rounded-full bg-primary-light flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <p class="text-xs text-muted">60 Seconds</p>
          </div>
          <div class="text-center">
            <div class="w-10 h-10 mx-auto mb-2 rounded-full bg-primary-light flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <p class="text-xs text-muted">No Credit Impact</p>
          </div>
        </div>

        <button id="start-quiz-btn" class="inline-flex items-center gap-2 bg-primary hover:bg-primary-hover text-white font-semibold px-8 py-3.5 rounded-xl transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5">
          Find My Borrowing Power
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </button>
      </div>

      <!-- Quiz Questions -->
      <div id="quiz-questions" class="hidden">
        <!-- Progress Bar -->
        <div class="mb-8">
          <div class="flex justify-between items-center mb-2">
            <span class="text-sm font-medium text-muted">Question <span id="current-q">1</span> of 5</span>
            <span id="progress-pct" class="text-sm font-medium text-primary">20%</span>
          </div>
          <div class="w-full bg-bg-alt rounded-full h-2.5">
            <div id="progress-bar" class="bg-primary h-2.5 rounded-full transition-all duration-500 ease-out" style="width: 20%"></div>
          </div>
        </div>

        <!-- Question 1: Income -->
        <div class="quiz-step" data-step="1">
          <h2 class="text-2xl font-bold text-text mb-2">What's your annual household income?</h2>
          <p class="text-muted mb-6">Before taxes. Include all regular income sources.</p>
          <div class="grid gap-3" id="q1-options">
            <button class="quiz-option" data-value="under25k">
              <span class="quiz-option-icon">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </span>
              <span class="quiz-option-text">
                <span class="font-semibold">Under $25,000</span>
              </span>
            </button>
            <button class="quiz-option" data-value="25k-50k">
              <span class="quiz-option-icon">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </span>
              <span class="quiz-option-text">
                <span class="font-semibold">$25,000 &ndash; $50,000</span>
              </span>
            </button>
            <button class="quiz-option" data-value="50k-75k">
              <span class="quiz-option-icon">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </span>
              <span class="quiz-option-text">
                <span class="font-semibold">$50,000 &ndash; $75,000</span>
              </span>
            </button>
            <button class="quiz-option" data-value="75k-100k">
              <span class="quiz-option-icon">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </span>
              <span class="quiz-option-text">
                <span class="font-semibold">$75,000 &ndash; $100,000</span>
              </span>
            </button>
            <button class="quiz-option" data-value="over100k">
              <span class="quiz-option-icon">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </span>
              <span class="quiz-option-text">
                <span class="font-semibold">Over $100,000</span>
              </span>
            </button>
          </div>
        </div>

        <!-- Question 2: Monthly Debt -->
        <div class="quiz-step hidden" data-step="2">
          <h2 class="text-2xl font-bold text-text mb-2">How much do you pay in monthly debt?</h2>
          <p class="text-muted mb-6">Include rent/mortgage, car payments, student loans, credit cards, and other recurring debt.</p>
          <div class="grid gap-3" id="q2-options">
            <button class="quiz-option" data-value="under500">
              <span class="quiz-option-icon">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>
              </span>
              <span class="quiz-option-text">
                <span class="font-semibold">Under $500/month</span>
                <span class="text-sm text-muted">Low debt load</span>
              </span>
            </button>
            <button class="quiz-option" data-value="500-1000">
              <span class="quiz-option-icon">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>
              </span>
              <span class="quiz-option-text">
                <span class="font-semibold">$500 &ndash; $1,000/month</span>
                <span class="text-sm text-muted">Moderate debt</span>
              </span>
            </button>
            <button class="quiz-option" data-value="1000-2000">
              <span class="quiz-option-icon">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>
              </span>
              <span class="quiz-option-text">
                <span class="font-semibold">$1,000 &ndash; $2,000/month</span>
                <span class="text-sm text-muted">Significant obligations</span>
              </span>
            </button>
            <button class="quiz-option" data-value="2000-3000">
              <span class="quiz-option-icon">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>
              </span>
              <span class="quiz-option-text">
                <span class="font-semibold">$2,000 &ndash; $3,000/month</span>
                <span class="text-sm text-muted">Heavy debt load</span>
              </span>
            </button>
            <button class="quiz-option" data-value="over3000">
              <span class="quiz-option-icon">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>
              </span>
              <span class="quiz-option-text">
                <span class="font-semibold">Over $3,000/month</span>
                <span class="text-sm text-muted">Very high obligations</span>
              </span>
            </button>
          </div>
        </div>

        <!-- Question 3: Credit Score -->
        <div class="quiz-step hidden" data-step="3">
          <h2 class="text-2xl font-bold text-text mb-2">What's your credit score range?</h2>
          <p class="text-muted mb-6">Your best estimate is fine. Don't know? <a href="/financial-wellness/understanding-credit-scores/" class="text-primary hover:underline">Learn how to check for free</a>.</p>
          <div class="grid gap-3" id="q3-options">
            <button class="quiz-option" data-value="poor">
              <span class="quiz-option-icon bg-negative-light text-negative">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" /></svg>
              </span>
              <span class="quiz-option-text">
                <span class="font-semibold">Poor (300&ndash;579)</span>
                <span class="text-sm text-muted">Limited options, but they exist</span>
              </span>
            </button>
            <button class="quiz-option" data-value="fair">
              <span class="quiz-option-icon bg-warning-light text-warning">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" /></svg>
              </span>
              <span class="quiz-option-text">
                <span class="font-semibold">Fair (580&ndash;669)</span>
                <span class="text-sm text-muted">Some options available</span>
              </span>
            </button>
            <button class="quiz-option" data-value="good">
              <span class="quiz-option-icon bg-primary-light text-primary">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </span>
              <span class="quiz-option-text">
                <span class="font-semibold">Good (670&ndash;739)</span>
                <span class="text-sm text-muted">Solid range, many options</span>
              </span>
            </button>
            <button class="quiz-option" data-value="excellent">
              <span class="quiz-option-icon bg-positive-light text-positive">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>
              </span>
