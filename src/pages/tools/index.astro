---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Free Financial Tools & Calculators | CreditDoc";
const description = "Free tools to help you make smarter financial decisions. Borrowing power quiz, debt payoff calculator, and credit score simulator — no signup required.";

const tools = [
  {
    title: "What's My Borrowing Power?",
    description: "Answer 5 quick questions to estimate how much you could borrow and get matched with lenders for your situation.",
    href: "/tools/borrowing-power-quiz/",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />',
    badge: "60 seconds",
    live: true,
  },
  {
    title: "Debt Payoff Calculator",
    description: "Compare snowball vs. avalanche strategies. See exactly when you'll be debt-free and how much interest you'll save.",
    href: "/tools/debt-payoff-calculator/",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V13.5zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V18zm2.498-6.75h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V13.5zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V18zm2.504-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zm0 2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V18zm2.498-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zM8.25 6h7.5v2.25h-7.5V6zM12 2.25c-1.892 0-3.758.11-5.593.322C5.307 2.7 4.5 3.65 4.5 4.757V19.5a2.25 2.25 0 002.25 2.25h10.5a2.25 2.25 0 002.25-2.25V4.757c0-1.108-.806-2.057-1.907-2.185A48.507 48.507 0 0012 2.25z" />',
    badge: "New",
    live: true,
  },
  {
    title: "Credit Score Simulator",
    description: "See how paying off debt, opening new accounts, or missing payments could affect your credit score.",
    href: "/tools/credit-score-simulator/",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />',
    badge: "New",
    live: true,
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Free Financial Tools",
  "description": description,
  "url": "https://creditdoc.co/tools/",
  "publisher": {
    "@type": "Organization",
    "name": "CreditDoc",
    "url": "https://creditdoc.co"
  }
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://creditdoc.co/" },
    { "@type": "ListItem", "position": 2, "name": "Tools", "item": "https://creditdoc.co/tools/" }
  ]
};
---

<BaseLayout title={title} description={description} jsonLd={[jsonLd, breadcrumbJsonLd]}>
  <nav class="max-w-4xl mx-auto px-4 pt-6 pb-2" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2 text-sm text-muted">
      <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
      <li class="text-border">/</li>
      <li class="text-text font-medium">Tools</li>
    </ol>
  </nav>

  <div class="max-w-4xl mx-auto px-4 py-8">
    <div class="text-center mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-text mb-4">Free Financial Tools</h1>
      <p class="text-lg text-muted max-w-2xl mx-auto">Make smarter money decisions with free, no-signup-required tools built for people rebuilding or building their credit.</p>
    </div>

    <div class="grid gap-6">
      {tools.map(tool => (
        <a href={tool.live ? tool.href : undefined}
           class:list={["glass-card p-6 flex flex-col sm:flex-row items-start gap-5", { "opacity-60 cursor-default": !tool.live, "pointer-events-auto": !tool.live }]}
           style={!tool.live ? "pointer-events: none;" : ""}>
          <div class="w-14 h-14 rounded-2xl bg-primary-light flex items-center justify-center flex-shrink-0">
            <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <Fragment set:html={tool.icon} />
            </svg>
          </div>
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-2">
              <h2 class="text-xl font-bold text-text">{tool.title}</h2>
              <span class:list={["text-xs font-medium px-2.5 py-0.5 rounded-full", tool.live ? "bg-positive-light text-positive" : "bg-bg-alt text-muted"]}>
                {tool.badge}
              </span>
            </div>
            <p class="text-muted">{tool.description}</p>
          </div>
          {tool.live && (
            <svg class="w-5 h-5 text-muted flex-shrink-0 mt-1 hidden sm:block" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
          )}
        </a>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="text-sm text-muted">More tools coming soon. <a href="/" class="text-primary hover:underline">Back to CreditDoc</a></p>
    </div>
  </div>
</BaseLayout>
