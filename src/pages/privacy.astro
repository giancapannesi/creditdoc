---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Privacy Policy",
  "description": "CreditDoc's privacy policy explaining how we collect, use, and protect your personal information.",
  "url": "https://creditdoc.co/privacy/",
  "datePublished": "2026-03-19",
  "dateModified": "2026-03-19"
};
---

<BaseLayout
  title="Privacy Policy | CreditDoc"
  description="CreditDoc's privacy policy. Learn how we collect, use, store, and protect your personal information, including your rights under CCPA and other privacy laws."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-white border-b border-border">
    <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8 text-center">
      <span class="inline-block rounded-full bg-bg-alt px-4 py-1.5 text-xs font-semibold text-muted uppercase tracking-wider mb-6">Legal</span>
      <h1 class="text-4xl font-bold text-text sm:text-5xl">Privacy Policy</h1>
      <p class="mt-6 text-base text-muted leading-relaxed max-w-2xl mx-auto">
        Effective Date: March 19, 2026 &middot; Last Updated: March 19, 2026
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="space-y-10">

      <div class="rounded-xl border border-border bg-white p-6 sm:p-8">
        <p class="text-sm text-muted leading-relaxed">
          This Privacy Policy describes how CreditDoc.co ("CreditDoc," "we," "us," or "our"), a website owned and operated by Cosmic Phoenix LLC, collects, uses, discloses, and protects information about you when you visit our website at <strong>creditdoc.co</strong> (the "Site"). By using the Site, you agree to the collection and use of information in accordance with this policy.
        </p>
      </div>

      <!-- 1. Information We Collect -->
      <div>
        <h2 class="text-xl font-bold text-text mb-4">1. Information We Collect</h2>
        <div class="rounded-xl border border-border bg-white p-6 sm:p-8 space-y-6">
          <div>
            <h3 class="text-base font-semibold text-text mb-2">1.1 Information You Provide Voluntarily</h3>
            <p class="text-sm text-muted leading-relaxed mb-2">We may collect personal information that you voluntarily provide to us, including:</p>
            <ul class="ml-4 list-disc text-sm text-muted leading-relaxed space-y-1">
              <li><strong>Email address</strong> -- if you subscribe to our newsletter or contact us</li>
              <li><strong>Name</strong> -- if you contact us via email</li>
              <li><strong>Message content</strong> -- if you send us a correction request, feedback, or inquiry</li>
            </ul>
          </div>
          <div>
            <h3 class="text-base font-semibold text-text mb-2">1.2 Information Collected Automatically</h3>
            <p class="text-sm text-muted leading-relaxed mb-2">When you visit the Site, certain information is collected automatically through cookies and similar technologies:</p>
            <ul class="ml-4 list-disc text-sm text-muted leading-relaxed space-y-1">
              <li><strong>Device and browser information</strong> -- browser type, operating system, device type, screen resolution</li>
              <li><strong>Usage data</strong> -- pages visited, time spent on pages, referring URLs, click patterns</li>
              <li><strong>IP address</strong> -- used for approximate geographic location (country/region level) and security purposes</li>
              <li><strong>Cookies and similar technologies</strong> -- see Section 5 below for details</li>
            </ul>
          </div>
          <div>
            <h3 class="text-base font-semibold text-text mb-2">1.3 Information from Third Parties</h3>
            <p class="text-sm text-muted leading-relaxed">
              We may receive anonymized, aggregated analytics data from third-party analytics providers (such as Google Analytics) about how visitors interact with the Site. This data does not identify individual users.
            </p>
          </div>
        </div>
      </div>

      <!-- 2. How We Use Your Information -->
      <div>
        <h2 class="text-xl font-bold text-text mb-4">2. How We Use Your Information</h2>
        <div class="rounded-xl border border-border bg-white p-6 sm:p-8">
          <p class="text-sm text-muted leading-relaxed mb-3">We use the information we collect for the following purposes:</p>
          <ul class="ml-4 list-disc text-sm text-muted leading-relaxed space-y-2">
            <li><strong>To provide and improve the Site</strong> -- analyzing usage patterns to improve content, navigation, and user experience</li>
            <li><strong>To communicate with you</strong> -- responding to inquiries, sending newsletters (if subscribed), and providing updates about our services</li>
            <li><strong>To maintain security</strong> -- detecting and preventing fraud, abuse, or unauthorized access to the Site</li>
            <li><strong>To comply with legal obligations</strong> -- responding to lawful requests from public authorities and complying with applicable laws</li>
            <li><strong>For analytics</strong> -- understanding which pages and content are most useful to our visitors, so we can improve our research and recommendations</li>
          </ul>
        </div>
      </div>

      <!-- 3. Third-Party Sharing -->
      <div>
        <h2 class="text-xl font-bold text-text mb-4">3. How We Share Your Information</h2>
        <div class="rounded-xl border border-border bg-white p-6 sm:p-8 space-y-4">
          <div class="rounded-lg border border-primary/20 bg-primary-light/30 p-4">
            <p class="text-sm text-text font-semibold">We do not sell your personal information. We have never sold personal information and have no plans to do so.</p>
          </div>
          <p class="text-sm text-muted leading-relaxed">We may share information with the following categories of third parties:</p>
          <ul class="ml-4 list-disc text-sm text-muted leading-relaxed space-y-2">
            <li><strong>Analytics providers</strong> -- We use analytics services (such as Google Analytics) to understand how visitors use the Site. These providers collect anonymized data about your interactions with the Site. Google's privacy policy is available at <a href="https://policies.google.com/privacy" class="text-primary hover:underline" target="_blank" rel="noopener noreferrer">policies.google.com/privacy</a>.</li>
            <li><strong>Affiliate networks and partners</strong> -- When you click an affiliate link, the destination company and/or their affiliate network may collect information about your visit. This is governed by those third parties' own privacy policies, not ours. We do not share your personal information (such as your email address) with affiliate partners.</li>
            <li><strong>Email service providers</strong> -- If you subscribe to our newsletter, your email address is stored with our email service provider for the purpose of sending you newsletters. You can unsubscribe at any time.</li>
            <li><strong>Legal requirements</strong> -- We may disclose information if required by law, subpoena, court order, or other governmental authority.</li>
            <li><strong>Business transfers</strong> -- In the event of a merger, acquisition, or sale of assets, user information may be transferred to the acquiring entity.</li>
          </ul>
        </div>
      </div>

      <!-- 4. Data Retention -->
      <div>
        <h2 class="text-xl font-bold text-text mb-4">4. Data Retention</h2>
        <div class="rounded-xl border border-border bg-white p-6 sm:p-8">
          <p class="text-sm text-muted leading-relaxed mb-3">We retain your information only for as long as necessary to fulfill the purposes described in this Privacy Policy:</p>
          <ul class="ml-4 list-disc text-sm text-muted leading-relaxed space-y-2">
            <li><strong>Email addresses</strong> -- retained until you unsubscribe or request deletion</li>
            <li><strong>Analytics data</strong> -- retained in accordance with our analytics provider's data retention settings (typically 14-26 months)</li>
            <li><strong>Server logs</strong> -- retained for up to 90 days for security and troubleshooting purposes</li>
            <li><strong>Correspondence</strong> -- retained for as long as necessary to resolve your inquiry, plus a reasonable period afterward for record-keeping</li>
          </ul>
        </div>
      </div>

      <!-- 5. Cookies -->
      <div>
        <h2 class="text-xl font-bold text-text mb-4">5. Cookies and Tracking Technologies</h2>
        <div class="rounded-xl border border-border bg-white p-6 sm:p-8 space-y-4">
          <p class="text-sm text-muted leading-relaxed">
            Cookies are small text files placed on your device by websites you visit. We use cookies and similar technologies for the following purposes:
          </p>
          <div class="overflow-hidden rounded-lg border border-border">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-bg-alt">
                  <th class="px-4 py-3 text-left font-semibold text-text">Type</th>
                  <th class="px-4 py-3 text-left font-semibold text-text">Purpose</th>
                  <th class="px-4 py-3 text-left font-semibold text-text">Duration</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-border">
                <tr>
                  <td class="px-4 py-3 text-muted font-medium">Essential</td>
                  <td class="px-4 py-3 text-muted">Basic site functionality (e.g., remembering preferences)</td>
                  <td class="px-4 py-3 text-muted">Session</td>
                </tr>
                <tr>
                  <td class="px-4 py-3 text-muted font-medium">Analytics</td>
                  <td class="px-4 py-3 text-muted">Understanding how visitors use the Site (Google Analytics)</td>
                  <td class="px-4 py-3 text-muted">Up to 2 years</td>
                </tr>
                <tr>
                  <td class="px-4 py-3 text-muted font-medium">Affiliate tracking</td>
                  <td class="px-4 py-3 text-muted">Tracking referrals to affiliate partners when you click links</td>
                  <td class="px-4 py-3 text-muted">Varies by partner</td>
                </tr>
              </tbody>
            </table>
          </div>

          <div>
            <h3 class="text-base font-semibold text-text mb-2">How to Manage Cookies</h3>
            <p class="text-sm text-muted leading-relaxed">
              Most web browsers allow you to control cookies through their settings. You can typically:
            </p>
            <ul class="ml-4 list-disc text-sm text-muted leading-relaxed space-y-1 mt-2">
              <li>Delete existing cookies from your browser</li>
              <li>Block all cookies or only third-party cookies</li>
              <li>Set your browser to notify you when a cookie is placed</li>
            </ul>
            <p class="mt-2 text-sm text-muted leading-relaxed">
              Please note that disabling cookies may affect the functionality of the Site. For Google Analytics specifically, you can opt out by installing the <a href="https://tools.google.com/dlpage/gaoptout" class="text-primary hover:underline" target="_blank" rel="noopener noreferrer">Google Analytics Opt-out Browser Add-on</a>.
            </p>
          </div>
        </div>
      </div>

      <!-- 6. California Residents (CCPA) -->
      <div>
        <h2 class="text-xl font-bold text-text mb-4">6. Your Privacy Rights (California Residents)</h2>
        <div class="rounded-xl border border-border bg-white p-6 sm:p-8 space-y-4">
          <p class="text-sm text-muted leading-relaxed">
            If you are a California resident, you have specific rights under the California Consumer Privacy Act (CCPA) and its amendments (CPRA). These rights include:
          </p>
          <div class="space-y-4">
            <div class="flex gap-3">
              <div class="flex-shrink-0 mt-0.5 text-primary font-bold text-sm">1.</div>
              <div>
                <p class="text-sm font-semibold text-text">Right to Know</p>
                <p class="text-sm text-muted leading-relaxed">You have the right to request information about what personal information we have collected about you, the sources of that information, the purpose for collecting it, and the categories of third parties with whom we share it.</p>
              </div>
            </div>
            <div class="flex gap-3">
              <div class="flex-shrink-0 mt-0.5 text-primary font-bold text-sm">2.</div>
              <div>
                <p class="text-sm font-semibold text-text">Right to Delete</p>
                <p class="text-sm text-muted leading-relaxed">You have the right to request that we delete personal information we have collected about you, subject to certain exceptions (such as legal obligations or exercising legal claims).</p>
              </div>
            </div>
            <div class="flex gap-3">
              <div class="flex-shrink-0 mt-0.5 text-primary font-bold text-sm">3.</div>
              <div>
                <p class="text-sm font-semibold text-text">Right to Opt-Out of Sale</p>
                <p class="text-sm text-muted leading-relaxed">You have the right to opt out of the "sale" of your personal information. <strong>CreditDoc does not sell personal information,</strong> so this right does not currently apply. If our practices change, we will update this policy and provide a "Do Not Sell My Personal Information" link.</p>
              </div>
            </div>
            <div class="flex gap-3">
              <div class="flex-shrink-0 mt-0.5 text-primary font-bold text-sm">4.</div>
              <div>
                <p class="text-sm font-semibold text-text">Right to Non-Discrimination</p>
                <p class="text-sm text-muted leading-relaxed">We will not discriminate against you for exercising any of your CCPA rights. We will not charge you different prices, provide different quality of service, or deny you services for exercising your privacy rights.</p>
              </div>
            </div>
            <div class="flex gap-3">
              <div class="flex-shrink-0 mt-0.5 text-primary font-bold text-sm">5.</div>
              <div>
                <p class="text-sm font-semibold text-text">Right to Correct</p>
                <p class="text-sm text-muted leading-relaxed">You have the right to request that we correct inaccurate personal information that we maintain about you.</p>
              </div>
            </div>
          </div>
          <p class="text-sm text-muted leading-relaxed">
            To exercise any of these rights, please contact us at <a href="mailto:gian.eao@gmail.com" class="text-primary hover:underline">gian.eao@gmail.com</a>. We will respond to verifiable requests within 45 days.
          </p>
        </div>
      </div>

      <!-- 7. Children's Privacy -->
      <div>
        <h2 class="text-xl font-bold text-text mb-4">7. Children's Privacy</h2>
        <div class="rounded-xl border border-border bg-white p-6 sm:p-8">
          <p class="text-sm text-muted leading-relaxed">
            The Site is not directed to individuals under the age of 18. We do not knowingly collect personal information from children under 18 years of age. If we learn that we have collected personal information from a child under 18, we will promptly delete that information. If you believe we have collected information from a child under 18, please contact us immediately at <a href="mailto:gian.eao@gmail.com" class="text-primary hover:underline">gian.eao@gmail.com</a>.
          </p>
        </div>
      </div>

      <!-- 8. Security -->
      <div>
        <h2 class="text-xl font-bold text-text mb-4">8. Security Measures</h2>
        <div class="rounded-xl border border-border bg-white p-6 sm:p-8">
          <p class="text-sm text-muted leading-relaxed mb-3">
            We implement reasonable technical and organizational security measures to protect the information we collect, including:
          </p>
          <ul class="ml-4 list-disc text-sm text-muted leading-relaxed space-y-1">
            <li>SSL/TLS encryption for all data transmitted between your browser and our servers</li>
            <li>Secure hosting infrastructure with regular security updates</li>
            <li>Access controls limiting who can access personal information</li>
            <li>Regular review of our data collection, storage, and processing practices</li>
          </ul>
          <p class="mt-3 text-sm text-muted leading-relaxed">
            However, no method of transmission over the Internet or method of electronic storage is completely secure. While we strive to protect your personal information, we cannot guarantee its absolute security.
          </p>
        </div>
      </div>

      <!-- 9. Third-Party Links -->
      <div>
        <h2 class="text-xl font-bold text-text mb-4">9. Third-Party Links</h2>
        <div class="rounded-xl border border-border bg-white p-6 sm:p-8">
          <p class="text-sm text-muted leading-relaxed">
            The Site contains links to third-party websites, including the websites of credit repair companies, lenders, and other financial service providers. This Privacy Policy applies only to CreditDoc.co. We are not responsible for the privacy practices, content, or security of any third-party websites. We encourage you to review the privacy policy of every website you visit, particularly before providing any personal information.
          </p>
        </div>
      </div>

      <!-- 10. International Users -->
      <div>
        <h2 class="text-xl font-bold text-text mb-4">10. International Users</h2>
        <div class="rounded-xl border border-border bg-white p-6 sm:p-8">
          <p class="text-sm text-muted leading-relaxed">
            CreditDoc is operated from the United States and is primarily intended for U.S. residents. If you are accessing the Site from outside the United States, please be aware that your information may be transferred to, stored, and processed in the United States. By using the Site, you consent to the transfer of your information to the United States, which may have different data protection laws than your country of residence.
          </p>
        </div>
      </div>

      <!-- 11. Changes to This Policy -->
      <div>
        <h2 class="text-xl font-bold text-text mb-4">11. Changes to This Privacy Policy</h2>
        <div class="rounded-xl border border-border bg-white p-6 sm:p-8">
          <p class="text-sm text-muted leading-relaxed">
            We may update this Privacy Policy from time to time to reflect changes in our practices, technology, legal requirements, or other factors. When we make material changes, we will update the "Effective Date" and "Last Updated" date at the top of this page. We encourage you to review this Privacy Policy periodically. Your continued use of the Site after any changes constitutes your acceptance of the updated Privacy Policy.
          </p>
        </div>
      </div>

      <!-- 12. Contact -->
      <div>
        <h2 class="text-xl font-bold text-text mb-4">12. Contact Us</h2>
        <div class="rounded-xl border border-border bg-white p-6 sm:p-8">
          <p class="text-sm text-muted leading-relaxed mb-4">
            If you have any questions, concerns, or requests regarding this Privacy Policy or our data practices, please contact us:
          </p>
          <div class="rounded-lg bg-bg-alt p-4 text-sm text-muted space-y-1">
            <p><strong class="text-text">CreditDoc</strong> (a property of Cosmic Phoenix LLC)</p>
            <p>Email: <a href="mailto:gian.eao@gmail.com" class="text-primary hover:underline">gian.eao@gmail.com</a></p>
            <p>Website: <a href="https://creditdoc.co" class="text-primary hover:underline">creditdoc.co</a></p>
          </div>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>
