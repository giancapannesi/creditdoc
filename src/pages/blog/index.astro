---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getBlogPosts, getBlogPostsByCategory } from '../../utils/data-build';

const posts = getBlogPosts().sort((a, b) =>
  new Date(b.publish_date).getTime() - new Date(a.publish_date).getTime()
);

const categories = [
  { slug: 'payday-loan-traps', label: 'Payday Loans' },
  { slug: 'credit-card-traps', label: 'Credit Cards' },
  { slug: 'auto-loan-traps', label: 'Auto Loans' },
  { slug: 'student-loan-traps', label: 'Student Loans' },
  { slug: 'mortgage-traps', label: 'Mortgages' },
  { slug: 'debt-settlement-traps', label: 'Debt Settlement' },
  { slug: 'bnpl-traps', label: 'Buy Now Pay Later' },
  { slug: 'predatory-lending', label: 'Predatory Lending' },
  { slug: 'credit-repair-traps', label: 'Credit Repair' },
  { slug: 'financial-literacy', label: 'Financial Literacy' },
];

const categoryCounts = new Map<string, number>();
for (const post of posts) {
  categoryCounts.set(post.category, (categoryCounts.get(post.category) || 0) + 1);
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "CreditDoc Blog — Debt Traps & Financial Education",
  "description": "In-depth articles exposing how debt traps work, how to avoid them, and how to build real financial literacy. New articles every week.",
  "url": "https://www.creditdoc.co/blog/",
  "publisher": {
    "@type": "Organization",
    "name": "CreditDoc",
    "url": "https://www.creditdoc.co"
  }
};
---

<BaseLayout
  title="Blog — Debt Traps & Financial Education | CreditDoc"
  description="In-depth articles exposing how debt traps work, how to avoid predatory lending, and build real financial literacy. New articles published every week."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-white border-b border-border">
    <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8 text-center">
      <span class="inline-block rounded-full bg-primary-light px-4 py-1.5 text-xs font-semibold text-primary uppercase tracking-wider mb-6">Blog</span>
      <h1 class="text-4xl font-bold text-text sm:text-5xl">Debt Traps & Financial Education</h1>
      <p class="mt-6 text-lg text-muted leading-relaxed max-w-2xl mx-auto">
        How loans, credit cards, and financial products are designed to keep you paying. We break down the mechanics, show you the real numbers, and give you a way out. New articles every week.
      </p>
    </div>
  </section>

  {posts.length === 0 ? (
    <!-- Empty state -->
    <section class="mx-auto max-w-4xl px-4 py-20 sm:px-6 lg:px-8 text-center">
      <div class="glass-card p-12">
        <div class="mx-auto w-16 h-16 rounded-2xl bg-bg-alt flex items-center justify-center mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/>
          </svg>
        </div>
        <h2 class="text-xl font-bold text-text">Coming Soon</h2>
        <p class="mt-3 text-muted">Our first articles launch the week of April 6, 2026. Check back soon or browse our <a href="/financial-wellness/" class="text-primary hover:underline font-medium">Financial Wellness Center</a> for educational guides available now.</p>
      </div>
    </section>
  ) : (
    <>
      <!-- Category Filter Tabs -->
      <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div class="flex flex-wrap gap-2" id="category-filters">
          <button
            class="filter-btn active rounded-full px-4 py-2 text-sm font-medium border transition-colors"
            data-category="all"
          >
            All ({posts.length})
          </button>
          {categories.map(cat => {
            const count = categoryCounts.get(cat.slug) || 0;
            if (count === 0) return null;
            return (
              <button
                class="filter-btn rounded-full px-4 py-2 text-sm font-medium border transition-colors"
                data-category={cat.slug}
              >
                {cat.label} ({count})
              </button>
            );
          })}
        </div>
      </section>

      <!-- Posts Grid -->
      <section class="mx-auto max-w-7xl px-4 pb-16 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="posts-grid">
          {posts.map(post => (
            <a
              href={`/blog/${post.slug}/`}
              class="post-card glass-card p-6 hover:shadow-lg transition-shadow group flex flex-col h-full"
              data-category={post.category}
            >
              <div class="flex items-center gap-2 mb-3">
                <span class="inline-block rounded-full bg-primary-light px-2.5 py-0.5 text-[11px] font-semibold text-primary uppercase tracking-wider">
                  {post.category_label}
                </span>
                <span class="text-xs text-muted">{post.read_time}</span>
              </div>
              <h2 class="text-base font-semibold text-text group-hover:text-primary transition-colors leading-snug">{post.title}</h2>
              <p class="mt-2 text-sm text-muted leading-relaxed line-clamp-3">{post.description}</p>
              <div class="flex-1"></div>
              <div class="mt-4 flex items-center justify-between">
                <span class="text-xs text-muted">
                  {new Date(post.publish_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </span>
                <span class="flex items-center text-sm font-medium text-primary">
                  Read
                  <svg xmlns="http://www.w3.org/2000/svg" class="ml-1 h-4 w-4 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </section>
    </>
  )}

  <!-- CTA -->
  <section class="bg-white border-t border-border">
    <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-text">Learn More</h2>
      <p class="mt-3 text-muted max-w-xl mx-auto">
        Explore our educational resources or search for financial topics.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="/financial-wellness/"
          class="inline-flex items-center px-6 py-3 rounded-lg bg-primary text-white font-semibold text-sm hover:bg-primary-hover transition-colors min-h-[44px]"
        >
          Wellness Guides
        </a>
        <a
          href="/learn/"
          class="inline-flex items-center px-6 py-3 rounded-lg border border-border text-text font-semibold text-sm hover:bg-bg-alt transition-colors min-h-[44px]"
        >
          Search Topics
        </a>
      </div>
    </div>
  </section>

  <style>
    .filter-btn {
      background: var(--bg-alt);
      color: var(--text);
      border-color: var(--border);
    }
    .filter-btn:hover, .filter-btn.active {
      background: var(--primary-light);
      color: var(--primary);
      border-color: var(--primary);
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const buttons = document.querySelectorAll('.filter-btn');
      const cards = document.querySelectorAll('.post-card');

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          const category = btn.getAttribute('data-category');

          buttons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');

          cards.forEach(card => {
            const cardCat = card.getAttribute('data-category');
            if (category === 'all' || cardCat === category) {
              (card as HTMLElement).style.display = '';
            } else {
              (card as HTMLElement).style.display = 'none';
            }
          });
        });
      });
    });
  </script>
</BaseLayout>
