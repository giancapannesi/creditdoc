---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import GlossaryAppendix from '../../components/GlossaryAppendix.astro';
import AffiliateSidebar from '../../components/AffiliateSidebar.astro';
import AffiliateInline from '../../components/AffiliateInline.astro';
import AffiliateGeoFilter from '../../components/AffiliateGeoFilter.astro';
import { getBlogPosts, getBlogPostBySlug, getBlogPostsByCategory, getCategories, getListicles, getWellnessGuideBySlug, getGlossaryTermsForContext } from '../../utils/data';
import type { BlogPost } from '../../utils/data';


const { slug } = Astro.params;
const post = await getBlogPostBySlug(slug!);
if (!post) return new Response('Not found', { status: 404 });

const relatedPosts = (await getBlogPostsByCategory(post.category))
  .filter(p => p.slug !== post.slug)
  .slice(0, 3);

const relatedGuides = (await Promise.all(post.related_guides.map(s => getWellnessGuideBySlug(s))))
  .filter((g): g is NonNullable<typeof g> => g !== undefined);

const categories = await getCategories();
const relatedCategories = post.related_categories
  .map(slug => categories.find(c => c.slug === slug))
  .filter((c): c is NonNullable<typeof c> => c !== undefined);

// Glossary terms based on tags
const glossaryContexts = post.tags.map(t => `blog-${t}`);
const glossaryTerms = getGlossaryTermsForContext(glossaryContexts);

// Cross-link: match blog category to relevant listicles
const blogCategoryToListicleCategory: Record<string, string[]> = {
  'personal-loans': ['personal-loans'],
  'credit-repair': ['credit-repair'],
  'debt-relief': ['debt-relief'],
  'build-credit': ['build-credit'],
  'credit-monitoring': ['credit-monitoring'],
  'emergency-cash': ['payday-alternatives', 'emergency-cash'],
};
const matchingListicleCategories = blogCategoryToListicleCategory[post.category] || [];
const relatedListicles = (await getListicles())
  .filter(l => matchingListicleCategories.includes(l.category))
  .slice(0, 3);

// JSON-LD: Article + FAQPage + BreadcrumbList
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.title,
    "description": post.seo_description,
    "image": "https://www.creditdoc.co/og-default.png",
    "url": `https://www.creditdoc.co/blog/${post.slug}/`,
    "datePublished": post.publish_date,
    "dateModified": post.last_updated,
    "author": {
      "@type": "Person",
      "name": "Harvey Brooks",
      "jobTitle": "Senior Financial Editor",
      "description": "Consumer finance writer and editor with over a decade covering credit repair, personal lending, and debt management.",
      "url": "https://www.creditdoc.co/about/"
    },
    "publisher": {
      "@type": "Organization",
      "name": "CreditDoc",
      "url": "https://www.creditdoc.co",
      "logo": { "@type": "ImageObject", "url": "https://www.creditdoc.co/favicon.svg" }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://www.creditdoc.co/blog/${post.slug}/`
    },
    "keywords": post.tags.join(', ')
  },
  ...(post.faq.length > 0 ? [{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": post.faq.map(f => ({
      "@type": "Question",
      "name": f.question,
      "acceptedAnswer": { "@type": "Answer", "text": f.answer }
    }))
  }] : []),
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.creditdoc.co/" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://www.creditdoc.co/blog/" },
      { "@type": "ListItem", "position": 3, "name": post.title, "item": `https://www.creditdoc.co/blog/${post.slug}/` }
    ]
  }
];
---

<BaseLayout
  title={post.seo_title}
  description={post.seo_description}
  jsonLd={jsonLd}
>
  <!-- Breadcrumbs -->
  <div class="border-b border-border bg-white">
    <div class="mx-auto max-w-7xl px-4 py-3 sm:px-6 lg:px-8">
      <nav class="flex items-center text-sm text-muted" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" class="mx-2 h-4 w-4 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"/>
        </svg>
        <a href="/blog/" class="hover:text-primary transition-colors">Blog</a>
        <svg xmlns="http://www.w3.org/2000/svg" class="mx-2 h-4 w-4 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"/>
        </svg>
        <span class="text-text font-medium truncate">{post.title}</span>
      </nav>
    </div>
  </div>

  <!-- Header -->
  <section class="bg-white border-b border-border">
    <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-4">
          <span class="inline-block rounded-full bg-primary-light px-3 py-1 text-xs font-semibold text-primary uppercase tracking-wider">{post.category_label}</span>
          <span class="text-sm text-muted">{post.read_time} read</span>
        </div>
        <h1 class="text-3xl font-bold text-text sm:text-4xl leading-tight">{post.title}</h1>
        <p class="mt-4 text-lg text-muted leading-relaxed">{post.description}</p>
        <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-muted">
          <span>Written by <a href="/about/" class="text-primary hover:underline font-medium">Harvey Brooks</a></span>
          <span class="text-border">|</span>
          <span>Reviewed by the CreditDoc Editorial Team</span>
          <span class="text-border">|</span>
          <span>Published {new Date(post.publish_date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
        </div>
        {post.tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {post.tags.map(tag => (
              <span class="inline-block rounded-full bg-bg-alt px-2.5 py-0.5 text-[11px] font-medium text-muted border border-border">
                {tag.replace(/-/g, ' ')}
              </span>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Two-column layout -->
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <!-- Main Column -->
      <div class="lg:col-span-2 space-y-8">
        {post.sections.map((section, i) => (
          <Fragment>
            <section id={`section-${i}`}>
              <h2 class="text-xl font-bold text-text mb-4">{section.heading}</h2>
              <div class="prose-content text-sm text-muted leading-relaxed space-y-4">
                {section.content.split('\n\n').map(paragraph => {
                  if (paragraph.startsWith('- ') || paragraph.startsWith('* ')) {
                    const items = paragraph.split('\n').filter(line => line.startsWith('- ') || line.startsWith('* '));
                    return (
                      <ul class="list-disc list-inside space-y-1.5 ml-1">
                        {items.map(item => (
                          <li set:html={item.replace(/^[-*]\s+/, '').replace(/\*\*(.*?)\*\*/g, '<strong class="text-text">$1</strong>')} />
                        ))}
                      </ul>
                    );
                  }
                  if (paragraph.match(/^\d+\.\s/)) {
                    const items = paragraph.split('\n').filter(line => line.match(/^\d+\.\s/));
                    return (
                      <ol class="list-decimal list-inside space-y-1.5 ml-1">
                        {items.map(item => (
                          <li set:html={item.replace(/^\d+\.\s+/, '').replace(/\*\*(.*?)\*\*/g, '<strong class="text-text">$1</strong>')} />
                        ))}
                      </ol>
                    );
                  }
                  return <p set:html={paragraph.replace(/\*\*(.*?)\*\*/g, '<strong class="text-text">$1</strong>')} />;
                })}
              </div>
            </section>
            {i === 1 && post.sections.length > 3 && (
              <AffiliateInline category={post.category} />
            )}
          </Fragment>
        ))}

        <!-- FAQ Section -->
        {post.faq.length > 0 && (
          <section id="faq" class="border-t border-border pt-8">
            <h2 class="text-xl font-bold text-text mb-6">Frequently Asked Questions</h2>
            <div class="space-y-4">
              {post.faq.map(item => (
                <details class="glass-card p-5 group">
                  <summary class="flex items-center justify-between cursor-pointer list-none text-base font-semibold text-text">
                    {item.question}
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-muted flex-shrink-0 ml-4 group-open:rotate-180 transition-transform" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/>
                    </svg>
                  </summary>
                  <p class="mt-3 text-sm text-muted leading-relaxed">{item.answer}</p>
                </details>
              ))}
            </div>
          </section>
        )}

        <!-- Author / E-E-A-T -->
        <section class="border-t border-border pt-8">
          <div class="rounded-xl border border-border bg-white p-5 flex gap-4">
            <div class="flex-shrink-0">
              <div class="h-12 w-12 rounded-full bg-gradient-to-br from-primary to-primary-hover flex items-center justify-center text-white text-sm font-bold">HB</div>
            </div>
            <div>
              <p class="text-sm font-semibold text-text">Harvey Brooks</p>
              <p class="text-xs text-primary font-medium">Senior Financial Editor</p>
              <p class="mt-2 text-xs text-muted leading-relaxed">
                Harvey Brooks is a consumer finance writer specializing in credit repair, personal lending, and debt management. With over a decade covering the industry, he makes financial literacy accessible to everyday Americans. <a href="/about/" class="text-primary hover:underline">About our editorial team</a>.
              </p>
            </div>
          </div>
        </section>

        <!-- Glossary Appendix -->
        <GlossaryAppendix terms={glossaryTerms} />

        <!-- Disclaimer -->
        <div class="rounded-lg bg-bg-alt p-4 border border-border">
          <p class="text-xs text-muted leading-relaxed">
            <strong class="text-text">Disclaimer:</strong> This article is for educational purposes only and does not constitute financial advice. CreditDoc is not a financial advisor, lender, or credit repair company. Always consult with a qualified financial professional before making financial decisions. Your individual circumstances may differ from the general information presented here.
          </p>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Key Takeaways -->
        <div class="glass-card p-5">
          <h3 class="text-base font-semibold text-text mb-3 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 20 20" fill="currentColor">
              <path d="M10 1a6 6 0 00-3.815 10.631C7.237 12.5 8 13.443 8 14.456v.644a.75.75 0 00.572.729 6.016 6.016 0 002.856 0A.75.75 0 0012 15.1v-.644c0-1.013.762-1.957 1.815-2.825A6 6 0 0010 1zM8.863 17.414a.75.75 0 00-.226 1.483 9.066 9.066 0 002.726 0 .75.75 0 00-.226-1.483 7.553 7.553 0 01-2.274 0z"/>
            </svg>
            Key Takeaways
          </h3>
          <ul class="space-y-2">
            {post.key_takeaways.map(takeaway => (
              <li class="flex gap-2 text-sm text-muted leading-relaxed">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary flex-shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
                </svg>
                <span>{takeaway}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Table of Contents -->
        <div class="glass-card p-5">
          <h3 class="text-base font-semibold text-text mb-3 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M2 3.75A.75.75 0 012.75 3h14.5a.75.75 0 010 1.5H2.75A.75.75 0 012 3.75zm0 4.167a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H2.75a.75.75 0 01-.75-.75zm0 4.166a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H2.75a.75.75 0 01-.75-.75zm0 4.167a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H2.75a.75.75 0 01-.75-.75z" clip-rule="evenodd"/>
            </svg>
            In This Article
          </h3>
          <nav class="space-y-1.5">
            {post.sections.map((section, i) => (
              <a
                href={`#section-${i}`}
                class="block text-sm text-muted hover:text-primary transition-colors py-0.5"
              >
                {section.heading}
              </a>
            ))}
            {post.faq.length > 0 && (
              <a href="#faq" class="block text-sm text-muted hover:text-primary transition-colors py-0.5">
                FAQ
              </a>
            )}
          </nav>
        </div>

        <!-- Related Posts -->
        {relatedPosts.length > 0 && (
          <div class="glass-card p-5">
            <h3 class="text-base font-semibold text-text mb-3">More on {post.category_label}</h3>
            <div class="space-y-3">
              {relatedPosts.map(related => (
                <a
                  href={`/blog/${related.slug}/`}
                  class="block rounded-lg border border-border p-3 hover:border-primary/30 hover:bg-primary-light/20 transition-colors"
                >
                  <p class="text-sm font-medium text-text leading-snug">{related.title}</p>
                  <p class="mt-1 text-xs text-muted">{related.read_time}</p>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Related Wellness Guides -->
        {relatedGuides.length > 0 && (
          <div class="glass-card p-5">
            <h3 class="text-base font-semibold text-text mb-3">Related Guides</h3>
            <div class="space-y-3">
              {relatedGuides.map(guide => (
                <a
                  href={`/financial-wellness/${guide.slug}/`}
                  class="block rounded-lg border border-border p-3 hover:border-primary/30 hover:bg-primary-light/20 transition-colors"
                >
                  <p class="text-sm font-medium text-text leading-snug">{guide.title}</p>
                  <p class="mt-1 text-xs text-muted">{guide.read_time}</p>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Affiliate Sidebar -->
        <AffiliateSidebar category={post.category} />

        <!-- Recommended Services (cross-link to listicles) -->
        {relatedListicles.length > 0 && (
          <div class="glass-card p-5">
            <h3 class="text-base font-semibold text-text mb-3 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z" clip-rule="evenodd"/>
              </svg>
              Recommended Services
            </h3>
            <div class="space-y-3">
              {relatedListicles.map(listicle => (
                <a
                  href={`/best/${listicle.slug}/`}
                  class="block rounded-lg border border-border p-3 hover:border-primary/30 hover:bg-primary-light/20 transition-colors"
                >
                  <p class="text-sm font-medium text-text leading-snug">{listicle.title}</p>
                  <p class="mt-1 text-xs text-primary font-medium">Compare top picks &rarr;</p>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Related Categories -->
        {relatedCategories.length > 0 && (
          <div class="glass-card p-5">
            <h3 class="text-base font-semibold text-text mb-3">Find Services</h3>
            <p class="text-xs text-muted mb-3">Browse companies related to this topic:</p>
            <div class="space-y-2">
              {relatedCategories.map(cat => (
                <a
                  href={`/categories/${cat.slug}/`}
                  class="flex items-center gap-2 rounded-lg border border-border px-3 py-2.5 text-sm text-text hover:border-primary/30 hover:bg-primary-light/20 transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"/>
                  </svg>
                  {cat.name}
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
  <AffiliateGeoFilter />
</BaseLayout>
