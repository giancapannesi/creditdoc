---
import BaseLayout from '../layouts/BaseLayout.astro';
import glossaryTerms from '../content/glossary-terms.json';

// Group terms by category
const categoryLabels: Record<string, string> = {
  'interest-and-rates': 'Interest & Rates',
  'how-loans-work': 'How Loans Work',
  'fees-and-costs': 'Fees & Costs',
  'credit-and-scoring': 'Credit & Scoring',
  'credit-cards': 'Credit Cards',
  'debt-and-recovery': 'Debt & Recovery',
  'legal-terms': 'Legal Terms',
  'mortgages': 'Mortgages',
};

const categoryOrder = [
  'credit-and-scoring',
  'interest-and-rates',
  'how-loans-work',
  'fees-and-costs',
  'credit-cards',
  'debt-and-recovery',
  'legal-terms',
  'mortgages',
];

const grouped = new Map<string, typeof glossaryTerms>();
for (const cat of categoryOrder) {
  grouped.set(cat, glossaryTerms.filter(t => t.category === cat).sort((a, b) => a.term.localeCompare(b.term)));
}

const title = 'Credit & Lending Glossary — 70 Terms Explained Simply | CreditDoc';
const description = 'Plain-English definitions for credit scores, loan terms, interest rates, debt recovery, and more. Every term explained with real examples.';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  "name": "CreditDoc Credit & Lending Glossary",
  "description": description,
  "url": "https://creditdoc.co/glossary/",
  "hasDefinedTerm": glossaryTerms.map(t => ({
    "@type": "DefinedTerm",
    "name": t.term,
    "description": t.plain_definition,
    "url": `https://creditdoc.co/glossary/#${t.slug}`,
  })),
};
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <main class="flex-1">
    <!-- Breadcrumb -->
    <nav class="mx-auto max-w-7xl px-4 pt-6 sm:px-6 lg:px-8" aria-label="Breadcrumb">
      <ol class="flex items-center gap-1.5 text-sm text-muted">
        <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
        <li><span class="mx-1">/</span></li>
        <li class="text-text font-medium">Glossary</li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <div class="glass-card p-6 sm:p-8">
        <h1 class="text-2xl sm:text-3xl font-bold text-text">Credit & Lending Glossary</h1>
        <p class="mt-3 text-muted leading-relaxed max-w-3xl">
          {glossaryTerms.length} terms explained in plain English — no jargon, real examples. Click any term to read the full definition.
        </p>

        <!-- Quick nav -->
        <div class="mt-6 flex flex-wrap gap-2">
          {categoryOrder.map(cat => (
            <a href={`#cat-${cat}`} class="inline-flex items-center rounded-full bg-bg-alt px-3 py-1 text-xs font-medium text-text border border-border hover:border-primary hover:text-primary transition-colors">
              {categoryLabels[cat]}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Terms by category -->
    <section class="mx-auto max-w-7xl px-4 pb-12 sm:px-6 lg:px-8 space-y-10">
      {categoryOrder.map(cat => {
        const terms = grouped.get(cat) || [];
        return (
          <div id={`cat-${cat}`}>
            <h2 class="text-xl font-bold text-text mb-4 scroll-mt-20">{categoryLabels[cat]}</h2>
            <div class="space-y-4">
              {terms.map(term => (
                <div id={term.slug} class="glass-card p-5 scroll-mt-20">
                  <h3 class="text-base font-semibold text-text">
                    {term.term}
                    {term.full_form !== term.term && (
                      <span class="text-muted font-normal text-sm ml-2">({term.full_form})</span>
                    )}
                  </h3>
                  <p class="mt-2 text-sm text-muted leading-relaxed">{term.plain_definition}</p>
                  {term.why_it_matters && (
                    <div class="mt-3 rounded-lg bg-primary-light/30 border border-primary/10 px-4 py-3">
                      <p class="text-xs font-semibold text-primary uppercase tracking-wide mb-1">Why it matters</p>
                      <p class="text-sm text-text leading-relaxed">{term.why_it_matters}</p>
                    </div>
                  )}
                  {term.example && (
                    <div class="mt-3 rounded-lg bg-bg-alt border border-border px-4 py-3">
                      <p class="text-xs font-semibold text-muted uppercase tracking-wide mb-1">Example</p>
                      <p class="text-sm text-text leading-relaxed">{term.example}</p>
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </section>
  </main>
</BaseLayout>
