---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RatingStars from '../../components/RatingStars.astro';
import { getListicles, getLenderBySlug, formatPrice, getBbbClass } from '../../utils/data';
import type { Lender } from '../../utils/data';

export function getStaticPaths() {
  const listicles = getListicles();
  return listicles.map(listicle => ({
    params: { slug: listicle.slug },
  }));
}

const { slug } = Astro.params;
const listicles = getListicles();
const listicle = listicles.find(l => l.slug === slug)!;

const rankedLenders = listicle.lenders
  .map(s => getLenderBySlug(s))
  .filter((l): l is Lender => l !== undefined);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://creditdoc.co/' },
      { '@type': 'ListItem', position: 2, name: listicle.title, item: `https://creditdoc.co/best/${listicle.slug}/` },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: listicle.title,
    description: listicle.description,
    numberOfItems: rankedLenders.length,
    itemListElement: rankedLenders.map((lender, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: lender.name,
      url: `https://creditdoc.co/review/${lender.slug}/`,
    })),
  },
];
---

<BaseLayout
  title={listicle.seo_title}
  description={listicle.seo_description}
  jsonLd={jsonLd}
>
  <!-- Breadcrumbs -->
  <nav class="mx-auto max-w-7xl px-4 pt-6 sm:px-6 lg:px-8" aria-label="Breadcrumb">
    <ol class="flex items-center gap-1.5 text-sm text-muted">
      <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
      <li><span class="mx-1">/</span></li>
      <li class="text-text font-medium">{listicle.title}</li>
    </ol>
  </nav>

  <!-- Header -->
  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <h1 class="text-2xl sm:text-3xl font-bold text-text">{listicle.title}</h1>
      <p class="mt-3 text-muted leading-relaxed">{listicle.description}</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="mx-auto max-w-7xl px-4 pb-4 sm:px-6 lg:px-8">
    <div class="glass-card p-6">
      <p class="text-sm text-muted leading-relaxed">{listicle.intro}</p>
    </div>
  </section>

  <!-- Ranked List -->
  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="space-y-6">
      {rankedLenders.map((lender, i) => {
        const bbbCls = getBbbClass(lender.company_info.bbb_rating);
        const lowestPrice = lender.pricing.tiers.length > 0
          ? Math.min(...lender.pricing.tiers.map(t => t.price))
          : lender.pricing.monthly_price;
        return (
          <article class="glass-card p-6 relative">
            <!-- Rank Badge -->
            <div class="absolute -top-4 -left-2 w-10 h-10 rounded-full bg-primary text-white text-lg font-bold flex items-center justify-center shadow-lg">
              {i + 1}
            </div>

            <div class="flex flex-col sm:flex-row items-start gap-6 ml-6 sm:ml-8">
              <!-- Logo -->
              <div class="w-16 h-16 rounded-xl bg-bg-alt border border-border flex items-center justify-center shrink-0 overflow-hidden">
                {lender.logo_url ? (
                  <img src={lender.logo_url} alt={`${lender.name} logo`} class="w-12 h-12 object-contain" loading="lazy" />
                ) : (
                  <span class="text-xl font-bold text-primary">{lender.name.charAt(0)}</span>
                )}
              </div>

              <!-- Content -->
              <div class="flex-1 min-w-0">
                <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4">
                  <h2 class="text-lg font-bold text-text">{lender.name}</h2>
                  <RatingStars rating={lender.rating} size="sm" showValue={true} />
                </div>

                <!-- Key Stats -->
                <div class="mt-3 flex flex-wrap items-center gap-2">
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-primary-light text-primary">
                    From {formatPrice(lowestPrice)}/mo
                  </span>
                  <span class:list={['inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold', bbbCls]}>
                    BBB: {lender.company_info.bbb_rating}
                  </span>
                  {lender.pricing.money_back_guarantee && (
                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-positive-light text-positive">
                      Money-Back Guarantee
                    </span>
                  )}
                  {lender.pricing.free_consultation && (
                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-accent/10 text-accent">
                      Free Consultation
                    </span>
                  )}
                </div>

                <!-- Why it made the list -->
                <p class="mt-3 text-sm text-muted leading-relaxed">
                  {lender.description_short}
                </p>

                <!-- Highlight pros -->
                <div class="mt-3 space-y-1">
                  {lender.pros.slice(0, 3).map(pro => (
                    <div class="flex items-start gap-2 text-sm text-text">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 text-positive shrink-0" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
                      </svg>
                      {pro}
                    </div>
                  ))}
                </div>

                <!-- CTA -->
                <div class="mt-4 flex flex-col sm:flex-row gap-2">
                  <a
                    href={`/review/${lender.slug}/`}
                    class="inline-flex items-center justify-center px-4 py-2.5 rounded-lg border border-border text-sm font-medium text-text hover:bg-bg-alt transition-colors"
                  >
                    Read Full Review
                  </a>
                  <a
                    href={lender.affiliate_url || lender.website_url}
                    target="_blank"
                    rel="noopener noreferrer nofollow"
                    class="inline-flex items-center justify-center px-4 py-2.5 rounded-lg bg-primary text-sm font-medium text-white hover:bg-primary-hover transition-colors"
                  >
                    Visit {lender.name}
                  </a>
                </div>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <!-- Affiliate Disclosure -->
  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="rounded-lg bg-bg-alt border border-border p-4">
      <p class="text-xs text-muted leading-relaxed">
        <strong class="text-text">Affiliate Disclosure:</strong> CreditDoc may earn a commission when you click links to the services featured on this page. Our editorial team independently evaluates all services. <a href="/disclosure/" class="text-primary hover:underline">Learn more</a>.
      </p>
    </div>
  </section>
</BaseLayout>
