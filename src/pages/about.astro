---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About CreditDoc",
  "description": "Learn about CreditDoc's mission, team, and methodology for reviewing credit repair companies and financial services.",
  "url": "https://www.creditdoc.co/about/",
  "mainEntity": {
    "@type": "Organization",
    "name": "CreditDoc",
    "url": "https://www.creditdoc.co",
    "description": "Independent comparison website for credit repair companies, personal lenders, and financial services.",
    "foundingDate": "2026",
    "parentOrganization": {
      "@type": "Organization",
      "name": "Cosmic Phoenix LLC",
      "address": {
        "@type": "PostalAddress",
        "addressRegion": "WY",
        "addressCountry": "US"
      }
    },
    "founder": {
      "@type": "Person",
      "name": "CreditDoc Founder",
      "jobTitle": "Founder & Lead Analyst",
      "description": "Consumer finance specialist with 15+ years experience across payments, lending, and risk management in 10+ countries. MBA from a globally ranked business school.",
      "knowsAbout": ["Consumer Finance", "Credit Repair", "Lending", "Risk Management", "Payments"]
    }
  }
};
---

<BaseLayout
  title="About CreditDoc | Our Mission, Team & Expertise"
  description="CreditDoc is an independent comparison website helping Americans find the right credit repair, personal loan, and debt relief services. Learn about our team and mission."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-white border-b border-border">
    <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8 text-center">
      <span class="inline-block rounded-full bg-primary-light px-4 py-1.5 text-xs font-semibold text-primary uppercase tracking-wider mb-6">About Us</span>
      <h1 class="text-4xl font-bold text-text sm:text-5xl">About CreditDoc</h1>
      <p class="mt-6 text-lg text-muted leading-relaxed max-w-2xl mx-auto">
        We believe every American deserves access to clear, unbiased information about credit repair and lending services. CreditDoc exists to shine a light on an industry that has historically been opaque.
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="space-y-16">

      <!-- Our Mission -->
      <div>
        <h2 class="text-2xl font-bold text-text mb-6">Our Mission</h2>
        <div class="rounded-xl border border-primary/20 bg-primary-light/30 p-6 sm:p-8">
          <p class="text-base text-text leading-relaxed">
            Millions of Americans struggle with damaged credit. The credit repair industry -- worth over $5 billion annually -- promises solutions, but the landscape is filled with confusing pricing, misleading claims, and companies that don't always deliver on their promises. Meanwhile, predatory lenders target the most financially vulnerable consumers.
          </p>
          <p class="mt-4 text-base text-text leading-relaxed">
            CreditDoc was built to change that. We provide independent, research-backed reviews and comparisons of credit repair companies, personal lenders, and financial services so that consumers can make informed decisions -- not pressured ones.
          </p>
        </div>
      </div>

      <!-- What We Do -->
      <div>
        <h2 class="text-2xl font-bold text-text mb-6">What We Do</h2>
        <div class="grid gap-6 sm:grid-cols-2">
          <div class="rounded-xl border border-border bg-white p-6">
            <div class="flex items-center gap-3 mb-4">
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-light text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"/>
                  <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"/>
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-text">Independent Research</h3>
            </div>
            <p class="text-sm text-muted leading-relaxed">
              We analyze credit repair companies and lenders using publicly available data, including BBB ratings, CFPB complaint records, user reviews, and direct pricing verification.
            </p>
          </div>

          <div class="rounded-xl border border-border bg-white p-6">
            <div class="flex items-center gap-3 mb-4">
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-light text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M3 3a1 1 0 000 2v8a2 2 0 002 2h2.586l-1.293 1.293a1 1 0 101.414 1.414L10 15.414l2.293 2.293a1 1 0 001.414-1.414L12.414 15H15a2 2 0 002-2V5a1 1 0 100-2H3zm11 4a1 1 0 10-2 0v4a1 1 0 102 0V7zm-3 1a1 1 0 10-2 0v3a1 1 0 102 0V8zM8 9a1 1 0 00-2 0v2a1 1 0 102 0V9z" clip-rule="evenodd"/>
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-text">Unbiased Comparisons</h3>
            </div>
            <p class="text-sm text-muted leading-relaxed">
              Our side-by-side comparisons help you evaluate credit repair services on the factors that matter: pricing, effectiveness, transparency, customer service, and ease of use.
            </p>
          </div>

          <div class="rounded-xl border border-border bg-white p-6">
            <div class="flex items-center gap-3 mb-4">
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-light text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-text">Consumer Education</h3>
            </div>
            <p class="text-sm text-muted leading-relaxed">
              We provide guides, resources, and educational content to help consumers understand their rights under the FCRA and CROA, and to help them make informed choices about their financial health.
            </p>
          </div>

          <div class="rounded-xl border border-border bg-white p-6">
            <div class="flex items-center gap-3 mb-4">
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-light text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-text">Verified Pricing</h3>
            </div>
            <p class="text-sm text-muted leading-relaxed">
              We verify pricing directly from company websites monthly. When prices change, we update our listings. You'll always see current, accurate pricing information.
            </p>
          </div>
        </div>
      </div>

      <!-- How We're Different -->
      <div>
        <h2 class="text-2xl font-bold text-text mb-6">How We're Different</h2>
        <div class="rounded-xl border border-border bg-white p-6 sm:p-8">
          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="flex-shrink-0 mt-1">
                <div class="h-6 w-6 rounded-full bg-primary-light flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
              </div>
              <div>
                <p class="text-base font-semibold text-text">We are not a credit repair company.</p>
                <p class="mt-1 text-sm text-muted">We don't sell credit repair services, originate loans, or provide financial advice. We compare services so you can choose the right one for your situation.</p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="flex-shrink-0 mt-1">
                <div class="h-6 w-6 rounded-full bg-primary-light flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
              </div>
              <div>
                <p class="text-base font-semibold text-text">Compensation never influences our ratings.</p>
                <p class="mt-1 text-sm text-muted">Some companies featured on our site pay us referral fees. This compensation never affects our editorial ratings, rankings, or recommendations. We also feature companies that don't pay us anything.</p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="flex-shrink-0 mt-1">
                <div class="h-6 w-6 rounded-full bg-primary-light flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
              </div>
              <div>
                <p class="text-base font-semibold text-text">Built by a finance professional, not marketers.</p>
                <p class="mt-1 text-sm text-muted">Our founder has 15+ years in consumer financial services -- not affiliate marketing. This is a financial research site built with industry expertise, not a content farm designed to rank on Google.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Our Founder -->
      <div>
        <h2 class="text-2xl font-bold text-text mb-6">Our Founder</h2>
        <div class="rounded-xl border border-border bg-white p-6 sm:p-8">
          <div class="flex flex-col sm:flex-row gap-6">
            <div class="flex-shrink-0">
              <div class="h-24 w-24 rounded-full bg-gradient-to-br from-primary to-primary-hover flex items-center justify-center text-white text-3xl font-bold">
                CD
              </div>
            </div>
            <div>
              <h3 class="text-xl font-bold text-text">Founder & Lead Analyst</h3>
              <p class="mt-1 text-sm text-primary font-medium">Consumer Finance Specialist</p>
              <div class="mt-4 space-y-3 text-sm text-muted leading-relaxed">
                <p>
                  Our founder brings over 15 years of experience in consumer financial services, with deep expertise in payments, lending, credit risk management, and financial operations across 10+ countries.
                </p>
                <p>
                  With an MBA from a globally ranked business school and former COO-level roles at major financial services organizations, our founder has seen the lending and credit industry from the inside -- including the parts that don't always serve consumers well.
                </p>
                <p>
                  After leaving the corporate world in 2024, the mission became clear: build tools and resources that help underserved consumers navigate financial products with the same level of information that industry insiders have. CreditDoc is the result of that mission.
                </p>
              </div>

              <div class="mt-6 flex flex-wrap gap-2">
                <span class="rounded-full bg-bg-alt px-3 py-1 text-xs font-medium text-muted">15+ Years Finance</span>
                <span class="rounded-full bg-bg-alt px-3 py-1 text-xs font-medium text-muted">MBA, Ranked Business School</span>
                <span class="rounded-full bg-bg-alt px-3 py-1 text-xs font-medium text-muted">10+ Countries</span>
                <span class="rounded-full bg-bg-alt px-3 py-1 text-xs font-medium text-muted">Payments & Lending</span>
                <span class="rounded-full bg-bg-alt px-3 py-1 text-xs font-medium text-muted">Risk Management</span>
                <span class="rounded-full bg-bg-alt px-3 py-1 text-xs font-medium text-muted">Former COO</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h2 class="text-2xl font-bold text-text mb-6">Contact Us</h2>
        <div class="rounded-xl border border-border bg-white p-6 sm:p-8">
          <p class="text-sm text-muted leading-relaxed mb-4">
            Have a question, correction, or suggestion? We'd love to hear from you. We take accuracy seriously and are always looking to improve our research.
          </p>
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-light text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-text">Email</p>
              <a href="mailto:contact@creditdoc.co" class="text-sm text-primary hover:underline">contact@creditdoc.co</a>
            </div>
          </div>
          <p class="mt-6 text-xs text-muted">
            CreditDoc is a property of Cosmic Phoenix LLC, a Wyoming limited liability company.
          </p>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>
