---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Do Not Sell My Personal Information",
  "description": "CreditDoc's commitment to your privacy. Learn about your California Consumer Privacy Act (CCPA) rights.",
  "url": "https://creditdoc.co/do-not-sell/",
  "datePublished": "2026-03-22",
  "dateModified": "2026-03-22"
};
---

<BaseLayout
  title="Do Not Sell My Personal Information | CCPA Rights - CreditDoc"
  description="CreditDoc does not sell your personal information. Learn about your rights under the California Consumer Privacy Act (CCPA/CPRA)."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-white border-b border-border">
    <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8 text-center">
      <span class="inline-block rounded-full bg-primary-light px-4 py-1.5 text-xs font-semibold text-primary uppercase tracking-wider mb-6">Your Privacy Rights</span>
      <h1 class="text-4xl font-bold text-text sm:text-5xl">Do Not Sell My Personal Information</h1>
      <p class="mt-6 text-lg text-muted leading-relaxed max-w-2xl mx-auto">
        Your privacy matters. This page explains your rights under the California Consumer Privacy Act (CCPA) and the California Privacy Rights Act (CPRA).
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="space-y-12">

      <!-- Key Statement -->
      <div class="rounded-xl border-2 border-primary/30 bg-primary-light/30 p-6 sm:p-8">
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 mt-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div>
            <h2 class="text-xl font-bold text-text">CreditDoc Does Not Sell Your Personal Information</h2>
            <p class="mt-3 text-base text-text leading-relaxed">
              CreditDoc, operated by Cosmic Phoenix LLC, does not sell, rent, or trade your personal information to third parties for monetary or other valuable consideration. This has been our practice since our founding, and we are committed to maintaining it.
            </p>
          </div>
        </div>
      </div>

      <!-- Your Rights -->
      <div>
        <h2 class="text-2xl font-bold text-text mb-6">Your Rights Under the CCPA/CPRA</h2>
        <p class="text-sm text-muted leading-relaxed mb-6">
          If you are a California resident, you have the following rights regarding your personal information:
        </p>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-xl border border-border bg-white p-5">
            <h3 class="text-base font-semibold text-text mb-2">Right to Know</h3>
            <p class="text-sm text-muted leading-relaxed">You can request that we disclose what personal information we collect, use, and share about you.</p>
          </div>
          <div class="rounded-xl border border-border bg-white p-5">
            <h3 class="text-base font-semibold text-text mb-2">Right to Delete</h3>
            <p class="text-sm text-muted leading-relaxed">You can request that we delete any personal information we have collected from you, subject to certain exceptions.</p>
          </div>
          <div class="rounded-xl border border-border bg-white p-5">
            <h3 class="text-base font-semibold text-text mb-2">Right to Correct</h3>
            <p class="text-sm text-muted leading-relaxed">You can request that we correct inaccurate personal information that we maintain about you.</p>
          </div>
          <div class="rounded-xl border border-border bg-white p-5">
            <h3 class="text-base font-semibold text-text mb-2">Right to Non-Discrimination</h3>
            <p class="text-sm text-muted leading-relaxed">We will not discriminate against you for exercising any of your CCPA/CPRA rights.</p>
          </div>
        </div>
      </div>

      <!-- What We Collect -->
      <div>
        <h2 class="text-2xl font-bold text-text mb-6">What Information We Collect</h2>
        <div class="rounded-xl border border-border bg-white p-6">
          <p class="text-sm text-muted leading-relaxed mb-4">
            CreditDoc is a comparison and research website. We collect minimal personal information:
          </p>
          <ul class="space-y-3">
            <li class="flex items-start gap-3 text-sm text-muted">
              <span class="text-primary font-bold mt-0.5">1.</span>
              <span><strong class="text-text">Automatically collected:</strong> IP address, browser type, device information, pages visited, and referring URL via standard web analytics (Google Analytics).</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-muted">
              <span class="text-primary font-bold mt-0.5">2.</span>
              <span><strong class="text-text">Voluntarily provided:</strong> Email address if you contact us via our contact form.</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-muted">
              <span class="text-primary font-bold mt-0.5">3.</span>
              <span><strong class="text-text">Cookies:</strong> We use cookies for analytics and site functionality. See our <a href="/privacy/" class="text-primary hover:underline">Privacy Policy</a> for full details.</span>
            </li>
          </ul>
          <p class="mt-4 text-sm text-muted leading-relaxed">
            We do <strong class="text-text">not</strong> collect Social Security numbers, financial account numbers, credit scores, or any other sensitive financial data.
          </p>
        </div>
      </div>

      <!-- Third-Party Sharing -->
      <div>
        <h2 class="text-2xl font-bold text-text mb-6">Third-Party Sharing</h2>
        <div class="rounded-xl border border-border bg-white p-6">
          <p class="text-sm text-muted leading-relaxed mb-4">
            When you click an affiliate link on CreditDoc and visit a third-party website, that company may collect information about you under their own privacy policy. CreditDoc does not control what those third parties do with your data.
          </p>
          <p class="text-sm text-muted leading-relaxed">
            We share anonymized, aggregated analytics data with our analytics provider (Google Analytics). This data cannot be used to identify you personally.
          </p>
        </div>
      </div>

      <!-- How to Exercise -->
      <div>
        <h2 class="text-2xl font-bold text-text mb-6">How to Exercise Your Rights</h2>
        <div class="rounded-xl border border-primary/20 bg-primary-light/20 p-6">
          <p class="text-sm text-muted leading-relaxed mb-4">
            To exercise any of the rights described above, please contact us:
          </p>
          <div class="flex items-center gap-3 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 20 20" fill="currentColor">
              <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
              <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
            </svg>
            <a href="mailto:contact@creditdoc.co" class="text-sm text-primary font-medium hover:underline">contact@creditdoc.co</a>
          </div>
          <p class="text-sm text-muted leading-relaxed">
            Please include "CCPA Request" in the subject line. We will verify your identity and respond within 45 days as required by law. You may also designate an authorized agent to make a request on your behalf.
          </p>
        </div>
      </div>

      <!-- Additional State Laws -->
      <div>
        <h2 class="text-2xl font-bold text-text mb-6">Other State Privacy Laws</h2>
        <div class="rounded-xl border border-border bg-white p-6">
          <p class="text-sm text-muted leading-relaxed mb-4">
            In addition to the CCPA/CPRA, several other states have enacted consumer privacy laws. While CreditDoc's practices already comply with these standards (we do not sell personal information), residents of the following states have similar rights:
          </p>
          <ul class="space-y-2 text-sm text-muted">
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 text-primary shrink-0" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span><strong class="text-text">Virginia</strong> — Virginia Consumer Data Protection Act (VCDPA)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 text-primary shrink-0" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span><strong class="text-text">Colorado</strong> — Colorado Privacy Act (CPA)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 text-primary shrink-0" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span><strong class="text-text">Connecticut</strong> — Connecticut Data Privacy Act (CTDPA)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 text-primary shrink-0" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span><strong class="text-text">Utah</strong> — Utah Consumer Privacy Act (UCPA)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 text-primary shrink-0" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span><strong class="text-text">Texas</strong> — Texas Data Privacy and Security Act (TDPSA)</span>
            </li>
          </ul>
          <p class="mt-4 text-sm text-muted leading-relaxed">
            Residents of any state may contact us to exercise their privacy rights using the email address above.
          </p>
        </div>
      </div>

      <!-- Last Updated -->
      <div class="text-center">
        <p class="text-xs text-muted">
          Last updated: March 22, 2026 | CreditDoc is a property of Cosmic Phoenix LLC, a Wyoming limited liability company.
        </p>
      </div>

    </div>
  </section>
</BaseLayout>
