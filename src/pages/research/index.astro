---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Research — CreditDoc";
const description = "Original research and data reports on consumer lending, credit repair, and financial access in America.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "CreditDoc Research",
  "description": description,
  "url": "https://www.creditdoc.co/research/",
  "publisher": { "@type": "Organization", "name": "CreditDoc", "url": "https://www.creditdoc.co" }
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <nav class="max-w-4xl mx-auto px-4 pt-6 pb-2" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2 text-sm text-muted">
      <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
      <li class="text-border">/</li>
      <li class="text-text font-medium">Research</li>
    </ol>
  </nav>

  <div class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-text mb-3">Research</h1>
    <p class="text-lg text-muted max-w-2xl mb-8">
      Original data analysis and reports on consumer lending, credit access, and financial services in America.
    </p>

    <div class="space-y-4">
      <a href="/research/state-of-subprime-lending-2026/" class="glass-card p-6 block hover:border-primary transition-all group">
        <span class="text-xs font-semibold text-primary uppercase tracking-wider">March 2026</span>
        <h2 class="text-xl font-bold text-text mt-2 group-hover:text-primary transition-colors">State of Subprime Lending in America 2026</h2>
        <p class="text-muted mt-2">
          Analysis of 28,000+ consumer lending companies across 50 states. Examines credit access, payday lending regulations, poverty rates, and financial vulnerability state by state.
        </p>
        <span class="text-sm text-primary mt-3 inline-block">Read the report &rarr;</span>
      </a>
    </div>
  </div>
</BaseLayout>
