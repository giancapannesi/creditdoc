---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSpecials, getLenderBySlug, getBbbClass } from '../utils/data';

const specials = getSpecials();
---

<BaseLayout
  title="Current Deals & Promotions | CreditDoc"
  description="Browse current deals, discounts, and promotions from top credit repair companies. Find promo codes and special offers."
>
  <!-- Header -->
  <section class="bg-white border-b border-border">
    <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <div class="inline-flex items-center px-3 py-1 rounded-full bg-warning-light text-warning text-xs font-semibold mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.5 3A2.5 2.5 0 003 5.5v2.879a2.5 2.5 0 00.732 1.767l6.5 6.5a2.5 2.5 0 003.536 0l2.878-2.878a2.5 2.5 0 000-3.536l-6.5-6.5A2.5 2.5 0 008.38 3H5.5zM6 7a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
          </svg>
          Updated March 2026
        </div>
        <h1 class="text-2xl sm:text-3xl font-bold text-text">Current Deals & Promotions</h1>
        <p class="mt-3 text-muted leading-relaxed">
          Save money on credit repair services with these current promotions, discounts, and special offers.
        </p>
      </div>
    </div>
  </section>

  <!-- Deals Grid -->
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    {specials.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {specials.map(special => {
          const lender = getLenderBySlug(special.lender_slug);
          const bbbCls = lender ? getBbbClass(lender.company_info.bbb_rating) : '';
          return (
            <div class="glass-card p-6 flex flex-col">
              <!-- Header -->
              <div class="flex items-start gap-4 mb-4">
                <div class="w-12 h-12 rounded-xl bg-bg-alt border border-border flex items-center justify-center shrink-0 overflow-hidden">
                  {lender?.logo_url ? (
                    <img src={lender.logo_url} alt={`${special.lender_name} logo`} class="w-8 h-8 object-contain" loading="lazy" />
                  ) : (
                    <span class="text-sm font-bold text-primary">{special.lender_name.charAt(0)}</span>
                  )}
                </div>
                <div class="min-w-0">
                  <h2 class="text-base font-semibold text-text">{special.lender_name}</h2>
                  {lender && (
                    <div class="flex items-center gap-2 mt-1">
                      <span class:list={['inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold', bbbCls]}>
                        BBB: {lender.company_info.bbb_rating}
                      </span>
                    </div>
                  )}
                </div>
              </div>

              <!-- Deal Badge -->
              <div class="inline-flex self-start items-center px-3 py-1.5 rounded-lg bg-primary-light border border-primary/20 mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary mr-1.5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M5.5 3A2.5 2.5 0 003 5.5v2.879a2.5 2.5 0 00.732 1.767l6.5 6.5a2.5 2.5 0 003.536 0l2.878-2.878a2.5 2.5 0 000-3.536l-6.5-6.5A2.5 2.5 0 008.38 3H5.5zM6 7a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
                </svg>
                <span class="text-sm font-semibold text-primary">{special.deal_title}</span>
              </div>

              <!-- Description -->
              <p class="text-sm text-muted leading-relaxed flex-1">{special.deal_description}</p>

              <!-- Promo Code -->
              {special.promo_code && (
                <div class="mt-4 flex items-center gap-2">
                  <span class="text-xs text-muted">Promo Code:</span>
                  <code class="inline-flex items-center px-3 py-1.5 rounded-lg bg-warning-light border border-warning/20 text-sm font-mono font-bold text-warning tracking-wider">
                    {special.promo_code}
                  </code>
                  <button
                    class="copy-code-btn text-xs text-primary hover:text-primary-hover transition-colors"
                    data-code={special.promo_code}
                    title="Copy promo code"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                      <path d="M7 3.5A1.5 1.5 0 018.5 2h3.879a1.5 1.5 0 011.06.44l3.122 3.12A1.5 1.5 0 0117 6.622V12.5a1.5 1.5 0 01-1.5 1.5h-1v-3.379a3 3 0 00-.879-2.121L10.5 5.379A3 3 0 008.379 4.5H7v-1z"/>
                      <path d="M4.5 6A1.5 1.5 0 003 7.5v9A1.5 1.5 0 004.5 18h7a1.5 1.5 0 001.5-1.5v-5.879a1.5 1.5 0 00-.44-1.06L9.44 6.439A1.5 1.5 0 008.378 6H4.5z"/>
                    </svg>
                  </button>
                </div>
              )}

              <!-- Discount -->
              {special.discount_percent > 0 && (
                <div class="mt-3">
                  <span class="inline-flex items-center px-3 py-1 rounded-full bg-positive-light text-positive text-sm font-semibold">
                    {special.discount_percent}% OFF
                  </span>
                </div>
              )}

              <!-- Validity -->
              {special.valid_until && (
                <p class="mt-3 text-xs text-muted">
                  Valid until {new Date(special.valid_until).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                </p>
              )}

              <!-- CTAs -->
              <div class="mt-4 flex gap-2">
                {lender && (
                  <a
                    href={`/review/${lender.slug}/`}
                    class="flex-1 text-center px-4 py-2.5 text-sm font-medium rounded-lg border border-border text-text hover:bg-bg-alt transition-colors"
                  >
                    Read Review
                  </a>
                )}
                <a
                  href={special.url}
                  target="_blank"
                  rel="noopener noreferrer nofollow"
                  class="flex-1 text-center px-4 py-2.5 text-sm font-medium rounded-lg bg-primary text-white hover:bg-primary-hover transition-colors"
                >
                  Get Deal
                </a>
              </div>
            </div>
          );
        })}
      </div>
    ) : (
      <div class="glass-card p-12 text-center">
        <div class="mx-auto w-16 h-16 rounded-2xl bg-bg-alt flex items-center justify-center mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-muted" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.5 3A2.5 2.5 0 003 5.5v2.879a2.5 2.5 0 00.732 1.767l6.5 6.5a2.5 2.5 0 003.536 0l2.878-2.878a2.5 2.5 0 000-3.536l-6.5-6.5A2.5 2.5 0 008.38 3H5.5zM6 7a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
          </svg>
        </div>
        <h2 class="text-lg font-semibold text-text">No Active Deals</h2>
        <p class="mt-2 text-sm text-muted">Check back soon for new promotions and special offers.</p>
        <a
          href="/"
          class="mt-6 inline-flex items-center px-5 py-2.5 rounded-lg bg-primary text-white text-sm font-medium hover:bg-primary-hover transition-colors"
        >
          Browse All Companies
        </a>
      </div>
    )}
  </section>

  <!-- Affiliate Disclosure -->
  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="rounded-lg bg-bg-alt border border-border p-4">
      <p class="text-xs text-muted leading-relaxed">
        <strong class="text-text">Affiliate Disclosure:</strong> CreditDoc may earn a commission when you click links to the services featured on this page. Our editorial team independently verifies all deals and promotions. <a href="/disclosure/" class="text-primary hover:underline">Learn more</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<script>
  // Copy promo code functionality
  document.querySelectorAll('.copy-code-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const code = btn.dataset.code;
      if (!code) return;
      try {
        await navigator.clipboard.writeText(code);
        const originalHTML = btn.innerHTML;
        btn.innerHTML = '<span class="text-positive text-xs font-medium">Copied!</span>';
        setTimeout(() => {
          btn.innerHTML = originalHTML;
        }, 2000);
      } catch (e) {
        // Fallback for older browsers
        const textarea = document.createElement('textarea');
        textarea.value = code;
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        document.body.removeChild(textarea);
      }
    });
  });
</script>
