---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LenderCard from '../../components/LenderCard.astro';
import { getAllBrands, getLendersByBrand, getBrandInfo } from '../../utils/data';
import type { Lender } from '../../utils/data';

export function getStaticPaths() {
  const brands = getAllBrands();
  return brands.map(brand => ({
    params: { brand: brand.slug },
  }));
}

const { brand: brandSlug } = Astro.params;
const brandInfo = getBrandInfo(brandSlug!);

// Safety: should never happen if getStaticPaths is correct
if (!brandInfo) {
  return Astro.redirect('/404');
}

const lenders = getLendersByBrand(brandSlug!);
const locationCount = lenders.length;

// Group lenders by state
const byState = new Map<string, Lender[]>();
for (const l of lenders) {
  const state = l.company_info?.state || 'Unknown';
  if (!byState.has(state)) byState.set(state, []);
  byState.get(state)!.push(l);
}

// Sort states alphabetically
const sortedStates = Array.from(byState.keys()).sort();

// Compute stats
const statesCount = sortedStates.length;

// Build JSON-LD
const canonicalUrl = `https://www.creditdoc.co/brand/${brandSlug}/`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: brandInfo.display_name,
    url: brandInfo.official_website ?? undefined,
    description: brandInfo.summary_short,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `${brandInfo.display_name} Locations`,
    description: `Browse all ${locationCount} ${brandInfo.display_name} locations across ${statesCount} states.`,
    url: canonicalUrl,
    numberOfItems: locationCount,
    provider: {
      '@type': 'Organization',
      name: 'CreditDoc',
      url: 'https://www.creditdoc.co',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.creditdoc.co/' },
      { '@type': 'ListItem', position: 2, name: 'Brands', item: 'https://www.creditdoc.co/' },
      { '@type': 'ListItem', position: 3, name: brandInfo.display_name, item: canonicalUrl },
    ],
  },
];

const title = `${brandInfo.display_name} Locations — Find Your Nearest Branch | CreditDoc`;
const description = `Browse all ${locationCount} ${brandInfo.display_name} locations across ${statesCount} states. Find hours, addresses, and contact info for each branch.`;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonicalUrl}
  jsonLd={jsonLd}
>
  <!-- Breadcrumbs -->
  <nav class="mx-auto max-w-7xl px-4 pt-6 sm:px-6 lg:px-8" aria-label="Breadcrumb">
    <ol class="flex items-center gap-1.5 text-sm text-muted">
      <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
      <li><span class="mx-1">/</span></li>
      <li><a href="/" class="hover:text-primary transition-colors">Brands</a></li>
      <li><span class="mx-1">/</span></li>
      <li class="text-text font-medium">{brandInfo.display_name}</li>
    </ol>
  </nav>

  <!-- Header -->
  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="lg:flex lg:gap-10">
      <!-- Main content -->
      <div class="flex-1">
        <h1 class="text-2xl sm:text-3xl font-bold text-text">
          {brandInfo.display_name} Locations
        </h1>
        <p class="mt-3 text-muted leading-relaxed">
          {brandInfo.summary_short}
        </p>

        <!-- Stats bar -->
        <div class="mt-5 flex flex-wrap gap-4">
          <div class="glass-card px-4 py-2 text-sm">
            <span class="font-semibold text-text">{locationCount}</span>
            <span class="text-muted ml-1">locations</span>
          </div>
          <div class="glass-card px-4 py-2 text-sm">
            <span class="font-semibold text-text">{statesCount}</span>
            <span class="text-muted ml-1">states</span>
          </div>
          <div class="glass-card px-4 py-2 text-sm">
            <span class="text-muted">Category:</span>
            <a
              href={`/categories/${brandInfo.category}/`}
              class="ml-1 font-semibold text-primary hover:underline"
            >
              {brandInfo.category.replace(/-/g, ' ')}
            </a>
          </div>
        </div>

        <!-- State-grouped locations -->
        <div class="mt-8 space-y-4">
          {sortedStates.map(state => {
            const stateLenders = byState.get(state)!;
            return (
              <details class="glass-card" open={sortedStates.indexOf(state) < 3}>
                <summary class="cursor-pointer px-4 py-3 flex items-center justify-between">
                  <span class="font-semibold text-text">
                    {state}
                    <span class="ml-2 text-sm font-normal text-muted">
                      ({stateLenders.length} {stateLenders.length === 1 ? 'location' : 'locations'})
                    </span>
                  </span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-muted flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <div class="px-4 pb-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-2">
                  {stateLenders.map(lender => (
                    <LenderCard lender={lender} />
                  ))}
                </div>
              </details>
            );
          })}
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="mt-8 lg:mt-0 lg:w-72 flex-shrink-0">
        <div class="glass-card p-5 space-y-4">
          <h2 class="text-base font-semibold text-text">About {brandInfo.display_name}</h2>
          <div class="text-sm text-muted leading-relaxed prose prose-sm max-w-none">
            {brandInfo.summary_long.split('\n\n').map((para: string) => (
              <p>{para}</p>
            ))}
          </div>
          {brandInfo.official_website && (
            <a
              href={brandInfo.official_website}
              target="_blank"
              rel="noopener noreferrer nofollow"
              class="inline-flex items-center gap-1.5 text-sm text-primary hover:underline"
            >
              Official website
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          )}
          {brandInfo.parent_company && (
            <p class="text-xs text-muted">
              Parent company: <span class="font-medium text-text">{brandInfo.parent_company}</span>
            </p>
          )}
          <div class="pt-2 border-t border-border">
            <a
              href={`/categories/${brandInfo.category}/`}
              class="text-sm text-primary hover:underline"
            >
              Browse all {brandInfo.category.replace(/-/g, ' ')} companies
            </a>
          </div>
        </div>

        <!-- FAQ -->
        {brandInfo.faq && brandInfo.faq.length > 0 && (
          <div class="glass-card p-5 mt-4 space-y-3">
            <h2 class="text-base font-semibold text-text">Common Questions</h2>
            <dl class="space-y-4">
              {brandInfo.faq.map((item: { q: string; a: string }) => (
                <div>
                  <dt class="text-sm font-medium text-text">{item.q}</dt>
                  <dd class="mt-1 text-sm text-muted">{item.a}</dd>
                </div>
              ))}
            </dl>
          </div>
        )}
      </aside>
    </div>
  </section>
</BaseLayout>
