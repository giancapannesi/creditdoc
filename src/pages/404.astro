---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCategories } from '../utils/data';

const categories = getCategories().slice(0, 8);
---

<BaseLayout
  title="Page Not Found | CreditDoc"
  description="The page you're looking for doesn't exist. Browse our credit repair, personal loan, and debt relief resources."
  noindex={true}
>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 text-center">
    <h1 class="text-4xl font-bold text-text">Page Not Found</h1>
    <p class="mt-4 text-lg text-muted max-w-xl mx-auto">
      The page you're looking for may have been moved or no longer exists. Try one of the links below.
    </p>

    <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 max-w-4xl mx-auto">
      <a href="/best/best-credit-repair-companies/" class="glass-card p-4 hover:border-primary transition-colors">
        <p class="text-sm font-semibold text-text">Best Credit Repair</p>
        <p class="text-xs text-muted mt-1">Compare top-rated companies</p>
      </a>
      <a href="/best/best-personal-loans-bad-credit/" class="glass-card p-4 hover:border-primary transition-colors">
        <p class="text-sm font-semibold text-text">Personal Loans</p>
        <p class="text-xs text-muted mt-1">Bad credit options</p>
      </a>
      <a href="/best/best-debt-consolidation-loans/" class="glass-card p-4 hover:border-primary transition-colors">
        <p class="text-sm font-semibold text-text">Debt Consolidation</p>
        <p class="text-xs text-muted mt-1">Simplify your payments</p>
      </a>
      <a href="/financial-wellness/" class="glass-card p-4 hover:border-primary transition-colors">
        <p class="text-sm font-semibold text-text">Financial Wellness</p>
        <p class="text-xs text-muted mt-1">Free guides & education</p>
      </a>
    </div>

    <div class="mt-8">
      <h2 class="text-lg font-semibold text-text mb-4">Browse by Category</h2>
      <div class="flex flex-wrap justify-center gap-2">
        {categories.map(cat => (
          <a
            href={`/categories/${cat.slug}/`}
            class="inline-flex items-center px-3 py-1.5 rounded-full border border-border text-sm text-muted hover:text-primary hover:border-primary transition-colors"
          >
            {cat.name}
          </a>
        ))}
      </div>
    </div>

    <p class="mt-10 text-sm text-muted">
      <a href="/" class="text-primary hover:underline font-medium">Return to homepage</a>
    </p>
  </section>
</BaseLayout>
