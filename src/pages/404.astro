---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCategories } from '../utils/data';

const TARGET_SLUGS = ['credit-repair', 'personal-loans', 'debt-relief', 'credit-unions', 'banking', 'business-loans'];
const allCategories = getCategories();
const categories = TARGET_SLUGS
  .map(slug => allCategories.find(c => c.slug === slug))
  .filter(Boolean);

const CATEGORY_ICONS: Record<string, string> = {
  'credit-repair': '🛡️',
  'personal-loans': '💵',
  'debt-relief': '⚖️',
  'credit-unions': '🤝',
  'banking': '🏦',
  'business-loans': '💼',
};
---

<BaseLayout
  title="Page Not Found (404) | CreditDoc"
  description="The page you're looking for may have moved or no longer exists. Browse CreditDoc's guides on credit repair, loans, debt relief, and banking."
  canonical="https://www.creditdoc.co/404"
  noindex={true}
>
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto">
      <p class="text-6xl font-bold text-primary mb-4">404</p>
      <h1 class="text-2xl sm:text-3xl font-bold text-text mb-4">We couldn't find that page.</h1>
      <p class="text-muted leading-relaxed">
        The page you're looking for may have moved or no longer exists.
        Here's where to find what you need.
      </p>
    </div>

    <div class="mt-8 max-w-lg mx-auto">
      <form action="/search" method="get" class="flex gap-2">
        <label for="q" class="sr-only">Search</label>
        <input
          id="q"
          name="q"
          type="search"
          placeholder="Search lenders, guides, answers…"
          aria-label="Search CreditDoc"
          class="flex-1 rounded-lg border border-border bg-bg-alt px-4 py-2.5 text-sm text-text placeholder:text-muted focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
        />
        <button
          type="submit"
          class="rounded-lg bg-primary px-4 py-2.5 text-sm font-semibold text-white hover:bg-primary-hover transition-colors"
        >
          Search
        </button>
      </form>
    </div>

    <div class="mt-12">
      <h2 class="text-lg font-semibold text-text text-center mb-6">Browse by Category</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {categories.map(cat => (
          <a href={`/categories/${cat.slug}/`} class="glass-card p-5 block hover:border-primary transition-colors group">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-2xl" aria-hidden="true">{CATEGORY_ICONS[cat.slug] || '📄'}</span>
              <h3 class="text-base font-semibold text-text group-hover:text-primary transition-colors">{cat.name}</h3>
            </div>
            <p class="text-sm text-muted leading-relaxed line-clamp-2">{cat.description}</p>
          </a>
        ))}
      </div>
    </div>

    <div class="mt-12 max-w-xl mx-auto">
      <h2 class="text-lg font-semibold text-text mb-4">Top Guides</h2>
      <ul class="space-y-3">
        <li>
          <a href="/best/best-credit-repair-companies/" class="text-primary hover:underline font-medium text-sm">
            Best Credit Repair Companies
          </a>
        </li>
        <li>
          <a href="/best/best-personal-loan-lenders/" class="text-primary hover:underline font-medium text-sm">
            Best Personal Loan Lenders
          </a>
        </li>
        <li>
          <a href="/best/best-debt-relief-companies/" class="text-primary hover:underline font-medium text-sm">
            Best Debt Relief Companies
          </a>
        </li>
        <li>
          <a href="/best/best-credit-builder-loans/" class="text-primary hover:underline font-medium text-sm">
            Best Credit Builder Loans
          </a>
        </li>
        <li>
          <a href="/best/best-credit-monitoring-services/" class="text-primary hover:underline font-medium text-sm">
            Best Credit Monitoring Services
          </a>
        </li>
      </ul>
    </div>

    <div class="mt-10 text-center text-sm text-muted">
      Need help? <a href="/about/" class="text-primary hover:underline font-medium">Contact our team</a>.
    </div>

    <div class="mt-8 text-center">
      <a
        href="/"
        class="inline-flex items-center px-6 py-3 rounded-lg bg-primary text-white text-sm font-semibold hover:bg-primary-hover transition-colors"
      >
        Back to CreditDoc Home
        <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd"/>
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
