---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Terms of Service",
  "description": "Terms of Service for CreditDoc.co, an informational comparison website for credit repair and financial services.",
  "url": "https://creditdoc.co/terms/",
  "datePublished": "2026-03-19",
  "dateModified": "2026-04-04"
};
---

<BaseLayout
  title="Terms of Service | CreditDoc"
  description="Terms of Service governing your use of CreditDoc.co. Read our terms regarding site usage, disclaimers, intellectual property, limitation of liability, and more."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-white border-b border-border">
    <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8 text-center">
      <span class="inline-block rounded-full bg-bg-alt px-4 py-1.5 text-xs font-semibold text-muted uppercase tracking-wider mb-6">Legal</span>
      <h1 class="text-4xl font-bold text-text sm:text-5xl">Terms of Service</h1>
      <p class="mt-6 text-base text-muted leading-relaxed max-w-2xl mx-auto">
        Effective Date: March 19, 2026 &middot; Last Updated: April 4, 2026
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="space-y-10">

      <div class="rounded-xl border border-border bg-white p-6 sm:p-8">
        <p class="text-sm text-muted leading-relaxed">
          These Terms of Service ("Terms") govern your access to and use of the website located at <strong>creditdoc.co</strong> (the "Site"), which is owned and operated by Cosmic Phoenix LLC, a Wyoming limited liability company ("Company," "we," "us," or "our"). By accessing or using the Site, you agree to be bound by these Terms. If you do not agree to these Terms, you must not use the Site.
        </p>
      </div>

      <!-- 1. Acceptance of Terms -->
      <div>
        <h2 class="text-xl font-bold text-text mb-4">1. Acceptance of Terms</h2>
        <div class="rounded-xl border border-border bg-white p-6 sm:p-8">
          <p class="text-sm text-muted leading-relaxed mb-3">
            By accessing, browsing, or using the Site in any manner, you acknowledge that you have read, understood, and agree to be bound by these Terms, as well as our <a href="/privacy/" class="text-primary hover:underline">Privacy Policy</a> and <a href="/disclosure/" class="text-primary hover:underline">Affiliate Disclosure</a>, which are incorporated herein by reference.
          </p>
          <p class="text-sm text-muted leading-relaxed">
            We reserve the right to modify these Terms at any time. Changes will be effective immediately upon posting to the Site. Your continued use of the Site after any modifications constitutes your acceptance of the revised Terms. It is your responsibility to review these Terms periodically.
          </p>
        </div>
      </div>

      <!-- 2. Description of Service -->
      <div>
        <h2 class="text-xl font-bold text-text mb-4">2. Description of Service</h2>
        <div class="rounded-xl border border-border bg-white p-6 sm:p-8 space-y-4">
          <p class="text-sm text-muted leading-relaxed">
            CreditDoc is an <strong>informational comparison website</strong>. We provide reviews, ratings, comparisons, and educational content about credit repair companies, personal loan lenders, debt relief services, and other financial products and services.
          </p>
          <div class="rounded-lg border border-negative/30 bg-negative-light/30 p-4">
            <p class="text-sm text-text font-semibold mb-2">CreditDoc is NOT:</p>
            <ul class="ml-4 list-disc text-sm text-text leading-relaxed space-y-1">
              <li>A credit repair organization or credit repair company</li>
              <li>A lender, bank, credit union, or financial institution</li>
              <li>A financial advisor, investment advisor, or financial planner</li>
              <li>A credit counseling agency</li>
              <li>A law firm or provider of legal advice</li>
              <li>A debt collector or debt relief provider</li>
            </ul>
          </div>
          <p class="text-sm text-muted leading-relaxed">
            We do not originate loans, provide credit repair services, offer financial advice, or act as an intermediary between consumers and service providers. The information on the Site is provided for educational and informational purposes only. See our <a href="/disclaimer/" class="text-primary hover:underline">Financial Disclaimer</a> for full details.
          </p>
        </div>
      </div>

      <!-- 3. User Eligibility -->
      <div>
        <h2 class="text-xl font-bold text-text mb-4">3. User Eligibility</h2>
        <div class="rounded-xl border border-border bg-white p-6 sm:p-8">
          <p class="text-sm text-muted leading-relaxed">
            The Site is intended for use by individuals who are at least 18 years of age and are residents of the United States. By using the Site, you represent and warrant that you are at least 18 years old. If you are under 18, you must not use the Site. We do not knowingly collect information from or provide services to individuals under the age of 18.
          </p>
        </div>
      </div>

      <!-- 4. Accuracy of Information -->
      <div>
        <h2 class="text-xl font-bold text-text mb-4">4. Accuracy of Information</h2>
        <div class="rounded-xl border border-border bg-white p-6 sm:p-8 space-y-4">
