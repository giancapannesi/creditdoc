---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBar from '../components/SearchBar.astro';
import { getAllLenders, US_STATES, STATE_ABBREVIATIONS } from '../utils/data';

const lenders = getAllLenders();

// Lightweight data for client-side filtering + card rendering
const lendersData = lenders.map(l => ({
  s: l.slug,
  n: l.name,
  c: l.category,
  sc: l.subcategories,
  r: l.rating,
  mp: l.pricing.monthly_price,
  sf: l.pricing.setup_fee,
  bb: l.company_info.bbb_rating,
  mg: l.pricing.money_back_guarantee,
  fc: l.pricing.free_consultation,
  st: l.states_served,
  ct: l.cities_served,
  ds: l.description_short,
  bf: l.best_for,
  gr: (l as any).google_reviews_count || 0,
  qs: (l as any).quality_score || 0,
  en: (l as any).has_been_enriched || (l as any).data_source === 'enriched' || (l as any).data_source === 'editorial' || (l as any).data_source === 'verified' ? 1 : 0,
  sv: ((l as any).services || []).join(' ').toLowerCase(),
  lo: (l as any).logo_url || '',
}));

const stateEntries = US_STATES.map(state => ({
  name: state,
  abbr: STATE_ABBREVIATIONS[state] || '',
}));
---

<BaseLayout
  title="Search Credit Repair Companies by Location | CreditDoc"
  description="Search and filter credit repair companies by state, city, budget, and BBB rating. Find services available in your area."
>
  <!-- Header -->
  <section class="bg-white border-b border-border">
    <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 text-center">
      <h1 class="text-2xl sm:text-3xl font-bold text-text">Search Credit Repair Companies</h1>
      <p class="mt-2 text-muted">Find companies by location, budget, BBB rating, and more.</p>
    </div>
  </section>

  <!-- Search Bar Component -->
  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <SearchBar />
  </section>

  <!-- Results Header -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-4">
      <h2 id="results-heading" class="text-lg font-bold text-text">
        All Companies (<span id="results-count">{lenders.length}</span>)
      </h2>
      <select
        id="sort-select"
        class="rounded-lg border border-border bg-white px-3 py-2 text-sm text-text focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
      >
        <option value="rating">Highest Rated</option>
        <option value="reviews">Most Reviewed</option>
        <option value="price-low">Lowest Price</option>
        <option value="price-high">Highest Price</option>
        <option value="name">Alphabetical</option>
      </select>
    </div>
  </section>

  <!-- Results Grid (dynamically rendered) -->
  <section class="mx-auto max-w-7xl px-4 pb-16 sm:px-6 lg:px-8">
    <div id="results-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"></div>

    <!-- Load More -->
    <div id="load-more-wrap" class="hidden mt-8 text-center">
      <button
        id="load-more-btn"
        class="inline-flex items-center px-6 py-3 rounded-lg border-2 border-primary text-primary text-sm font-semibold hover:bg-primary-light transition-colors"
      >
        Show More Results
        <span id="load-more-count" class="ml-2 text-muted text-xs"></span>
      </button>
    </div>

    <!-- No Results State -->
    <div id="no-results" class="hidden glass-card p-12 text-center">
      <div class="mx-auto w-16 h-16 rounded-2xl bg-bg-alt flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-muted" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd"/>
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-text">No companies found</h3>
      <p class="mt-2 text-sm text-muted">Try adjusting your search filters or browsing all companies.</p>
      <button
        id="clear-filters-btn"
        class="mt-4 inline-flex items-center px-5 py-2.5 rounded-lg bg-primary text-white text-sm font-medium hover:bg-primary-hover transition-colors"
      >
        Clear All Filters
      </button>
    </div>
  </section>

  <!-- US States Map Section -->
  <section id="browse-by-state" class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="glass-card p-6">
      <h2 class="text-lg font-bold text-text mb-4 text-center">Browse by State</h2>
      <div class="grid grid-cols-5 sm:grid-cols-10 gap-2">
        {stateEntries.map(state => (
          <a
            href={`/search/?state=${encodeURIComponent(state.name)}`}
            class="flex items-center justify-center px-2 py-2 rounded-lg text-xs font-medium text-text bg-bg-alt hover:bg-primary-light hover:text-primary transition-colors border border-transparent hover:border-primary/20"
            title={state.name}
          >
            {state.abbr}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Client-side search engine -->
  <script define:vars={{ lendersData: JSON.stringify(lendersData) }}>
    const allLenders = JSON.parse(lendersData);
    const PAGE_SIZE = 48;
    let currentFiltered = [];
    let displayedCount = 0;

    // BBB class mapping
    function bbbClass(rating) {
      if (rating === 'A+') return 'bbb-a-plus';
      if (rating === 'A') return 'bbb-a';
      if (rating === 'B+') return 'bbb-b-plus';
      if (rating === 'B') return 'bbb-b';
      if (rating === 'C' || rating === 'C+' || rating === 'C-') return 'bbb-c';
      if (rating === 'F') return 'bbb-f';
      return 'bbb-nr';
    }

    // Format price
    function fmtPrice(p) {
      if (p === 0) return 'Free';
      return '$' + p.toFixed(2);
    }

    // Star SVG helper
    function starsSvg(rating) {
      const full = Math.floor(rating);
      const half = rating - full >= 0.25;
      let html = '<div class="flex items-center gap-1">';
      for (let i = 0; i < 5; i++) {
        if (i < full) {
          html += '<svg class="h-3.5 w-3.5 text-amber-400" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>';
        } else if (i === full && half) {
          html += '<svg class="h-3.5 w-3.5 text-amber-400" viewBox="0 0 20 20" fill="currentColor" style="clip-path:inset(0 50% 0 0)"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>';
        } else {
          html += '<svg class="h-3.5 w-3.5 text-gray-200" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>';
        }
      }
      html += '<span class="text-xs font-medium text-text ml-1">' + rating.toFixed(1) + '</span></div>';
      return html;
    }

    // Render a single card
    function renderCard(l) {
      const priceLabel = l.mp > 0 ? fmtPrice(l.mp) + '/mo' : 'Contact';
      const bestFor = l.bf.slice(0, 2).join(', ');
      const reviewCount = l.gr > 0 ? '<span class="text-xs text-muted ml-1">(' + l.gr.toLocaleString() + ' reviews)</span>' : '';
      return `<article class="glass-card p-5 sm:p-6 flex flex-col h-full">
        <div class="flex items-start gap-4">
          <div class="shrink-0 w-14 h-14 rounded-xl bg-bg-alt border border-border flex items-center justify-center overflow-hidden">
            <span class="text-lg font-bold text-primary">${l.n.charAt(0)}</span>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="text-lg font-semibold text-text truncate">${l.n}</h3>
            <p class="text-sm text-muted mt-0.5 line-clamp-2">${l.ds}</p>
          </div>
        </div>
        <div class="mt-4">${starsSvg(l.r)}${reviewCount}</div>
        <div class="mt-3 flex flex-wrap items-center gap-2">
          <span class="inline-flex items-center rounded-full bg-bg-alt px-3 py-1 text-xs font-semibold text-text border border-border">${priceLabel}</span>
          <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold ${bbbClass(l.bb)}">BBB: ${l.bb}</span>
          ${l.mg ? '<span class="inline-flex items-center rounded-full bg-positive/10 text-positive px-2.5 py-0.5 text-xs font-semibold">Guarantee</span>' : ''}
        </div>
        ${bestFor ? '<div class="mt-3"><p class="text-xs text-muted"><span class="font-medium">Best for:</span> ' + bestFor + '</p></div>' : ''}
        <div class="flex-1"></div>
        <div class="mt-5">
          <a href="/review/${l.s}/" class="flex items-center justify-center w-full rounded-lg bg-primary px-4 py-3 text-sm font-semibold text-white hover:bg-primary-hover transition-colors min-h-[44px]">
            View Details
            <svg xmlns="http://www.w3.org/2000/svg" class="ml-1.5 h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/></svg>
          </a>
        </div>
      </article>`;
    }

    function renderCards(lenders, startIdx, count) {
      const grid = document.getElementById('results-grid');
      if (!grid) return;
      const end = Math.min(startIdx + count, lenders.length);
      for (let i = startIdx; i < end; i++) {
        const div = document.createElement('div');
        div.innerHTML = renderCard(lenders[i]);
        grid.appendChild(div.firstElementChild);
      }
      displayedCount = end;
      updateLoadMore(lenders.length);
    }

    function updateLoadMore(total) {
      const wrap = document.getElementById('load-more-wrap');
      const countEl = document.getElementById('load-more-count');
      if (!wrap) return;
      const remaining = total - displayedCount;
      if (remaining > 0) {
        wrap.classList.remove('hidden');
        if (countEl) countEl.textContent = `(${remaining} more)`;
      } else {
        wrap.classList.add('hidden');
      }
    }

    function getParams() {
      const params = new URLSearchParams(window.location.search);
      return {
        mode: params.get('mode') || '',
        category: params.get('category') || '',
        q: (params.get('q') || '').toLowerCase().trim(),
        state: (params.get('state') || '').trim(),
        city: (params.get('city') || '').trim(),
        guarantee: params.get('guarantee') === '1',
        bbb_a_plus: params.get('bbb_a_plus') === '1',
        free_consult: params.get('free_consult') === '1',
        all_bureaus: params.get('all_bureaus') === '1',
        amount: params.get('amount') || '',
        term: params.get('term') || '',
        credit_score: params.get('credit_score') || '',
        max_apr: params.get('max_apr') || '',
        funding_speed: params.get('funding_speed') || '',
        no_origination_fee: params.get('no_origination_fee') === '1',
        soft_pull: params.get('soft_pull') === '1',
        direct_pay: params.get('direct_pay') === '1',
        bbb: params.get('bbb') || '',
        debt_amount: params.get('debt_amount') || '',
        debt_type: params.get('debt_type') || '',
        help_type: params.get('help_type') || '',
        issue: params.get('issue') || '',
        lender_type: params.get('lender_type') || '',
        monitor_need: params.get('monitor_need') || '',
        bureaus: params.get('bureaus') || '',
        credit_status: params.get('credit_status') || '',
        product_type: params.get('product_type') || '',
      };
    }

    function filterLenders() {
      const params = getParams();
      const resultsGrid = document.getElementById('results-grid');
      const noResults = document.getElementById('no-results');
      const resultsCount = document.getElementById('results-count');
      const resultsHeading = document.getElementById('results-heading');
      const sortSelect = document.getElementById('sort-select');

      if (!resultsGrid || !noResults || !resultsCount) return;

      const loanCategories = ['personal-loans', 'emergency-cash', 'payday-alternatives'];
      const isLoanMode = params.mode === 'loans' || loanCategories.indexOf(params.category) !== -1;

      // Category keyword aliases — so searching "credit repair" matches credit-repair
      const categoryAliases = {
        'credit repair': 'credit-repair',
        'fix my credit': 'credit-repair',
        'fix credit': 'credit-repair',
        'repair credit': 'credit-repair',
        'personal loan': 'personal-loans',
        'personal loans': 'personal-loans',
        'payday loan': 'payday-alternatives',
        'payday loans': 'payday-alternatives',
        'payday alternative': 'payday-alternatives',
        'emergency cash': 'emergency-cash',
        'emergency loan': 'emergency-cash',
        'quick cash': 'emergency-cash',
        'cash advance': 'emergency-cash',
        'debt relief': 'debt-relief',
        'debt consolidation': 'debt-relief',
        'debt help': 'debt-relief',
        'build credit': 'build-credit',
        'credit builder': 'build-credit',
        'credit monitoring': 'credit-monitoring',
        'credit score': 'credit-monitoring',
        'free credit': 'free-help',
        'free help': 'free-help',
        'pawn shop': 'pawn-shops',
        'pawn shops': 'pawn-shops',
        'title loan': 'emergency-cash',
        'title loans': 'emergency-cash',
        'bankruptcy': 'bankruptcy',
        'check cashing': 'check-cashing',
      };

      // Check if keyword maps to a category
      const matchedCategory = params.q ? categoryAliases[params.q] : null;

      // Filter
      currentFiltered = allLenders.filter(lender => {
        // Skip very low quality profiles — don't show garbage in results
        if (lender.qs < 3 && !lender.en) return false;

        if (params.category) {
          if (lender.c !== params.category && lender.sc.indexOf(params.category) === -1) return false;
        }
        if (params.q) {
          // If keyword matches a category, filter by that category
          if (matchedCategory) {
            if (lender.c !== matchedCategory && lender.sc.indexOf(matchedCategory) === -1) return false;
          } else {
            // Search across name, category, description, subcategories, best_for, and services
            const searchable = [lender.n, lender.c, lender.ds, lender.sv || '', ...lender.sc, ...lender.bf].join(' ').toLowerCase();
            if (!searchable.includes(params.q)) return false;
          }
        }
        if (params.state) {
          if (!lender.st.some(s => s.toLowerCase() === params.state.toLowerCase() || s.toLowerCase() === 'all' || s === 'All 50 States')) return false;
        }
        if (params.city) {
          const cityName = params.city.split(',')[0].trim().toLowerCase();
          if (!lender.ct.some(c => c.toLowerCase() === cityName) && !lender.st.some(s => s.toLowerCase() === 'all' || s === 'All 50 States')) return false;
        }
        if (params.guarantee && !lender.mg) return false;
        if (params.bbb_a_plus && lender.bb !== 'A+') return false;
        if (params.free_consult && !lender.fc) return false;
        if (params.bbb) {
          const b = lender.bb;
          if (params.bbb === 'a-plus' && b !== 'A+') return false;
          if (params.bbb === 'a-or-higher' && b !== 'A+' && b !== 'A') return false;
          if (params.bbb === 'b-or-higher' && ['C', 'C+', 'C-', 'D', 'F', 'NR'].indexOf(b) !== -1) return false;
        }
        return true;
      });

      // Sort — enriched and high-quality profiles first, then by selected sort
      const sortValue = sortSelect?.value || 'rating';
      currentFiltered.sort((a, b) => {
        // Enriched profiles always rank above non-enriched
        if (a.en !== b.en) return b.en - a.en;
        // Then by quality score tier (10+, 5-9, 3-4)
        const aTier = a.qs >= 10 ? 2 : a.qs >= 5 ? 1 : 0;
        const bTier = b.qs >= 10 ? 2 : b.qs >= 5 ? 1 : 0;
        if (aTier !== bTier) return bTier - aTier;
        // Then by user-selected sort
        if (sortValue === 'rating') return b.r - a.r;
        if (sortValue === 'reviews') return (b.gr || 0) - (a.gr || 0);
        if (sortValue === 'price-low') return a.mp - b.mp;
        if (sortValue === 'price-high') return b.mp - a.mp;
        if (sortValue === 'name') return a.n.localeCompare(b.n);
        return 0;
      });

      // Clear and render
      resultsGrid.innerHTML = '';
      displayedCount = 0;
      renderCards(currentFiltered, 0, PAGE_SIZE);

      // Update count
      resultsCount.textContent = String(currentFiltered.length);

      // Update heading
      let headingText = 'All Companies';
      if (params.category) {
        const categoryLabels = {
          'credit-repair': 'Credit Repair',
          'personal-loans': 'Personal Loans',
          'emergency-cash': 'Emergency Cash',
          'payday-alternatives': 'Payday Alternatives',
          'debt-relief': 'Debt Relief',
          'build-credit': 'Credit Building',
          'credit-monitoring': 'Credit Monitoring & Protection',
          'free-help': 'Free Help',
        };
        headingText = (categoryLabels[params.category] || params.category) + ' Results';
      } else if (params.state && params.city) {
        headingText = `Companies in ${params.city.split(',')[0].trim()}, ${params.state}`;
      } else if (params.state) {
        headingText = `Companies in ${params.state}`;
      } else if (params.city) {
        headingText = `Companies in ${params.city.split(',')[0].trim()}`;
      } else if (params.q) {
        headingText = `Results for "${params.q}"`;
      } else if (isLoanMode) {
        headingText = 'Loan Results';
      }

      if (resultsHeading) {
        resultsHeading.innerHTML = `${headingText} (<span id="results-count">${currentFiltered.length}</span>)`;
      }

      // Toggle no results
      if (currentFiltered.length === 0) {
        noResults.classList.remove('hidden');
        resultsGrid.classList.add('hidden');
      } else {
        noResults.classList.add('hidden');
        resultsGrid.classList.remove('hidden');
      }
    }

    // Run on page load
    filterLenders();

    // Listen for SearchBar custom submit event
    window.addEventListener('searchbar:submit', filterLenders);

    // Sort change
    document.getElementById('sort-select')?.addEventListener('change', filterLenders);

    // Load More
    document.getElementById('load-more-btn')?.addEventListener('click', () => {
      renderCards(currentFiltered, displayedCount, PAGE_SIZE);
    });

    // Clear filters
    document.getElementById('clear-filters-btn')?.addEventListener('click', () => {
      window.history.pushState({}, '', '/search/');
      const svcForm = document.getElementById('search-form-services');
      const loanForm = document.getElementById('search-form-loans');
      if (svcForm) svcForm.reset();
      if (loanForm) loanForm.reset();
      filterLenders();
    });
  </script>
</BaseLayout>
