---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: object;
  noindex?: boolean;
}

const { title: rawTitle, description: rawDesc, canonical, ogImage, jsonLd, noindex } = Astro.props;
const title = rawTitle.length > 60 ? rawTitle.slice(0, 57) + '...' : rawTitle;
const description = rawDesc.length > 155 ? rawDesc.slice(0, 152) + '...' : rawDesc;
const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).href;
const ogImg = ogImage || 'https://creditdoc.co/og-default.png';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="google-site-verification" content="TnwnBl_kT6XgHUFwFmR5JstL3ebCSAQf6iuoFwI-A-0" />
  <meta name="fo-verify" content="0bd4cd1e-5a7d-47e5-976c-c250d846b8ee" />
  <meta name="Impact-Site-Verification" content="df51c98d-280b-421a-85a8-0cf69f2fad48" />

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-ZBSCZ1GRXL"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-ZBSCZ1GRXL');
  </script>

  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <link rel="canonical" href={canonicalUrl} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImg} />
  <meta property="og:site_name" content="CreditDoc" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImg} />

  <!-- JSON-LD -->
  {jsonLd && (
    Array.isArray(jsonLd)
      ? jsonLd.map((item: any) => (
          <script type="application/ld+json" set:html={JSON.stringify(item)} />
        ))
      : <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}
</head>
<body class="min-h-screen flex flex-col">
  <Header />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
</body>
</html>
