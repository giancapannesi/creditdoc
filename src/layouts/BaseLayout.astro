---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleAuthor?: string;
  articleSection?: string;
  jsonLd?: object;
  noindex?: boolean;
}

const {
  title: rawTitle,
  description: rawDesc,
  canonical,
  ogImage,
  ogType,
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
  articleSection,
  jsonLd,
  noindex,
} = Astro.props;
const title = rawTitle.length > 65 ? rawTitle.slice(0, 62) + '...' : rawTitle;
const description = rawDesc.length > 160 ? rawDesc.slice(0, 157) + '...' : rawDesc;
const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).href;
const ogImg = ogImage || 'https://www.creditdoc.co/og-default.png';
const resolvedOgType = ogType || 'website';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="google-site-verification" content="TnwnBl_kT6XgHUFwFmR5JstL3ebCSAQf6iuoFwI-A-0" />
  <meta name="fo-verify" content="0bd4cd1e-5a7d-47e5-976c-c250d846b8ee" />
  <meta name="impact-site-verification" value="df51c98d-280b-421a-85a8-0cf69f2fad48" />
  <meta name="p:domain_verify" content="bf5a253c11c084976f9375cfe1a363b0" />

  <!-- Google Analytics — Consent Mode v2: default-deny until cookie banner accepted. -->
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('consent', 'default', {
      analytics_storage: 'denied',
      ad_storage: 'denied',
      ad_user_data: 'denied',
      ad_personalization: 'denied',
      wait_for_update: 500,
    });
    try {
      var prior = localStorage.getItem('cd_consent');
      if (prior === 'granted') {
        gtag('consent', 'update', { analytics_storage: 'granted' });
      }
    } catch (e) {}
    gtag('js', new Date());
    gtag('config', 'G-ZBSCZ1GRXL');
  </script>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-ZBSCZ1GRXL"></script>

  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <link rel="canonical" href={canonicalUrl} />

  <!-- DNS prefetch for external resources -->
  <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
  <link rel="dns-prefetch" href="https://icons.duckduckgo.com" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph -->
  <meta property="og:type" content={resolvedOgType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImg} />
  <meta property="og:site_name" content="CreditDoc" />
  {resolvedOgType === 'article' && articlePublishedTime && (
    <meta property="article:published_time" content={articlePublishedTime} />
  )}
  {resolvedOgType === 'article' && articleModifiedTime && (
    <meta property="article:modified_time" content={articleModifiedTime} />
  )}
  {resolvedOgType === 'article' && articleAuthor && (
    <meta property="article:author" content={articleAuthor} />
  )}
  {resolvedOgType === 'article' && articleSection && (
    <meta property="article:section" content={articleSection} />
  )}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImg} />

  <!-- JSON-LD -->
  {jsonLd && (
    Array.isArray(jsonLd)
      ? jsonLd.map((item: any) => (
          <script type="application/ld+json" set:html={JSON.stringify(item)} />
        ))
      : <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}
</head>
<body class="min-h-screen flex flex-col">
  <Header />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
  <CookieConsent />
</body>
</html>
