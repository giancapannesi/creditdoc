{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{"type": "host", "value": "creditdoc.co"}],
      "destination": "https://www.creditdoc.co/:path*",
      "permanent": true
    },
    {
      "source": "/categories/fix-my-credit/",
      "destination": "/categories/credit-repair/",
      "permanent": true
    },
    {
      "source": "/categories/fix-my-credit",
      "destination": "/categories/credit-repair/",
      "permanent": true
    },
    {
      "source": "/review/undefined/",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/review/null/",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/blog/undefined/",
      "destination": "/blog/",
      "permanent": false
    },
    {
      "source": "/lenders/:slug/",
      "destination": "/review/:slug/",
      "permanent": true
    },
    {
      "source": "/lender/:slug/",
      "destination": "/review/:slug/",
      "permanent": true
    },
    {
      "source": "/reviews/:slug/",
      "destination": "/review/:slug/",
      "permanent": true
    },
    {
      "source": "/review/thinksmart-financial/",
      "destination": "/personal-loans/",
      "permanent": true
    },
    {
      "source": "/review/thinksmart-financial",
      "destination": "/personal-loans/",
      "permanent": true
    },
    {
      "source": "/review/ebay-new-york-office/",
      "destination": "/categories/credit-repair/",
      "permanent": true
    },
    {
      "source": "/review/ebay-new-york-office",
      "destination": "/categories/credit-repair/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {"key": "X-Content-Type-Options", "value": "nosniff"},
        {"key": "X-Frame-Options", "value": "SAMEORIGIN"},
        {"key": "Referrer-Policy", "value": "strict-origin-when-cross-origin"},
        {"key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()"}
      ]
    }
  ]
}
